{%- liquid
  assign og_title = page_title | default: shop.name
  assign og_url = canonical_url | default: request.origin
  assign og_type = 'website'
  if page_description != blank
    assign og_description = page_description
  elsif request.page_type == 'collection' and collection.description != blank
    assign og_description = collection.description | strip_html | strip_newlines | truncate: 160
  else
    assign og_description = shop.description | default: shop.name
  endif

  if request.page_type == 'product'
    assign og_type = 'product'
  elsif request.page_type == 'article'
    assign og_type = 'article'
  elsif request.page_type == 'password'
    assign og_url = request.origin
  endif
%}

<meta property="og:site_name" content="{{ shop.name }}">
<meta property="og:url" content="{{ og_url }}">
<meta property="og:title" content="{{ og_title | escape }}">
<meta property="og:type" content="{{ og_type }}">
<meta property="og:description" content="{{ og_description | escape }}">

{%- if page_image -%}
  <meta property="og:image" content="http:{{ page_image | image_url }}">
  <meta property="og:image:secure_url" content="https:{{ page_image | image_url }}">
  <meta property="og:image:width" content="{{ page_image.width }}">
  <meta property="og:image:height" content="{{ page_image.height }}">
{%- endif -%}

{%- if request.page_type == 'product' -%}
  <meta property="og:price:amount" content="{{ product.price | money_without_currency | strip_html }}">
  <meta property="og:price:currency" content="{{ cart.currency.iso_code }}">
{%- endif -%}

{%- if settings.social_twitter_link != blank -%}
  <meta name="twitter:site" content="{{ settings.social_twitter_link | split: 'twitter.com/' | last | prepend: '@' }}">
{%- endif -%}
<meta name="twitter:card" content="summary_large_image">
<meta name="twitter:title" content="{{ og_title | escape }}">
<meta name="twitter:description" content="{{ og_description | escape }}">

{%- comment -%} AI Readiness: permit large snippets and image previews for AI answer engines {%- endcomment -%}
<meta name="robots" content="max-snippet:-1, max-image-preview:large, max-video-preview:-1">

{%- comment -%} AI content purpose signals {%- endcomment -%}
<meta name="ai-content-purpose" content="product-catalog, b2b-wholesale, restaurant-equipment, commercial-kitchen">
<meta name="dcterms.subject" content="Restaurant Equipment; Commercial Kitchen; Foodservice; B2B Wholesale">
<meta name="dcterms.type" content="Dataset">
<meta name="dcterms.publisher" content="Celebrate Festival Inc">
<meta name="dcterms.language" content="en-US">

{%- comment -%} Page-type specific AI hints {%- endcomment -%}
{%- if request.page_type == 'product' and product -%}
  <meta name="ai-entity-type" content="Product">
  <meta name="ai-entity-id" content="shopify:product:{{ product.id }}">
  <meta name="product:price:amount" content="{{ product.price | money_without_currency }}">
  <meta name="product:price:currency" content="{{ cart.currency.iso_code }}">
  <meta name="product:availability" content="{% if product.available %}in stock{% else %}out of stock{% endif %}">
  <meta name="product:condition" content="new">
  <meta name="product:brand" content="{{ product.vendor | escape }}">
{%- elsif request.page_type == 'collection' and collection -%}
  <meta name="ai-entity-type" content="ProductCollection">
  <meta name="ai-entity-id" content="shopify:collection:{{ collection.id }}">
{%- endif -%}
