<script>
(function() {
  if (window.__cfCompactAqSuccess) {
    document.addEventListener('DOMContentLoaded', function() {
      var modal = document.getElementById('cf-compact-aq-modal');
      var body = document.getElementById('cf-compact-aq-form-body');
      if (modal && body) {
        body.innerHTML = '<div style="text-align:center;padding:30px 20px;">' +
          '<div style="width:56px;height:56px;background:linear-gradient(135deg,#10b981,#059669);border-radius:50%;display:flex;align-items:center;justify-content:center;margin:0 auto 16px;font-size:28px;color:#fff;">&#10003;</div>' +
          '<h4 style="font-family:Montserrat,sans-serif;font-size:16px;color:#1a365d;margin:0 0 8px 0;">Question Submitted!</h4>' +
          '<p style="font-size:13px;color:#718096;margin:0;line-height:1.5;">Thank you! Our team will respond within 24 hours.</p>' +
          '</div>';
        modal.classList.add('active');
      }
    });
  }
  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape') {
      var modal = document.getElementById('cf-compact-aq-modal');
      if (modal) modal.classList.remove('active');
    }
  });
})();
