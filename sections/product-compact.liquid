  ════════════════════════════════════════════
{%- endcomment -%}
<div class="compact-product-lightbox" id="compact-lightbox">
  <button class="lb-close" id="compact-lb-close">&#10005;</button>
  <button class="lb-nav lb-prev" id="compact-lb-prev">&#8249;</button>
  <div class="lb-content">
    <img class="lb-image" id="compact-lb-image" src="" alt="">
