{%- comment -%} ── F1: Image Gallery + Lightbox ── {%- endcomment -%}
<script>
(function() {
  'use strict';
  if (window.__compactGalleryInit) return;
  window.__compactGalleryInit = true;

  let currentIdx = 0;
  let allImgs = [];

  function getSizedUrl(url, w) {
    if (!url) return url;
    let base = url.split('?')[0];
    let vP = '';
    const m = url.match(/[?&](v=[^&]+)/);
    if (m) vP = '?' + m[1];
    base = base.replace(/_\d+x\d*/i, '');
    base = base.replace(/_(pico|icon|thumb|small|compact|medium|large|grande|master)/i, '');
    return base + vP + (vP ? '&' : '?') + 'width=' + w;
  }

  function getBaseUrl(url) {
    if (!url) return '';
    let base = url.split('?')[0];
    base = base.replace(/^https?:\/\//, '//');
    base = base.replace(/_\d+x\d*/i, '');
    base = base.replace(/_(pico|icon|thumb|small|compact|medium|large|grande|master)/i, '');
    return base;
  }

  function buildVideoEmbed(mediaItem) {
    if (mediaItem.type === 'video' && mediaItem.sources && mediaItem.sources.length) {
      var mp4 = mediaItem.sources.find(function(s) { return s.mime_type === 'video/mp4'; }) || mediaItem.sources[0];
      return '<video controls playsinline style="width:100%;height:100%;object-fit:contain;background:#000;">' +
        '<source src="' + mp4.url + '" type="' + mp4.mime_type + '">' +
        'Your browser does not support the video tag.</video>';
    }
    if (mediaItem.type === 'external_video') {
      var src = '';
      if (mediaItem.host === 'youtube') {
        src = 'https://www.youtube.com/embed/' + mediaItem.external_id + '?autoplay=1&rel=0';
      } else if (mediaItem.host === 'vimeo') {
        src = 'https://player.vimeo.com/video/' + mediaItem.external_id + '?autoplay=1';
      }
      return '<iframe src="' + src + '" style="width:100%;height:100%;border:none;" allow="autoplay; encrypted-media; fullscreen" allowfullscreen></iframe>';
    }
    return '';
  }

  function init() {
    var mainImg = document.getElementById('compact-main-img');
    var thumbs = document.querySelectorAll('.compact-thumb');
    var videoPlayer = document.getElementById('compact-video-player');
    var zoomBtn = document.getElementById('compact-zoom-btn');
    var zoomIndicator = document.querySelector('.compact-zoom-indicator');
    if (!mainImg) return;

    // Load media data from embedded JSON
    var allMedia = [];
    var mediaDataEl = document.getElementById('compact-media-data');
    if (mediaDataEl) {
      try { allMedia = JSON.parse(mediaDataEl.textContent); } catch(e) { allMedia = []; }
    }

    // Fallback: build from thumbs if no media data
    if (allMedia.length === 0) {
      thumbs.forEach(function(t, i) {
        var img = t.querySelector('img');
        if (img && img.src) {
          allMedia.push({ type: 'image', src: img.src, alt: img.alt || 'Image ' + (i+1) });
        }
      });
    }
    // If still empty, add the main image
    if (allMedia.length === 0 && mainImg.src) {
      allMedia.push({ type: 'image', src: mainImg.src, alt: mainImg.alt || 'Product image' });
    }

    // Keep allImgs for backward compatibility (variant image matching)
    allImgs = allMedia.map(function(m) {
      var imgSrc = m.src || m.preview || '';
      return { baseUrl: getBaseUrl(imgSrc), src: imgSrc, alt: m.alt || '' };
    });

    function stopVideo() {
      if (videoPlayer) {
        videoPlayer.innerHTML = '';
        videoPlayer.style.display = 'none';
      }
      mainImg.style.display = '';
      if (zoomBtn) zoomBtn.style.display = '';
      if (zoomIndicator) zoomIndicator.style.display = '';
    }

    function showVideo(mediaItem) {
      var html = buildVideoEmbed(mediaItem);
      if (!html) return;
      mainImg.style.display = 'none';
      if (zoomBtn) zoomBtn.style.display = 'none';
      if (zoomIndicator) zoomIndicator.style.display = 'none';
      videoPlayer.innerHTML = html;
      videoPlayer.style.display = 'flex';
    }

    function switchMedia(idx) {
      if (idx < 0 || idx >= allMedia.length) return;
      currentIdx = idx;
      var m = allMedia[idx];
      thumbs.forEach(function(t, i) { t.classList.toggle('active', i === idx); });

      if (m.type === 'image') {
        stopVideo();
        var imgSrc = m.src || '';
        mainImg.src = getSizedUrl(imgSrc, 800);
        if (m.srcset) {
          mainImg.srcset = m.srcset;
        } else {
          mainImg.srcset = getSizedUrl(imgSrc,400)+' 400w,'+getSizedUrl(imgSrc,600)+' 600w,'+getSizedUrl(imgSrc,800)+' 800w,'+getSizedUrl(imgSrc,1000)+' 1000w';
        }
        mainImg.alt = m.alt;
      } else if (m.type === 'video' || m.type === 'external_video') {
        showVideo(m);
      } else {
        // model or unknown — show preview image
        stopVideo();
        var preview = m.preview || '';
        if (preview) {
          mainImg.src = getSizedUrl(preview, 800);
          mainImg.srcset = '';
          mainImg.alt = m.alt;
        }
      }
    }

    thumbs.forEach(function(t, i) {
      t.style.cursor = 'pointer';
      t.addEventListener('click', function(e) { e.preventDefault(); switchMedia(i); });
    });

    // Lightbox
    var lb = document.getElementById('compact-lightbox');
    var lbImg = document.getElementById('compact-lb-image');
    var lbVideo = document.getElementById('compact-lb-video');
    var lbCounter = document.getElementById('compact-lb-counter');

    function openLb(idx) {
      if (allMedia.length === 0) return;
      currentIdx = idx;
      updateLb();
      lb.classList.add('active');
      document.body.style.overflow = 'hidden';
    }
    function closeLb() {
      lb.classList.remove('active');
      document.body.style.overflow = '';
      // Stop any lightbox video
      if (lbVideo) { lbVideo.innerHTML = ''; lbVideo.style.display = 'none'; }
      if (lbImg) lbImg.style.display = '';
    }
    function updateLb() {
      if (currentIdx < 0 || currentIdx >= allMedia.length) return;
      var m = allMedia[currentIdx];
      lbCounter.textContent = (currentIdx+1) + ' / ' + allMedia.length;
      var prevBtn = document.getElementById('compact-lb-prev');
      var nextBtn = document.getElementById('compact-lb-next');
      if (allMedia.length <= 1) { prevBtn.style.display='none'; nextBtn.style.display='none'; }
      else { prevBtn.style.display=''; nextBtn.style.display=''; }

      if (m.type === 'video' || m.type === 'external_video') {
        lbImg.style.display = 'none';
        lbVideo.innerHTML = buildVideoEmbed(m);
        lbVideo.style.display = 'flex';
      } else {
        lbVideo.innerHTML = '';
        lbVideo.style.display = 'none';
        lbImg.style.display = '';
        var imgSrc = m.src || m.preview || '';
        lbImg.src = m.zoom ? m.zoom : getSizedUrl(imgSrc, 1600);
        lbImg.alt = m.alt;
      }
    }
    function navLb(dir) {
      // Stop current video before navigating
      if (lbVideo) { lbVideo.innerHTML = ''; lbVideo.style.display = 'none'; }
      currentIdx += dir;
      if (currentIdx < 0) currentIdx = allMedia.length - 1;
      if (currentIdx >= allMedia.length) currentIdx = 0;
      updateLb();
    }

    // Open via zoom button or main image click
    if (zoomBtn) zoomBtn.addEventListener('click', function() { openLb(currentIdx); });
    mainImg.addEventListener('click', function() { openLb(currentIdx); });

    document.getElementById('compact-lb-close').addEventListener('click', closeLb);
    document.getElementById('compact-lb-prev').addEventListener('click', function() { navLb(-1); });
    document.getElementById('compact-lb-next').addEventListener('click', function() { navLb(1); });
    lb.addEventListener('click', function(e) { if (e.target === lb) closeLb(); });
    document.addEventListener('keydown', function(e) {
      if (!lb.classList.contains('active')) return;
      if (e.key === 'Escape') closeLb();
      if (e.key === 'ArrowLeft') navLb(-1);
      if (e.key === 'ArrowRight') navLb(1);
    });

    currentIdx = 0;
    thumbs.forEach(function(t, i) { t.classList.toggle('active', i === 0); });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }

  // Expose helpers globally for variant handler
  window.switchProductImage = function(url) {
    var mainImg = document.getElementById('compact-main-img');
    var videoPlayer = document.getElementById('compact-video-player');
    if (mainImg && url) {
      // When switching variant image, stop any playing video
      if (videoPlayer) { videoPlayer.innerHTML = ''; videoPlayer.style.display = 'none'; }
      mainImg.style.display = '';
      var zoomBtn = document.getElementById('compact-zoom-btn');
      var zoomIndicator = document.querySelector('.compact-zoom-indicator');
      if (zoomBtn) zoomBtn.style.display = '';
      if (zoomIndicator) zoomIndicator.style.display = '';
      mainImg.src = getSizedUrl(url, 800);
      mainImg.srcset = getSizedUrl(url,400)+' 400w,'+getSizedUrl(url,600)+' 600w,'+getSizedUrl(url,800)+' 800w,'+getSizedUrl(url,1000)+' 1000w';
    }
  };
  window.cfGetShopifySizedUrl = getSizedUrl;
  window.cfGetBaseUrl = getBaseUrl;
})();
</script>

{%- comment -%} ── F2: Variant Selection Handler ── {%- endcomment -%}
<script>
(function() {
  'use strict';

  const sectionId = '{{ section.id }}';
  const productJson = {{ product | json }};

  const variantMap = {};
  productJson.variants.forEach(function(v) { variantMap[v.id] = v; });

  // Build inventory map from server-side data (reliable — storefront /variants/.js omits qty)
  const invMap = {};
  try {
    var sppData = JSON.parse(document.getElementById('cf-spp-variants-data').textContent);
    sppData.forEach(function(d) {
      invMap[d.variant_id] = { qty: d.inv_qty || 0, managed: d.inv_managed === 'shopify' };
    });
  } catch(e) {}

  let variantWshMap = window.cfVariantWshMap || {};

  const isMember = {{ is_member | json }};
  const isOwnBrand = {{ is_own_brand | json }};
  const isIndianVendor = {{ is_indian_vendor | json }};
  const enableMemberPricing = {{ enable_member_pricing | json }};
  const filterForCph = {{ filter_variants_for_cph | json }};
  const cphAllowedVariantIds = [{{ cph_variant_ids }}];
  const memberPriceBadge = window.cfMemberPriceBadge || {{ member_price_badge | json }};

  // Listen for BDR API response
  document.addEventListener('cf:wholesale-prices-ready', function(e) {
    variantWshMap = e.detail || {};
    window.cfVariantWshMap = variantWshMap;
    var cv = getSelectedVariant();
    // Fallback for single-variant products: pills are not rendered in the DOM
    // (product.has_only_default_variant = true), so getSelectedVariant()
    // returns null. Fall back to URL param or first variant.
    if (!cv) {
      var params = new URLSearchParams(window.location.search);
      var vidUrl = params.get('variant');
      if (vidUrl) cv = variantMap[parseInt(vidUrl)];
      if (!cv && productJson.variants.length > 0) cv = productJson.variants[0];
    }
    updatePillStates();
    if (cv) updateVariantDisplay(cv);
  });

  function getSelectedVariant() {
    var container = document.getElementById('compact-variant-selects-' + sectionId);
    if (!container) return null;
    var opts = [];
    container.querySelectorAll('.compact-variant-pills').forEach(function(c) {
      var checked = c.querySelector('input[type="radio"]:checked');
      if (checked) opts.push(checked.value);
    });
    for (var i = 0; i < productJson.variants.length; i++) {
      var v = productJson.variants[i];
      var match = true;
      for (var j = 0; j < opts.length; j++) {
        if (v['option' + (j+1)] !== opts[j]) { match = false; break; }
      }
      if (match) return v;
    }
    return null;
  }

  function fmt(cents) {
    if (Shopify && Shopify.formatMoney) return Shopify.formatMoney(cents);
    return '$' + (cents / 100).toFixed(2).replace(/\B(?=(\d{3})+(?!\d))/g, ',');
  }

  function updateVariantDisplay(sv) {
    if (!sv) return;

    var vidInput = document.getElementById('compact-variant-id-' + sectionId);
    var atcBtn = document.getElementById('compact-atc-btn-' + sectionId);
    var mainImg = document.getElementById('compact-main-img');
    var skuEl = document.getElementById('compact-sku');
    var priceUnit = '{{ section.settings.price_unit | default: "Each" }}';

    // Update hidden variant ID
    if (vidInput) vidInput.value = sv.id;

    // Update ATC button
    var isZeroPrice = (sv.price === 0);
    window._cfCompactZeroPrice = isZeroPrice;

    // Toggle zero-price notice
    var zeroPriceNotice = document.getElementById('zero-price-notice-' + sectionId);
    if (zeroPriceNotice) zeroPriceNotice.style.display = isZeroPrice ? '' : 'none';

    // Toggle qty wrapper
    var qtyWrap = document.querySelector('.compact-qty-wrap');
    if (qtyWrap) qtyWrap.style.display = isZeroPrice ? 'none' : '';

    if (atcBtn) {
      if (isZeroPrice) {
        atcBtn.disabled = true;
        atcBtn.innerHTML = 'Contact Us';
      } else if (sv.available) {
        atcBtn.disabled = false;
        atcBtn.innerHTML = '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/></svg> {{ section.settings.add_to_cart_text | default: "Add to Cart" }}';
      } else {
        atcBtn.disabled = true;
        let soldOutText = 'Sold Out';
        if (isIndianVendor) {
          soldOutText = 'Notify me when back in stock';
        }
        atcBtn.innerHTML = soldOutText;
      }
    }

    // Update SKU
    if (skuEl && sv.sku) skuEl.textContent = 'SKU: ' + sv.sku;

    // Update inventory box from server-side inventory map
    (function(variantId) {
      var box = document.getElementById('compact-inventory-box-sidebar-' + sectionId);
      if (!box) return;
      var inv     = invMap[String(variantId)] || { qty: 0, managed: false };
      var tracked = inv.managed;
      var qty     = inv.qty;
      var inStock = tracked && qty >= 1;
      var content = box.querySelector('.cib-content');
      if (!tracked) { box.style.display = 'none'; return; }
      box.style.display = '';
      box.dataset.state = inStock ? 'in_stock' : 'out_of_stock';
      box.dataset.qty   = qty;
      if (inStock) {
        content.innerHTML =
          '<div class="cib-headline cib-headline--green">IN STOCK: Ships in 1 Business Day</div>' +
          '<div class="cib-sub">' +
            '<svg class="cib-check" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>' +
            (qty >= 200 ? '200+' : qty) + ' in Stock' +
          '</div>';
      } else {
        content.innerHTML =
          '<div class="cib-headline cib-headline--dark">Typically ships in <strong>1 \u2013 3 Business Days</strong></div>' +
          '<div class="cib-sub cib-sub--coral">Shipped directly from manufacturer</div>';
      }
    })(sv.id);

    // Pricing data
    var wshData = variantWshMap[sv.id] || { hasWsh: false, wshPrice: 0, variantPrice: sv.price };
    var hasWsh = wshData.hasWsh;
    var wshPrice = wshData.wshPrice;
    var vPrice = sv.price;
    var vCompare = sv.compare_at_price || 0;

    var pricingCard = document.querySelector('.compact-product .pricing-card');
    var priceDisplay = pricingCard ? pricingCard.querySelector('.compact-price-display') : null;

    if (priceDisplay && enableMemberPricing && isMember) {
      // MEMBER VIEWING
      if (hasWsh && wshData.hasDiscount) {
        // Dual-column layout
        var regFmt = fmt(vPrice);
        var memFmt = fmt(wshPrice);
        var savings = vPrice - wshPrice;
        var savePct = Math.round((savings / vPrice) * 100);

        priceDisplay.innerHTML =
          '<div class="compact-price-row">' +
            '<div class="compact-price-col price-regular">' +
              '<div class="compact-price-label">Retail Price</div>' +
              '<div class="compact-price-amount">' + regFmt + '</div>' +
            '</div>' +
            '<div class="compact-price-col price-member">' +
              '<div class="compact-price-label">' + memberPriceBadge + '</div>' +
              '<div class="compact-price-amount">' + memFmt + '<span class="compact-price-unit">/' + priceUnit + '</span></div>' +
              (savings > 0 ? '<div class="compact-save-badge">Save ' + savePct + '%</div>' : '') +
            '</div>' +
          '</div>';
      } else {
        // Single column — no WSH for this variant
        var dpFmt = fmt(vPrice);
        var html = '<div class="compact-price-single" id="compact-price-box">';
        if (vCompare > vPrice) {
          html += '<div class="compact-price-label">Sale Price</div>';
          html += '<div class="compact-compare-strike"><s>' + fmt(vCompare) + '</s></div>';
        } else {
          html += '<div class="compact-price-label">Price</div>';
        }
        html += '<div class="compact-price-amount">' + dpFmt + '<span class="compact-price-unit">/' + priceUnit + '</span></div>';
        if (vCompare > vPrice) {
          var sp = Math.round(((vCompare - vPrice) / vCompare) * 100);
          html += '<div class="compact-sale-savings">Save ' + sp + '%</div>';
        }
        html += '</div>';
        priceDisplay.innerHTML = html;
      }
    } else if (priceDisplay) {
      // NON-MEMBER — update single price
      var priceBox = priceDisplay.querySelector('.compact-price-single');
      if (priceBox) {
        var dpFmt = fmt(vPrice);
        var html = '';
        if (vCompare > vPrice) {
          html += '<div class="compact-price-label">Sale Price</div>';
          html += '<div class="compact-compare-strike"><s>' + fmt(vCompare) + '</s></div>';
        } else {
          html += '<div class="compact-price-label">Price</div>';
        }
        html += '<div class="compact-price-amount">' + dpFmt + '<span class="compact-price-unit">/' + priceUnit + '</span></div>';
        if (vCompare > vPrice) {
          var sp = Math.round(((vCompare - vPrice) / vCompare) * 100);
          html += '<div class="compact-sale-savings">Save ' + sp + '%</div>';
        }
        priceBox.innerHTML = html;
      }

      // Dynamic CTA toggling
      var loginCta = pricingCard.querySelector('.compact-spp-login');
      var callCta = pricingCard.querySelector('.compact-spp-call');

      if (hasWsh && isOwnBrand) {
        if (!loginCta) {
          loginCta = document.createElement('a');
          loginCta.href = '/account/login?return_url=' + encodeURIComponent(window.location.pathname);
          loginCta.className = 'compact-cta-login compact-spp-login';
          loginCta.innerHTML = '<span class="compact-cta-icon">&#128274;</span> Login for Member Pricing';
          var fin = pricingCard.querySelector('.compact-financing');
          if (fin) pricingCard.insertBefore(loginCta, fin);
          else pricingCard.appendChild(loginCta);
        }
        if (loginCta) loginCta.style.display = '';
        if (callCta) callCta.style.display = 'none';
      } else if (hasWsh && !isOwnBrand) {
        if (!callCta) {
          callCta = document.createElement('a');
          callCta.href = 'tel:+14086739999';
          callCta.className = 'compact-cta-call compact-spp-call';
          callCta.innerHTML = '<span class="compact-cta-icon">&#128222;</span> Call Us For Details - (408) 673-9999';
          var fin = pricingCard.querySelector('.compact-financing');
          if (fin) pricingCard.insertBefore(callCta, fin);
          else pricingCard.appendChild(callCta);
        }
        if (callCta) callCta.style.display = '';
        if (loginCta) loginCta.style.display = 'none';
      } else {
        if (loginCta) loginCta.style.display = 'none';
        if (callCta) callCta.style.display = 'none';
      }
    }

    // Update sticky bar price
    var stickyPrice = document.getElementById('compact-sticky-price');
    if (stickyPrice) {
      stickyPrice.textContent = (isMember && hasWsh) ? fmt(wshPrice) : fmt(vPrice);
    }

    // Update data-cf-* attributes on pricing card
    if (pricingCard) {
      pricingCard.setAttribute('data-cf-variant-id', sv.id);
      pricingCard.setAttribute('data-cf-price', sv.price);
      pricingCard.setAttribute('data-cf-compare-at-price', sv.compare_at_price || '');
    }

    // Update image if variant has featured image
    if (sv.featured_image && mainImg) {
      // Stop any playing video when switching variants
      if (window.switchProductImage) window.switchProductImage(sv.featured_image.src);
      var viUrl = sv.featured_image.src;
      var getSized = window.cfGetShopifySizedUrl || function(u) { return u; };
      mainImg.src = getSized(viUrl, 800);
      mainImg.srcset = getSized(viUrl,400)+' 400w,'+getSized(viUrl,600)+' 600w,'+getSized(viUrl,800)+' 800w,'+getSized(viUrl,1000)+' 1000w';
      mainImg.alt = sv.featured_image.alt || sv.title;

      var varBase = (window.cfGetBaseUrl || function(u){return u;})(viUrl);
      document.querySelectorAll('.compact-thumb').forEach(function(t, i) {
        var ti = t.querySelector('img');
        if (ti) {
          var tb = (window.cfGetBaseUrl || function(u){return u;})(ti.src);
          t.classList.toggle('active', tb === varBase);
        }
      });
    }

    // Update URL
    if (history.replaceState) {
      history.replaceState(null, '', window.location.pathname + '?variant=' + sv.id);
    }
  }

  // Debounce guard
  var _lastVid = null;

  // Re-evaluate which pills are valid/unavailable/soldout based on current selections.
  // Runs after every pill change so cross-option unavailable combos show as strikethrough.
  function updatePillStates() {
    var container = document.getElementById('compact-variant-selects-' + sectionId);
    if (!container) return;
    var pillGroups = Array.prototype.slice.call(container.querySelectorAll('.compact-variant-pills'));
    var numGroups = pillGroups.length;
    if (numGroups <= 1) return;

    // Snapshot current selections
    var currentSel = pillGroups.map(function(g) {
      var checked = g.querySelector('input[type="radio"]:checked');
      return checked ? checked.value : null;
    });

    pillGroups.forEach(function(group, gIdx) {
      var radios = Array.prototype.slice.call(group.querySelectorAll('input[type="radio"]'));
      radios.forEach(function(radio) {
        var val = radio.value;
        var hasVariant = false;
        var hasAvailable = false;

        for (var i = 0; i < productJson.variants.length; i++) {
          var v = productJson.variants[i];
          var match = true;
          for (var j = 0; j < numGroups; j++) {
            var required = (j === gIdx) ? val : currentSel[j];
            if (required !== null && v['option' + (j + 1)] !== required) { match = false; break; }
          }
          if (match) {
            hasVariant = true;
            if (v.available) hasAvailable = true;
          }
        }

        if (!hasVariant) {
          // Combination doesn't exist — strikethrough
          radio.disabled = true;
        } else if (!hasAvailable) {
          // Exists but sold out — also disabled/strikethrough
          radio.disabled = true;
        } else {
          radio.disabled = false;
        }
      });

      // If the currently selected pill in this group just became disabled,
      // auto-advance to the first enabled pill in the group.
      var checkedRadio = group.querySelector('input[type="radio"]:checked');
      if (checkedRadio && checkedRadio.disabled) {
        var firstEnabled = group.querySelector('input[type="radio"]:not([disabled])');
        if (firstEnabled) {
          firstEnabled.checked = true;
          currentSel[gIdx] = firstEnabled.value;
        }
      }
    });
  }

  window.handleCompactVariantChange = function(radio, sid) {
    updatePillStates();
    var sv = getSelectedVariant();
    if (sv) { _lastVid = sv.id; updateVariantDisplay(sv); }
  };

  // Backup listener
  document.querySelectorAll('.compact-variant-pills input[type="radio"]').forEach(function(r) {
    r.addEventListener('change', function(e) {
      e.stopPropagation();
      var sv = getSelectedVariant();
      if (sv && sv.id !== _lastVid) { _lastVid = sv.id; updateVariantDisplay(sv); }
    });
  });

  // Backup click on pill wrappers
  document.querySelectorAll('.compact-variant-pill').forEach(function(pill) {
    pill.addEventListener('click', function(e) {
      if (e.target.tagName === 'INPUT') return;
      var r = pill.querySelector('input[type="radio"]');
      if (r && !r.checked) { r.checked = true; r.dispatchEvent(new Event('change', {bubbles:false})); }
    });
  });

  // CPH: Programmatically select pills for a variant
  function selectVariantPills(variant) {
    var container = document.getElementById('compact-variant-selects-' + sectionId);
    if (!container) return;
    container.querySelectorAll('.compact-variant-pills').forEach(function(c, idx) {
      var optVal = variant['option' + (idx+1)];
      if (optVal) {
        c.querySelectorAll('input[type="radio"]').forEach(function(r) { r.checked = (r.value === optVal); });
      }
    });
  }

  // Initialize from URL
  function initFromUrl() {
    var params = new URLSearchParams(window.location.search);
    var vidUrl = params.get('variant');

    if (filterForCph && cphAllowedVariantIds.length > 0) {
      if (vidUrl) {
        var uid = parseInt(vidUrl);
        if (!cphAllowedVariantIds.includes(uid)) {
          var fv = variantMap[cphAllowedVariantIds[0]];
          if (fv) { selectVariantPills(fv); updateVariantDisplay(fv); return; }
        }
      }
      var sv = getSelectedVariant();
      if (sv) { updateVariantDisplay(sv); return; }
    }

    if (vidUrl) {
      var pv = variantMap[parseInt(vidUrl)];
      if (pv) { updateVariantDisplay(pv); return; }
    }

    var sv = getSelectedVariant();
    if (sv) {
      var fv = productJson.variants[0];
      if (sv.id !== fv.id) updateVariantDisplay(sv);
    }
  }

  if (document.readyState === 'loading') {
