.cf-aq-body { padding:20px 24px 24px; }
.cf-aq-product-tag { display:flex; align-items:center; gap:12px; background:#f7fafc; border:1px solid #e2e8f0; border-radius:8px; padding:10px 14px; margin-bottom:18px; }
.cf-aq-product-tag img { width:48px; height:48px; object-fit:contain; border-radius:6px; background:#fff; border:1px solid #e2e8f0; }
.cf-aq-product-name { display:block; font-size:13px; font-weight:600; color:#1a365d; line-height:1.3; }
