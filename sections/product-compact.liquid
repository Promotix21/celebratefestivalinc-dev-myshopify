{%- comment -%} ── F3: Carousel auto-slide ── {%- endcomment -%}
<script>
{%- comment -%} Carousel, quickAdd, accordion — deferred to reduce main-thread blocking {%- endcomment -%}
(function(){var d=function(){
  window.slideCarousel = function(wrapperId, dir) {
    var wrap = document.getElementById(wrapperId);
    if (!wrap) return;
    var track = wrap.querySelector('.compact-carousel-track');
    if (!track) return;
    var card = track.querySelector('.compact-carousel-card');
    if (!card) return;
    var cardW = card.offsetWidth + 12;
    track.scrollBy({ left: dir * cardW * 2, behavior: 'smooth' });
  };
  window.quickAdd = function(variantId, btn) {
    if (!variantId) return;
    var qtyInput = btn.parentElement.querySelector('input[type="number"]');
    var qty = qtyInput ? parseInt(qtyInput.value) || 1 : 1;
    var origText = btn.textContent;
    btn.disabled = true; btn.textContent = '...';
    fetch('/cart/add.js', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ id: variantId, quantity: qty }) })
    .then(function(r) { return r.json(); })
    .then(function(data) {
      btn.textContent = '\u2713'; btn.style.background = '#10b981';
      fetch('/cart.js').then(function(r){return r.json();}).then(function(cart) {
        document.querySelectorAll('.cart-count-bubble span, [data-cart-count]').forEach(function(el) { el.textContent = cart.item_count; });
      });
      if (typeof window.cfShowCartToast === 'function') window.cfShowCartToast(data, qty);
      setTimeout(function() { btn.textContent = origText; btn.style.background = ''; btn.disabled = false; }, 2000);
    })
    .catch(function() { btn.textContent = 'Error'; setTimeout(function() { btn.textContent = origText; btn.disabled = false; }, 2000); });
  };
  window.toggleAccordion = function(header) { var item = header.parentElement; if (item) item.classList.toggle('open'); };
};
if ('requestIdleCallback' in window) requestIdleCallback(d); else setTimeout(d, 200);
})();
</script>

{%- comment -%} ── F5: FBT handler (deferred) ── {%- endcomment -%}
<script>
(function(){var d=function(){
  window.updateFbtTotal = function() {
    var basePrice = parseInt(document.getElementById('fbt-total')?.getAttribute('data-base-price')) || 0;
    var total = basePrice;
    document.querySelectorAll('#compact-fbt input[type="checkbox"]').forEach(function(cb) {
      if (cb.checked) total += parseInt(cb.getAttribute('data-fbt-price')) || 0;
    });
    var el = document.getElementById('fbt-total');
    if (el) {
      if (Shopify && Shopify.formatMoney) el.textContent = Shopify.formatMoney(total);
      else el.textContent = '$' + (total / 100).toFixed(2).replace(/\B(?=(\d{3})+(?!\d))/g, ',');
    }
  };
  window.addAllFbt = function() {
    var items = [];
    var mainVid = document.querySelector('.compact-product .pricing-card')?.getAttribute('data-cf-variant-id');
    var mainQty = parseInt(document.getElementById('compact-qty-input')?.value) || 1;
    if (mainVid) items.push({ id: parseInt(mainVid), quantity: mainQty });
    document.querySelectorAll('#compact-fbt input[type="checkbox"]:checked').forEach(function(cb) {
      var vid = cb.getAttribute('data-fbt-variant'); if (vid) items.push({ id: parseInt(vid), quantity: 1 });
    });
    if (items.length === 0) return;
    var btn = document.querySelector('.compact-fbt-add-btn');
    if (btn) { btn.disabled = true; btn.textContent = 'Adding...'; }
    fetch('/cart/add.js', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ items: items }) })
    .then(function(r) { return r.json(); })
    .then(function(data) {
      if (btn) { btn.textContent = 'Added!'; btn.style.background = '#10b981'; }
      fetch('/cart.js').then(function(r){return r.json();}).then(function(cart) {
        document.querySelectorAll('.cart-count-bubble span, [data-cart-count]').forEach(function(el) { el.textContent = cart.item_count; });
      });
      setTimeout(function() { if (btn) { btn.textContent = 'Add All to Cart'; btn.style.background = ''; btn.disabled = false; } }, 2000);
    })
    .catch(function() { if (btn) { btn.textContent = 'Error'; setTimeout(function() { btn.textContent = 'Add All to Cart'; btn.disabled = false; }, 2000); } });
  };
};
if ('requestIdleCallback' in window) requestIdleCallback(d); else setTimeout(d, 200);
})();
</script>

{%- comment -%} ── F6: Sticky ATC Bar ── {%- endcomment -%}
<script>
(function() {
  var stickyBar = document.getElementById('compact-sticky-bar');
  var mainAtcBtn = document.querySelector('.compact-product .compact-atc-btn');
  var ticking = false;

  function check() {
    if (!mainAtcBtn || !stickyBar) return;
    // Never show sticky bar for zero-price products
    if (window._cfCompactZeroPrice) { stickyBar.classList.remove('visible'); return; }
    var r = mainAtcBtn.getBoundingClientRect();
    var hidden = r.bottom < 0 || r.top > window.innerHeight;
    if (hidden) {
      stickyBar.classList.add('visible');
      stickyBar.style.display = 'block';
    } else {
      stickyBar.classList.remove('visible');
    }
  }

  window.addEventListener('scroll', function() {
    if (!ticking) {
      window.requestAnimationFrame(function() { check(); ticking = false; });
      ticking = true;
    }
  });

  window.compactStickyQty = function(d) {
    var inp = document.getElementById('compact-sticky-qty');
    var v = parseInt(inp.value) || 1;
    inp.value = Math.max(1, v + d);
  };

  window.compactStickyAdd = function() {
    var vid = document.querySelector('.compact-product .pricing-card')?.getAttribute('data-cf-variant-id');
    var qty = parseInt(document.getElementById('compact-sticky-qty').value) || 1;
    var btn = document.getElementById('compact-sticky-add-btn');
    if (!vid) return;

    btn.disabled = true;
    btn.textContent = 'Adding...';

    fetch('/cart/add.js', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ id: parseInt(vid), quantity: qty })
    })
    .then(function(r) { return r.json(); })
    .then(function(data) {
      btn.textContent = 'Added!';
      btn.style.background = 'linear-gradient(135deg, #10b981 0%, #059669 100%)';
      fetch('/cart.js').then(function(r){return r.json();}).then(function(cart) {
        document.querySelectorAll('.cart-count-bubble span, [data-cart-count]').forEach(function(el) { el.textContent = cart.item_count; });
      });
      if (typeof window.cfShowCartToast === 'function') window.cfShowCartToast(data, qty);
      setTimeout(function() { btn.textContent = 'Add to Cart'; btn.style.background = ''; btn.disabled = false; }, 2000);
    })
    .catch(function() {
      btn.textContent = 'Error';
      setTimeout(function() { btn.textContent = 'Add to Cart'; btn.disabled = false; }, 2000);
    });
  };

  setTimeout(check, 500);
})();
</script>
{%- endunless -%}

{%- comment -%} ── F6b: Variant Description — remove app's JSON script, show description ── {%- endcomment -%}
<script>
(function() {
  var target = document.getElementById('variant-description-target');
  if (!target) return;

  function cleanup() {
    /* REMOVE (not hide) every <script> tag the app injects into our container */
    var scripts = target.querySelectorAll('script');
    for (var i = scripts.length - 1; i >= 0; i--) {
      scripts[i].parentNode.removeChild(scripts[i]);
    }

    /* Make sure the description span is visible */
    var descSpan = target.querySelector('[data-variant-description-app="product description"]');
    if (descSpan) {
      descSpan.style.display = 'block';

      /* Add heading once */
      if (!target.querySelector('.vd-heading')) {
        var h3 = document.createElement('h3');
        h3.className = 'vd-heading';
        h3.textContent = 'Variant Details';
        target.insertBefore(h3, descSpan);
      }
    }
  }

  /* Poll until the app has injected content */
  var attempts = 0;
  var interval = setInterval(function() {
    if (target.children.length > 0) cleanup();
    if (++attempts >= 40) clearInterval(interval);
  }, 200);

  /* Watch for app re-injecting on variant change */
  var paused = false;
  var observer = new MutationObserver(function() {
    if (paused) return;
    paused = true;
    cleanup();
    setTimeout(function() { paused = false; }, 100);
  });
  observer.observe(target, { childList: true });
})();
</script>

