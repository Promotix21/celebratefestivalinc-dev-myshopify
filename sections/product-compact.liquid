{% comment %}
  Product - Compact Template
  A denser, WebstaurantStore-inspired product page layout.
  Ports ALL business logic from product-celebrate-festival.liquid:
  - WSH BDR API wholesale pricing
  - CPH variant filtering
  - Vendor-based CTAs (Login for Member Pricing / Call for More Details)
  - Image gallery with lightbox
  - Sticky ATC bar
  - Metafield support (specs, shipping, certifications, resources, FBT)
{% endcomment %}

{%- comment -%}
  ════════════════════════════════════════════
  PART A — Liquid Variables & Data
  ════════════════════════════════════════════
{%- endcomment -%}

{%- liquid
  assign show_demo = section.settings.show_demo_data
  assign enable_member_pricing = section.settings.enable_member_pricing
  assign member_discount = section.settings.member_discount_percent

  # Check if customer is logged in
  assign is_logged_in = false
  assign is_member = false
  if customer
    assign is_logged_in = true
    for tag in customer.tags
      assign tag_lower = tag | downcase
      if tag_lower contains 'wholesale' or tag_lower contains 'plus' or tag_lower contains 'member' or tag_lower contains 'cph' or tag_lower contains 'rou' or tag_lower contains 'margin'
        assign is_member = true
        break
      endif
    endfor
  endif

  # CPH Portal Variant Filtering
  assign is_cph = false
  if customer
    for tag in customer.tags
      assign tag_cph_check = tag | downcase
      if tag_cph_check == 'cph'
        assign is_cph = true
        break
      endif
    endfor
  endif

  # Member price label: always "Member Price" for all wholesale members
  assign member_price_badge = 'Member Price'

  # Check if product is own-brand using settings-driven vendor list
  assign is_own_brand = false
  assign own_brands = settings.own_brand_vendors | downcase | split: ','
  assign vendor_check = product.vendor | downcase | strip
  for brand in own_brands
    assign brand_check = brand | strip
    if vendor_check == brand_check
      assign is_own_brand = true
      break
    endif
  endfor

  # Call-to-order products — listed but not purchasable online
  assign call_to_order = false
  if product.tags contains 'call-to-order'
    assign call_to_order = true
  endif
-%}

{%- comment -%} CPH Variant Filtering — Build allowed variant list {%- endcomment -%}
{%- assign cph_variant_ids = '' -%}
{%- assign cph_variant_count = 0 -%}
{%- assign filter_variants_for_cph = false -%}
{%- if is_cph -%}
  {%- for variant in product.variants -%}
    {%- assign portal_access = variant.metafields.custom.logged_in_portal_variant_access | downcase | strip -%}
    {%- if portal_access == 'cph' -%}
      {%- if cph_variant_count > 0 -%}
        {%- assign cph_variant_ids = cph_variant_ids | append: ',' -%}
      {%- endif -%}
      {%- assign cph_variant_ids = cph_variant_ids | append: variant.id -%}
      {%- assign cph_variant_count = cph_variant_count | plus: 1 -%}
    {%- endif -%}
  {%- endfor -%}
  {%- if cph_variant_count > 0 -%}
    {%- assign filter_variants_for_cph = true -%}
  {%- endif -%}
{%- endif -%}

{%- comment -%} Build CPH-allowed option values for pill filtering {%- endcomment -%}
{%- assign cph_opt1_vals = '' -%}
{%- assign cph_opt2_vals = '' -%}
{%- assign cph_opt3_vals = '' -%}
{%- assign cph_first_opt1 = '' -%}
{%- assign cph_first_opt2 = '' -%}
{%- assign cph_first_opt3 = '' -%}
{%- if filter_variants_for_cph -%}
  {%- assign cph_first_found = false -%}
  {%- for variant in product.variants -%}
    {%- assign portal_access = variant.metafields.custom.logged_in_portal_variant_access | downcase | strip -%}
    {%- if portal_access == 'cph' -%}
      {%- unless cph_first_found -%}
        {%- assign cph_first_opt1 = variant.option1 -%}
        {%- assign cph_first_opt2 = variant.option2 -%}
        {%- assign cph_first_opt3 = variant.option3 -%}
        {%- assign cph_first_found = true -%}
      {%- endunless -%}
      {%- if variant.option1 -%}
        {%- assign cph_opt1_vals = cph_opt1_vals | append: '|||' | append: variant.option1 | append: '|||' -%}
      {%- endif -%}
      {%- if variant.option2 -%}
        {%- assign cph_opt2_vals = cph_opt2_vals | append: '|||' | append: variant.option2 | append: '|||' -%}
      {%- endif -%}
      {%- if variant.option3 -%}
        {%- assign cph_opt3_vals = cph_opt3_vals | append: '|||' | append: variant.option3 | append: '|||' -%}
      {%- endif -%}
    {%- endif -%}
  {%- endfor -%}
{%- endif -%}

{%- comment -%} Pricing — Server-side renders "Price" only. WSH wholesale pricing handled by cf-wholesale-pricing.js {%- endcomment -%}
{%- assign current_variant = product.selected_or_first_available_variant -%}

{%- liquid
  assign has_compare_price = false
  assign original_price = current_variant.price
  assign sale_price = current_variant.price
  if current_variant.compare_at_price != blank and current_variant.compare_at_price > current_variant.price
    assign has_compare_price = true
    assign original_price = current_variant.compare_at_price
    assign sale_price = current_variant.price
  endif

  assign has_wholesale_price = false
  assign retail_price = sale_price
  assign member_price = sale_price
-%}

{%- comment -%} Embed all variant data as JSON for cf-wholesale-pricing.js {%- endcomment -%}
<script type="application/json" id="cf-spp-variants-data">
[
{%- for variant in product.variants -%}
  {
    "variant_id": "{{ variant.id }}",
    "product_id": "{{ product.id }}",
    "compare_at_price": "{{ variant.compare_at_price | default: '' }}",
    "price": "{{ variant.price }}",
    "quantity": 1,
    "send_vd_table": true,
    "handle": "{{ product.handle }}",
    "collection_ids": "{{ product.collections | map: 'id' | join: ',' }}"
  }{%- unless forloop.last -%},{%- endunless -%}
{%- endfor -%}
]
</script>

{%- liquid
  # Vendor Logo Mapping
  assign vendor_logo = ''
  assign vendor_handle = product.vendor | handleize
  assign logo_filename = 'brand-logo-' | append: vendor_handle | append: '.png'
  assign vendor_logo = logo_filename | asset_url

  case vendor_handle
    when 'thunder-group', 'thundergroup'
      assign vendor_logo = 'brand-logo-thunder-group.png' | asset_url
    when 'robot-coupe', 'robotcoupe'
      assign vendor_logo = 'brand-logo-robot-coupe.png' | asset_url
    when 'turbo-air', 'turboair'
      assign vendor_logo = 'brand-logo-turbo-air.png' | asset_url
    when 'global-solutions', 'globalsolutions'
      assign vendor_logo = 'brand-logo-global-solutions.png' | asset_url
    when 'hamilton-beach', 'hamiltonbeach'
      assign vendor_logo = 'brand-logo-hamilton-beach.png' | asset_url
    when 'john-boos', 'johnboos'
      assign vendor_logo = 'brand-logo-john-boos.png' | asset_url
    when 'san-jamar', 'sanjamar'
      assign vendor_logo = 'brand-logo-san-jamar.png' | asset_url
    when 'chef-works', 'chefworks'
      assign vendor_logo = 'brand-logo-chef-works.png' | asset_url
    when 'ice-o-matic', 'iceomatic'
      assign vendor_logo = 'brand-logo-ice-o-matic.png' | asset_url
    when 'la-coppera', 'lacoppera'
      assign vendor_logo = 'brand-logo-la-coppera.png' | asset_url
    when 'nor-lake', 'norlake'
      assign vendor_logo = 'brand-logo-nor-lake.png' | asset_url
    when 'us-cooler', 'uscooler'
      assign vendor_logo = 'brand-logo-us-cooler.png' | asset_url
  endcase

  # Metafields
  assign specs_table = product.metafields.custom.specs_table_pic_pdf
  assign material = product.metafields.custom.material
  assign free_shipping = product.metafields.custom.free_shipping
  assign feature_sections = product.metafields.custom.feature_sections
  assign works_with_products = product.metafields.custom.works_with_products
  assign product_line_products = product.metafields.custom.product_line
  assign warranty_doc = product.metafields.custom.warranty_document
  assign spec_doc = product.metafields.custom.specification
  assign manual_doc = product.metafields.custom.instructions_manual
  assign warranty_text = product.metafields.custom.warranty
  assign spec_sheet = product.metafields.custom.specification_sheet
  assign certifications = product.metafields.custom.certifications
  assign shipment_text = product.metafields.custom.shipment_text1
  assign shipment_text_sub = product.metafields.custom.shipment_text_sub
  assign shipment_tooltip_text = product.metafields.custom.shipment_tooltip_text
  assign dimensions_utilities = product.metafields.custom.dimensions_utilities
  assign product_certificates = product.metafields.custom.product_certificates

  # Related products logic
  assign related_title = section.settings.related_title_default
  assign related_collection_handle = section.settings.related_collection_default

  if product.type == section.settings.conditional_product_type_1 and section.settings.conditional_product_type_1 != blank
    assign related_title = section.settings.conditional_title_1
    assign related_collection_handle = section.settings.conditional_collection_1
  elsif product.type == section.settings.conditional_product_type_2 and section.settings.conditional_product_type_2 != blank
    assign related_title = section.settings.conditional_title_2
    assign related_collection_handle = section.settings.conditional_collection_2
  endif

  if related_collection_handle != blank
    assign related_collection = collections[related_collection_handle]
  else
    if product.collections.size > 0
      assign related_collection = product.collections.first
    endif
  endif
-%}

{{ 'product-compact.css' | asset_url | stylesheet_tag }}

{%- comment -%}
  ════════════════════════════════════════════
  PART B + C — HTML
  ════════════════════════════════════════════
{%- endcomment -%}

<div class="compact-product">

  {%- comment -%} ── Breadcrumb ── {%- endcomment -%}
  {%- if section.settings.show_breadcrumb -%}
  <div class="compact-breadcrumb">
    <a href="/">Home</a>
    <span class="sep">&rsaquo;</span>
    {%- if product.collections.size > 0 -%}
      {%- assign main_collection = product.collections.first -%}
      <a href="{{ main_collection.url }}">{{ main_collection.title }}</a>
      <span class="sep">&rsaquo;</span>
    {%- endif -%}
    <span>{{ product.title | truncate: 50 }}</span>
  </div>
  {%- endif -%}

  {%- comment -%} ── Title Bar ── {%- endcomment -%}
  <div class="compact-title-bar">
    <h1>{{ product.title }}</h1>
    <div class="compact-meta-row">
      {%- if product.vendor != blank -%}
        <span>by <a href="/collections/vendors?q={{ product.vendor | url_encode }}">{{ product.vendor }}</a></span>
      {%- endif -%}
      {%- if current_variant.sku != blank -%}
        <span class="compact-sku-badge" id="compact-sku">{{ current_variant.sku }}</span>
      {%- endif -%}
    </div>
  </div>

  {%- comment -%} ── Two-Column Layout ── {%- endcomment -%}
  <div class="compact-layout">

    {%- comment -%} ═══ LEFT COLUMN ═══ {%- endcomment -%}
    <div class="compact-left">

      {%- comment -%} ── Image Container ── {%- endcomment -%}
      <div class="compact-image-wrap">
        {%- if product.images.size > 1 or show_demo -%}
        <div class="compact-thumb-strip">
          {%- if product.images.size > 1 -%}
            {%- for image in product.images limit: 8 -%}
              <div class="compact-thumb {% if forloop.first %}active{% endif %}" data-image-index="{{ forloop.index0 }}">
                <img src="{{ image | image_url: width: 70 }}" alt="{{ image.alt | escape }}">
              </div>
            {%- endfor -%}
          {%- elsif show_demo -%}
            {%- for i in (1..4) -%}
              <div class="compact-thumb {% if forloop.first %}active{% endif %}" data-image-index="{{ forloop.index0 }}">
                <img src="https://via.placeholder.com/70x70/f7fafc/718096?text={{ i }}" alt="Demo {{ i }}">
              </div>
            {%- endfor -%}
          {%- endif -%}
        </div>
        {%- endif -%}

        <div class="compact-main-image-box">
          {%- if product.featured_image -%}
            <img id="compact-main-img"
                 class="compact-main-image"
                 src="{{ product.featured_image | image_url: width: 800 }}"
                 srcset="{{ product.featured_image | image_url: width: 400 }} 400w,
                         {{ product.featured_image | image_url: width: 600 }} 600w,
                         {{ product.featured_image | image_url: width: 800 }} 800w,
                         {{ product.featured_image | image_url: width: 1000 }} 1000w"
                 sizes="(max-width: 768px) 100vw, 600px"
                 alt="{{ product.featured_image.alt | escape }}"
                 data-zoom-src="{{ product.featured_image | image_url: width: 1600 }}">
          {%- elsif show_demo -%}
            <img id="compact-main-img" class="compact-main-image" src="https://via.placeholder.com/600x600/f7fafc/1a2332?text=Product+Image" alt="Demo Product">
          {%- else -%}
            {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
          {%- endif -%}
          <button type="button" class="compact-zoom-btn" id="compact-zoom-btn" aria-label="Zoom image">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
            </svg>
          </button>
        </div>
      </div>

    </div>{%- comment -%} end .compact-left {%- endcomment -%}

    {%- comment -%} ── BELOW-IMAGE CONTENT (reordered below sidebar on mobile) ── {%- endcomment -%}
    <div class="compact-content-col">

      {%- comment -%} ── Carousel: Works With Products ── {%- endcomment -%}
      {%- if works_with_products.value.size > 0 -%}
      <div class="compact-carousel-section">
        <h3>Works With Products</h3>
        <div class="compact-carousel-wrap" id="carousel-works-with">
          <button class="compact-carousel-nav prev" onclick="slideCarousel('carousel-works-with', -1)" aria-label="Previous">&lsaquo;</button>
          <div class="compact-carousel-track">
            {%- for rp in works_with_products.value limit: 8 -%}
              <div class="compact-carousel-card">
                <a href="{{ rp.url }}">
                  {%- if rp.featured_image -%}
                    <img src="{{ rp.featured_image | image_url: width: 140 }}" alt="{{ rp.title | escape }}" class="compact-carousel-card-img">
                  {%- else -%}
                    <div class="compact-carousel-card-img" style="background:var(--g100);display:flex;align-items:center;justify-content:center;font-size:10px;color:var(--g400);">No image</div>
                  {%- endif -%}
                  <div class="compact-carousel-card-info">
                    <div class="compact-carousel-card-title">{{ rp.title }}</div>
                    <div class="compact-carousel-card-price">{{ rp.price | money }}</div>
                  </div>
                </a>
                <div class="compact-carousel-card-actions">
                  <input type="number" value="1" min="1" aria-label="Quantity">
                  <button type="button" onclick="quickAdd({{ rp.variants.first.id }}, this)">Add to Cart</button>
                </div>
              </div>
            {%- endfor -%}
          </div>
          <button class="compact-carousel-nav next" onclick="slideCarousel('carousel-works-with', 1)" aria-label="Next">&rsaquo;</button>
        </div>
      </div>
      {%- endif -%}

      {%- comment -%} ── Carousel: Other Products from this Line ── {%- endcomment -%}
      {%- if section.settings.show_other_products and product_line_products.value.size > 0 or show_demo -%}
      <div class="compact-carousel-section">
        <h3>{{ related_title }}</h3>
        <div class="compact-carousel-wrap" id="carousel-related">
          <button class="compact-carousel-nav prev" onclick="slideCarousel('carousel-related', -1)" aria-label="Previous">&lsaquo;</button>
          <div class="compact-carousel-track">
            {%- if product_line_products.value.size > 0 -%}
              {%- for rp in product_line_products.value limit: 8 -%}
                <div class="compact-carousel-card">
                  <a href="{{ rp.url }}">
                    {%- if rp.featured_image -%}
                      <img src="{{ rp.featured_image | image_url: width: 140 }}" alt="{{ rp.title | escape }}" class="compact-carousel-card-img">
                    {%- else -%}
                      <div class="compact-carousel-card-img" style="background:var(--g100);display:flex;align-items:center;justify-content:center;font-size:10px;color:var(--g400);">No image</div>
                    {%- endif -%}
                    <div class="compact-carousel-card-info">
                      <div class="compact-carousel-card-title">{{ rp.title }}</div>
                      <div class="compact-carousel-card-price">{{ rp.price | money }}</div>
                    </div>
                  </a>
                  <div class="compact-carousel-card-actions">
                    <input type="number" value="1" min="1" aria-label="Quantity">
                    <button type="button" onclick="quickAdd({{ rp.variants.first.id }}, this)">Add to Cart</button>
                  </div>
                </div>
              {%- endfor -%}
            {%- elsif show_demo -%}
              {%- for i in (1..6) -%}
              <div class="compact-carousel-card">
                <a href="#">
                  <img src="https://via.placeholder.com/140x140/f7fafc/718096?text={{ i }}" alt="Demo" class="compact-carousel-card-img">
                  <div class="compact-carousel-card-info">
                    <div class="compact-carousel-card-title">Related Product {{ i }} Name</div>
                    <div class="compact-carousel-card-price">${{ i }}99.00</div>
                  </div>
                </a>
                <div class="compact-carousel-card-actions">
                  <input type="number" value="1" min="1" aria-label="Quantity">
                  <button type="button">Add to Cart</button>
                </div>
              </div>
              {%- endfor -%}
            {%- endif -%}
          </div>
          <button class="compact-carousel-nav next" onclick="slideCarousel('carousel-related', 1)" aria-label="Next">&rsaquo;</button>
        </div>
      </div>
      {%- endif -%}

      {%- comment -%} ── Product Description ── {%- endcomment -%}
      {%- if product.description != blank or show_demo -%}
      <div class="compact-description">
        <h2>{{ section.settings.description_heading | default: "Product Description" }}</h2>
        <div class="compact-description-body">
          {%- if product.description != blank -%}
            {{ product.description }}
          {%- elsif show_demo -%}
            <p>Demo product description. Your actual product description will appear here.</p>
          {%- endif -%}
        </div>

        {%- if feature_sections != blank -%}
          <h3 style="font-size:14px;font-weight:700;color:var(--navy);margin:16px 0 8px;">Key Features</h3>
          <table class="compact-features-table">
            {%- assign features = feature_sections | split: '|' -%}
            {%- for feature in features -%}
              {%- assign trimmed = feature | strip -%}
              {%- if trimmed != blank -%}
                <tr>
                  <td><span class="feat-icon">&#10003;</span> {{ trimmed }}</td>
                </tr>
              {%- endif -%}
            {%- endfor -%}
          </table>
        {%- endif -%}

        {%- if dimensions_utilities != blank -%}
          <h3 style="font-size:14px;font-weight:700;color:var(--navy);margin:16px 0 8px;">Dimensions & Utilities</h3>
          <table class="compact-dimensions-table">
            {%- assign dim_items = dimensions_utilities | split: '|' -%}
            {%- for item in dim_items -%}
              {%- assign trimmed = item | strip -%}
              {%- if trimmed != blank -%}
                <tr>
                  <td><span class="dim-icon">&#128207;</span> {{ trimmed }}</td>
                </tr>
              {%- endif -%}
            {%- endfor -%}
          </table>
        {%- endif -%}
      </div>
      {%- endif -%}

      {%- comment -%} ── Certifications ── {%- endcomment -%}
      {%- if product_certificates.value.size > 0 -%}
      <div class="compact-certifications">
        {%- for cert_name in product_certificates.value -%}
          {%- assign cert_image = '' -%}
          {%- assign cert_desc = '' -%}
          {%- if cert_name == 'Made in America' -%}
            {%- assign cert_image = 'https://cdn.shopify.com/s/files/1/0562/3483/6013/files/MIA.png?v=1763021316' -%}
            {%- assign cert_desc = 'Made in the United States of America.' -%}
          {%- elsif cert_name == 'NSF Listed' -%}
            {%- assign cert_image = 'https://cdn.shopify.com/s/files/1/0562/3483/6013/files/nsf.png?v=1763021314' -%}
            {%- assign cert_desc = 'Certified by NSF International.' -%}
          {%- elsif cert_name == 'ETL, US & Canada' -%}
            {%- assign cert_image = 'https://cdn.shopify.com/s/files/1/0562/3483/6013/files/elt.png?v=1763021315' -%}
            {%- assign cert_desc = 'Certified by ETL for US & Canada.' -%}
          {%- endif -%}
          {%- if cert_image != '' -%}
          <div class="compact-cert-card">
            <img src="{{ cert_image }}" alt="{{ cert_name }}">
            <div>
              <h4>{{ cert_name }}</h4>
              <p>{{ cert_desc }}</p>
            </div>
          </div>
          {%- endif -%}
        {%- endfor -%}
      </div>
      {%- endif -%}

      {%- comment -%} ── Q&A + Reviews Row ── {%- endcomment -%}
      <div class="compact-qa-review-row">
        {%- if section.settings.enable_qa -%}
        <button type="button" class="compact-qa-btn" onclick="document.getElementById('cf-compact-aq-modal').classList.add('active')">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
          {{ section.settings.qa_button_text | default: 'Ask a Question' }}
        </button>
        {%- endif -%}
        {%- if section.settings.enable_reviews -%}
        <button type="button" class="compact-review-btn" onclick="document.getElementById('shopify-product-reviews-compact')?.scrollIntoView({behavior:'smooth'})">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
          Write a Review
        </button>
        {%- endif -%}
      </div>

      {%- comment -%} ── Reviews container ── {%- endcomment -%}
      {%- if section.settings.enable_reviews -%}
      <div id="shopify-product-reviews-compact" data-id="{{ product.id }}" style="margin-bottom:20px;"></div>
      {%- endif -%}

      {%- comment -%} ── Carousel: You May Also Like (Shopify Recommendations API) ── {%- endcomment -%}
      {%- if section.settings.enable_bottom_related -%}
      <div class="compact-carousel-section" id="carousel-also-like-section" style="display:none;">
        <h3>You May Also Like</h3>
        <div class="compact-carousel-wrap" id="carousel-also-need">
          <button class="compact-carousel-nav prev" onclick="slideCarousel('carousel-also-need', -1)" aria-label="Previous">&lsaquo;</button>
          <div class="compact-carousel-track" id="carousel-also-like-track"></div>
          <button class="compact-carousel-nav next" onclick="slideCarousel('carousel-also-need', 1)" aria-label="Next">&rsaquo;</button>
        </div>
      </div>
      <script>
      (function() {
        var productId = {{ product.id }};
        fetch('/recommendations/products.json?product_id=' + productId + '&limit=8&intent=related')
          .then(function(r) { return r.json(); })
          .then(function(data) {
            var products = data.products;
            if (!products || products.length === 0) return;
            var track = document.getElementById('carousel-also-like-track');
            var section = document.getElementById('carousel-also-like-section');
            if (!track || !section) return;
            products.forEach(function(p) {
              var price = (p.price_min / 100).toLocaleString('en-US', { style: 'currency', currency: 'USD' });
              var img = p.featured_image
                ? '<img src="' + p.featured_image + '&width=140" alt="" class="compact-carousel-card-img">'
                : '<div class="compact-carousel-card-img" style="background:var(--g100);display:flex;align-items:center;justify-content:center;font-size:10px;color:var(--g400);">No image</div>';
              var variantId = p.variants && p.variants[0] ? p.variants[0].id : '';
              var card = document.createElement('div');
              card.className = 'compact-carousel-card';
              card.innerHTML =
                '<a href="' + p.url + '">' +
                  img +
                  '<div class="compact-carousel-card-info">' +
                    '<div class="compact-carousel-card-title">' + p.title + '</div>' +
                    '<div class="compact-carousel-card-price">' + price + '</div>' +
                  '</div>' +
                '</a>' +
                '<div class="compact-carousel-card-actions">' +
                  '<input type="number" value="1" min="1" aria-label="Quantity">' +
                  '<button type="button" onclick="quickAdd(' + variantId + ', this)">Add to Cart</button>' +
                '</div>';
              track.appendChild(card);
            });
            section.style.display = '';
          })
          .catch(function() {});
      })();
      </script>
      {%- endif -%}

    </div>{%- comment -%} end .compact-content-col {%- endcomment -%}

    {%- comment -%} ═══ RIGHT SIDEBAR ═══ {%- endcomment -%}
    <div class="compact-right">

      {%- comment -%} ── Pricing Card ── {%- endcomment -%}
      <div class="pricing-card"
        data-cf-product-id="{{ product.id }}"
        data-cf-variant-id="{{ current_variant.id }}"
        data-cf-price="{{ current_variant.price }}"
        data-cf-compare-at-price="{{ current_variant.compare_at_price }}"
        data-cf-handle="{{ product.handle }}"
        data-cf-collection-ids="{{ product.collections | map: 'id' | join: ',' }}"
      >

        {%- comment -%} Badge row {%- endcomment -%}
        <div class="compact-badge-row">
          {%- if free_shipping -%}
            <span class="compact-badge compact-badge--shipping">Free Shipping</span>
          {%- endif -%}
          {%- if is_member and enable_member_pricing -%}
            <span class="compact-badge compact-badge--member">Member</span>
          {%- endif -%}
          {%- if has_compare_price -%}
            <span class="compact-badge compact-badge--sale">SALE</span>
          {%- endif -%}
        </div>

        {%- comment -%} Price display (server-side initial render) {%- endcomment -%}
        <div class="compact-price-display">
          {%- comment -%} Default: single column price. JS will upgrade to dual-column for members with WSH {%- endcomment -%}
          <div class="compact-price-single" id="compact-price-box">
            {%- if has_compare_price -%}
              <div class="compact-price-label">Sale Price</div>
              <div class="compact-compare-strike"><s>{{ original_price | money }}</s></div>
            {%- else -%}
              <div class="compact-price-label">Price</div>
            {%- endif -%}
            <div class="compact-price-amount">{{ sale_price | money }}<span class="compact-price-unit">/{{ section.settings.price_unit | default: "Each" }}</span></div>
            {%- if has_compare_price -%}
              {%- assign sale_savings = original_price | minus: sale_price -%}
              {%- assign sale_percent = sale_savings | times: 100.0 | divided_by: original_price | round -%}
              <div class="compact-sale-savings">Save {{ sale_percent }}%</div>
            {%- endif -%}
          </div>
        </div>

        {%- comment -%} Vendor CTAs (non-member, server-side) {%- endcomment -%}
        {%- unless is_member -%}
          {%- if is_own_brand -%}
            <a href="/account/login?return_url={{ request.path | url_param_escape }}" class="compact-cta-login compact-spp-login" style="{% if is_logged_in %}display:none;{% endif %}">
              <span class="compact-cta-icon">&#128274;</span> Login for Member Pricing
            </a>
          {%- else -%}
            <a href="tel:+14086739999" class="compact-cta-call compact-spp-call">
              <span class="compact-cta-icon">&#128222;</span> Call for More Details - (408) 673-9999
            </a>
          {%- endif -%}
        {%- endunless -%}

        {%- comment -%} Financing row {%- endcomment -%}
        <a href="/pages/contact-us#financing" class="compact-financing" style="text-decoration:none;cursor:pointer;">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <rect x="1" y="4" width="22" height="16" rx="2" ry="2"></rect>
            <line x1="1" y1="10" x2="23" y2="10"></line>
          </svg>
          <span>Financing Available</span>
          <span class="coming-soon" style="background:#2d5a87;color:#fff;">Apply Now →</span>
        </a>

        {%- comment -%} Variant Picker {%- endcomment -%}
        {%- unless product.has_only_default_variant -%}
        <div class="compact-variants">
          <variant-selects
            id="compact-variant-selects-{{ section.id }}"
            class="no-js-hidden"
            data-section="{{ section.id }}"
            data-url="{{ product.url }}"
            data-update-url="true"
          >
            {%- for option in product.options_with_values -%}
              {%- if filter_variants_for_cph -%}
                {%- case forloop.index0 -%}
                  {%- when 0 -%}{%- assign cph_effective_selected = cph_first_opt1 -%}
                  {%- when 1 -%}{%- assign cph_effective_selected = cph_first_opt2 -%}
                  {%- when 2 -%}{%- assign cph_effective_selected = cph_first_opt3 -%}
                {%- endcase -%}
              {%- endif -%}
              <div style="margin-bottom:10px;">
                <span class="compact-variants-label">{{ option.name }}:</span>
                <div class="compact-variant-pills" data-option-index="{{ forloop.index0 }}">
                  {%- for value in option.values -%}
                    {%- assign show_pill = true -%}
                    {%- if filter_variants_for_cph -%}
                      {%- assign pill_check = '|||' | append: value | append: '|||' -%}
                      {%- case forloop.parentloop.index0 -%}
                        {%- when 0 -%}{%- unless cph_opt1_vals contains pill_check -%}{%- assign show_pill = false -%}{%- endunless -%}
                        {%- when 1 -%}{%- unless cph_opt2_vals contains pill_check -%}{%- assign show_pill = false -%}{%- endunless -%}
                        {%- when 2 -%}{%- unless cph_opt3_vals contains pill_check -%}{%- assign show_pill = false -%}{%- endunless -%}
                      {%- endcase -%}
                    {%- endif -%}
                    {%- if show_pill -%}
                    <div class="compact-variant-pill">
                      <input
                        type="radio"
                        id="CompactOpt-{{ section.id }}-{{ forloop.index0 }}-{{ forloop.index }}"
                        name="compact_options[{{ option.name | escape }}]"
                        value="{{ value | escape }}"
                        form="compact-product-form-{{ section.id }}"
                        {% if filter_variants_for_cph %}{% if cph_effective_selected == value %}checked{% endif %}{% else %}{% if option.selected_value == value %}checked{% endif %}{% endif %}
                        data-option-index="{{ forloop.parentloop.index0 }}"
                        onchange="handleCompactVariantChange(this, '{{ section.id }}')"
                      >
                      <label for="CompactOpt-{{ section.id }}-{{ forloop.index0 }}-{{ forloop.index }}">
                        {{ value }}
                      </label>
                    </div>
                    {%- endif -%}
                  {%- endfor -%}
                </div>
              </div>
            {%- endfor -%}

            <script type="application/json" data-selected-variant>
              {{ current_variant | json }}
            </script>
          </variant-selects>
        </div>
        {%- endunless -%}

        {%- comment -%} Cart Row {%- endcomment -%}
        {%- if call_to_order -%}
          <div class="cf-call-to-order-spp" style="display:flex;flex-direction:column;gap:10px;width:100%;">
            <a href="tel:+14086739999" class="compact-atc-btn cf-call-to-order-btn" style="display:flex;align-items:center;justify-content:center;gap:8px;text-decoration:none;background:linear-gradient(135deg,#1a365d 0%,#2d5a87 100%);color:#fff;border:none;padding:12px 24px;border-radius:8px;font-size:15px;font-weight:700;cursor:pointer;width:100%;text-align:center;">
              <i class="fas fa-phone-alt"></i> Call to Order — (408) 673-9999
            </a>
            <a href="/pages/contact" style="display:flex;align-items:center;justify-content:center;gap:6px;text-decoration:none;color:#2d5a87;font-size:13px;font-weight:600;">
              <i class="fas fa-envelope"></i> Or Contact Us Online
            </a>
          </div>
        {%- else -%}
        <form action="/cart/add" method="post" enctype="multipart/form-data" id="compact-product-form-{{ section.id }}" class="compact-cart-row">
          <input type="hidden" name="id" id="compact-variant-id-{{ section.id }}" value="{{ current_variant.id }}">
          {%- unless current_variant.price == 0 -%}
          <div class="compact-qty-wrap">
            <input type="number" name="quantity" value="1" min="1" id="compact-qty-input" aria-label="Quantity">
            <span class="compact-qty-unit">{{ section.settings.price_unit | default: "Each" }}</span>
          </div>
          {%- endunless -%}
          <button type="submit" class="compact-atc-btn" id="compact-atc-btn-{{ section.id }}" {% if current_variant.price == 0 or product.available == false %}disabled{% endif %}>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/></svg>
            {%- if current_variant.price == 0 -%}
              Contact Us
            {%- elsif product.available -%}
              {{ section.settings.add_to_cart_text | default: "Add to Cart" }}
            {%- else -%}
              Sold Out
            {%- endif -%}
          </button>
        </form>
        <button
          type="button"
          class="compact-wishlist-btn"
          data-wishlist-btn
          data-product-id="{{ product.id }}"
          data-variant-id="{{ current_variant.id }}"
          data-product-title="{{ product.title | escape }}"
          data-product-handle="{{ product.handle }}"
          data-product-image="{{ product.featured_media | image_url: width: 400 }}"
          data-product-price="{{ product.price }}"
          data-product-compare-price="{{ product.compare_at_price }}"
          data-product-url="{{ product.url }}"
          aria-label="Add to wishlist"
        >
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="14" height="14">
            <path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/>
          </svg>
          Add to Wishlist
        </button>
        <div class="zero-price-notice" id="zero-price-notice-{{ section.id }}" style="margin-top:10px;padding:10px 14px;background:#fff8e1;border:1px solid #ffc107;border-radius:6px;font-size:12px;color:#856404;line-height:1.5;{%- if current_variant.price != 0 -%}display:none;{%- endif -%}">
          Sorry, product can't be added to cart as price not available. <a href="/pages/contact" style="color:#2d5a87;font-weight:600;">Contact us</a> to confirm availability, or call <a href="tel:+14086739999" style="color:#2d5a87;font-weight:600;">(408) 673-9999</a>.
        </div>
        {%- endif -%}

      </div>{%- comment -%} end .pricing-card {%- endcomment -%}

      {%- comment -%} ── Shipping Info ── {%- endcomment -%}
      <div class="compact-shipping-box">
        {%- if section.settings.shipping_alert_text != blank and shipment_text == blank -%}
          <div class="compact-shipping-alert">
            <span class="alert-icon">&#9888;&#65039;</span>
            <span>{{ section.settings.shipping_alert_text }}</span>
          </div>
        {%- endif -%}

        {%- if free_shipping -%}
          <div class="compact-free-shipping-pill">&#10003; FREE SHIPPING</div>
        {%- endif -%}

        {%- if section.settings.show_shipping_info or shipment_text != blank -%}
          {%- if shipment_text != blank -%}
            <ul class="compact-shipping-list">
              <li><span class="check-icon">&#10003;</span> {{ shipment_text }}</li>
              {%- if shipment_text_sub != blank -%}
                <li style="color:var(--g500);padding-left:20px;font-size:11px;">{{ shipment_text_sub }}</li>
              {%- endif -%}
            </ul>
          {%- elsif section.settings.shipping_info_list != blank -%}
            <ul class="compact-shipping-list">
              {%- assign ship_items = section.settings.shipping_info_list | split: '|' -%}
              {%- for item in ship_items -%}
                <li><span class="check-icon">&#10003;</span> {{ item }}</li>
              {%- endfor -%}
            </ul>
          {%- endif -%}
        {%- endif -%}
      </div>

      {%- comment -%} ── Vendor Row ── {%- endcomment -%}
      {%- if product.vendor -%}
      <div class="compact-vendor-row">
        {%- if vendor_logo != blank -%}
          <img src="{{ vendor_logo }}" alt="{{ product.vendor }}" class="compact-vendor-logo">
        {%- endif -%}
        <div>
          <div class="compact-vendor-text">Sold by</div>
          <div class="compact-vendor-name">{{ product.vendor }}</div>
        </div>
      </div>
      {%- endif -%}

      {%- comment -%} ── Frequently Bought Together ── {%- endcomment -%}
      {%- assign fbt_products = product.metafields.custom.fbt_products -%}
      {%- if section.settings.enable_fbt and fbt_products.value.size > 0 -%}
      {%- assign fbt_max = section.settings.fbt_max_items | default: 3 -%}
      <div class="compact-fbt" id="compact-fbt">
        <h4>Frequently Bought Together</h4>
        {%- assign fbt_total = product.price -%}
        {%- for fbt_product in fbt_products.value limit: fbt_max -%}
          {%- assign fbt_total = fbt_total | plus: fbt_product.price -%}
          <div class="compact-fbt-item">
            <input type="checkbox" checked data-fbt-variant="{{ fbt_product.variants.first.id }}" data-fbt-price="{{ fbt_product.price }}" onchange="updateFbtTotal()">
            {%- if fbt_product.featured_image -%}
              <img src="{{ fbt_product.featured_image | image_url: width: 80 }}" alt="{{ fbt_product.title | escape }}">
            {%- endif -%}
            <div class="compact-fbt-item-info">
              <div class="compact-fbt-item-title">{{ fbt_product.title }}</div>
              <div class="compact-fbt-item-price">{{ fbt_product.price | money }}</div>
            </div>
          </div>
        {%- endfor -%}
        <div class="compact-fbt-total">
          <span>Total:</span>
          <span class="compact-fbt-total-amount" id="fbt-total" data-base-price="{{ product.price }}">{{ fbt_total | money }}</span>
        </div>
        <button type="button" class="compact-fbt-add-btn" onclick="addAllFbt()">Add All to Cart</button>
      </div>
      {%- endif -%}

      {%- comment -%} ── Parts & Service Card ── {%- endcomment -%}
      {%- if section.settings.show_service_banner -%}
      <div class="compact-parts-card">
        <h4><span class="icon">{{ section.settings.service_banner_icon | default: "🏆" }}</span> {{ section.settings.service_banner_title }}</h4>
        <p>{{ section.settings.service_banner_description }}</p>
        {%- if section.settings.service_banner_list != blank -%}
          <div class="services-html">{{ section.settings.service_banner_list }}</div>
        {%- endif -%}
        {%- if section.settings.service_banner_button_text != blank -%}
          <a href="{{ section.settings.service_banner_button_url }}" class="compact-parts-btn">{{ section.settings.service_banner_button_text }}</a>
        {%- endif -%}
      </div>
      {%- endif -%}

      {%- if product.type -%}
      <div class="compact-product-type-row">
        <span class="compact-spec-label">Type</span>
        <span class="compact-spec-value">{{ product.type }}</span>
      </div>
      {%- endif -%}

      {%- comment -%} ── Accordion (Specs + Resources) ── {%- endcomment -%}
      <div class="compact-accordion">
        {%- comment -%} Specifications {%- endcomment -%}
        <div class="compact-acc-item open">
          <div class="compact-acc-header" onclick="toggleAccordion(this)">
            <span>Specifications</span>
            <span class="acc-icon">+</span>
          </div>
          <div class="compact-acc-content">
            {%- if specs_table != blank -%}
              {%- assign specs_file_url = specs_table | file_url -%}
              <div style="margin-bottom:12px;">
                <img src="{{ specs_file_url }}" alt="Specifications" style="width:100%;height:auto;border-radius:6px;border:1px solid var(--g200);">
              </div>
            {%- endif -%}

            {%- if spec_sheet != blank -%}
              {%- assign spec_html = spec_sheet | metafield_tag -%}
              {%- assign spec_text = spec_html | strip_html | strip -%}
              {%- assign spec_lines = spec_text | split: '|' -%}
              {%- for line in spec_lines -%}
                {%- assign tline = line | strip -%}
                {%- if tline != blank -%}
                  {%- if tline contains ':' -%}
                    {%- assign parts = tline | split: ':' -%}
                    <div class="compact-spec-row">
                      <span class="compact-spec-label">{{ parts[0] | strip }}</span>
                      <span class="compact-spec-value">{{ parts[1] | strip }}</span>
                    </div>
                  {%- else -%}
                    <div class="compact-spec-row">
                      <span class="compact-spec-label">{{ tline }}</span>
                      <span class="compact-spec-value"></span>
                    </div>
                  {%- endif -%}
                {%- endif -%}
              {%- endfor -%}
            {%- endif -%}

            {%- if material != blank -%}
              {%- if material.value.size > 0 -%}
                <div class="compact-spec-row">
                  <span class="compact-spec-label">Material</span>
                  <span class="compact-spec-value">{%- for mat in material.value -%}{{ mat.name }}{% unless forloop.last %}, {% endunless %}{%- endfor -%}</span>
                </div>
              {%- elsif material -%}
                <div class="compact-spec-row">
                  <span class="compact-spec-label">Material</span>
                  <span class="compact-spec-value">{{ material }}</span>
                </div>
              {%- endif -%}
            {%- endif -%}

            {%- if product.weight and product.weight > 0 -%}
              <div class="compact-spec-row">
                <span class="compact-spec-label">Weight</span>
                <span class="compact-spec-value">{{ product.weight | weight_with_unit }}</span>
              </div>
            {%- endif -%}

            {%- if warranty_text != blank -%}
              <div class="compact-spec-row">
                <span class="compact-spec-label">Warranty</span>
                <span class="compact-spec-value">{{ warranty_text | metafield_tag }}</span>
              </div>
            {%- endif -%}

            {%- if show_demo and material == blank and spec_sheet == blank -%}
              <div class="compact-spec-row">
                <span class="compact-spec-label">Type</span>
                <span class="compact-spec-value">Demo Product</span>
              </div>
              <div class="compact-spec-row">
                <span class="compact-spec-label">Capacity</span>
                <span class="compact-spec-value">Demo Value</span>
              </div>
            {%- endif -%}
          </div>
        </div>

        {%- comment -%} Resources & Documents {%- endcomment -%}
        {%- if warranty_doc != blank or spec_doc != blank or manual_doc != blank or section.settings.show_resources or show_demo -%}
        <div class="compact-acc-item open">
          <div class="compact-acc-header" onclick="toggleAccordion(this)">
            <span>Resources & Documents</span>
            <span class="acc-icon">+</span>
          </div>
          <div class="compact-acc-content">
            {%- if spec_doc != blank -%}
              {%- assign spec_doc_url = spec_doc | file_url -%}
              {%- if spec_doc_url contains '.pdf' -%}
                <a href="{{ spec_doc_url }}" target="_blank" class="compact-resource-link">
                  <span class="res-icon">&#128196;</span> Spec Sheet (PDF)
                </a>
              {%- else -%}
                <a href="{{ spec_doc_url }}" target="_blank" class="compact-resource-link">
                  <span class="res-icon">&#128444;</span> Spec Sheet (Image)
                </a>
              {%- endif -%}
            {%- endif -%}

            {%- if manual_doc != blank -%}
              {%- assign manual_doc_url = manual_doc | file_url -%}
              {%- if manual_doc_url contains '.pdf' -%}
                <a href="{{ manual_doc_url }}" target="_blank" class="compact-resource-link">
                  <span class="res-icon">&#128196;</span> Installation Manual (PDF)
                </a>
              {%- else -%}
                <a href="{{ manual_doc_url }}" target="_blank" class="compact-resource-link">
                  <span class="res-icon">&#128444;</span> Installation Manual (Image)
                </a>
              {%- endif -%}
            {%- endif -%}

            {%- if warranty_doc != blank -%}
              {%- assign warranty_doc_url = warranty_doc | file_url -%}
              <a href="{{ warranty_doc_url }}" target="_blank" class="compact-resource-link">
                <span class="res-icon">&#128196;</span> Warranty Information
              </a>
            {%- endif -%}

            {%- if section.settings.resource_links != blank -%}
              {%- assign resources = section.settings.resource_links | split: '|' -%}
              {%- for resource in resources -%}
                {%- assign resource_parts = resource | split: '::' -%}
                <a href="{{ resource_parts[1] }}" target="_blank" class="compact-resource-link">
                  <span class="res-icon">&#128279;</span> {{ resource_parts[0] }}
                </a>
              {%- endfor -%}
            {%- endif -%}

            {%- if show_demo and spec_doc == blank -%}
              <a href="#" class="compact-resource-link"><span class="res-icon">&#128196;</span> Demo Spec Sheet</a>
              <a href="#" class="compact-resource-link"><span class="res-icon">&#128196;</span> Demo Manual</a>
              <a href="#" class="compact-resource-link"><span class="res-icon">&#128196;</span> Demo Warranty Info</a>
            {%- endif -%}
          </div>
        </div>
        {%- endif -%}
      </div>

      {%- comment -%} ── Help Card ── {%- endcomment -%}
      {%- if section.settings.show_help_box -%}
      <div class="compact-help-card">
        <h4>Need Help?</h4>
        <ul>
          {%- if section.settings.help_phone != blank -%}
            <li>&#128222; Call: <a href="tel:{{ section.settings.help_phone | remove: ' ' | remove: '-' | remove: '(' | remove: ')' }}">{{ section.settings.help_phone }}</a></li>
          {%- endif -%}
          {%- if section.settings.help_email != blank -%}
            <li>&#9993; <a href="mailto:{{ section.settings.help_email }}">Email Support</a></li>
          {%- endif -%}
          {%- if section.settings.help_chat_enabled -%}
            <li>&#128172; Live Chat Available</li>
          {%- endif -%}
          {%- if section.settings.help_additional_links != blank -%}
            {%- assign help_links = section.settings.help_additional_links | split: '|' -%}
            {%- for link in help_links -%}
              <li>{{ link }}</li>
            {%- endfor -%}
          {%- endif -%}
        </ul>
      </div>
      {%- endif -%}

    </div>{%- comment -%} end .compact-right {%- endcomment -%}

  </div>{%- comment -%} end .compact-layout {%- endcomment -%}

</div>{%- comment -%} end .compact-product {%- endcomment -%}

{%- comment -%}
  ════════════════════════════════════════════
  PART D — Lightbox
  ════════════════════════════════════════════
{%- endcomment -%}
<div class="compact-product-lightbox" id="compact-lightbox">
  <button class="lb-close" id="compact-lb-close">&#10005;</button>
