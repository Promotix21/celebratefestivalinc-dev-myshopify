  ════════════════════════════════════════════
{%- endcomment -%}
{%- if section.settings.enable_qa -%}
<div id="cf-compact-aq-modal" class="cf-aq-modal">
  <div class="cf-aq-overlay" onclick="document.getElementById('cf-compact-aq-modal').classList.remove('active')"></div>
  <div class="cf-aq-dialog">
    <button class="cf-aq-close" onclick="document.getElementById('cf-compact-aq-modal').classList.remove('active')">&times;</button>
    <div class="cf-aq-header">
      <h3>Ask a Question</h3>
      <p>About: <strong>{{ product.title | escape }}</strong></p>
    </div>
    <div class="cf-aq-body" id="cf-compact-aq-form-body">
      {% form 'contact', class: 'cf-aq-form', id: 'cf-compact-aq-contact-form' %}
        {% if form.posted_successfully? %}
          <script>window.__cfCompactAqSuccess = true;</script>
        {% endif %}
        <input type="hidden" name="contact[inquiry_type]" value="Product Question">
        <input type="hidden" name="contact[product_title]" value="{{ product.title | escape }}">
        <input type="hidden" name="contact[product_url]" value="{{ shop.url }}{{ product.url }}">
        <input type="hidden" name="contact[product_sku]" value="{{ product.variants.first.sku | escape }}">
        <input type="hidden" name="contact[product_vendor]" value="{{ product.vendor | escape }}">

        <div class="cf-aq-product-tag">
          {% if product.featured_image %}
            <img src="{{ product.featured_image | image_url: width: 100 }}" alt="{{ product.title | escape }}">
          {% endif %}
          <div>
            <span class="cf-aq-product-name">{{ product.title }}</span>
            {% if product.variants.first.sku != blank %}
              <span class="cf-aq-product-sku">SKU: {{ product.variants.first.sku }}</span>
            {% endif %}
          </div>
        </div>

        <div class="cf-aq-row">
          <div class="cf-aq-field">
            <label>Name <span class="cf-aq-req">*</span></label>
            <input type="text" name="contact[name]" required {% if customer %}value="{{ customer.name | escape }}"{% endif %} placeholder="Your name">
          </div>
          <div class="cf-aq-field">
            <label>Email <span class="cf-aq-req">*</span></label>
            <input type="email" name="contact[email]" required {% if customer %}value="{{ customer.email | escape }}"{% endif %} placeholder="your@email.com">
          </div>
        </div>

        <div class="cf-aq-field">
          <label>Category</label>
          <select name="contact[question_category]">
            <option value="general">General Question</option>
            <option value="specs">Specifications & Features</option>
            <option value="compatibility">Compatibility & Sizing</option>
            <option value="shipping">Shipping & Delivery</option>
            <option value="warranty">Warranty & Returns</option>
            <option value="installation">Installation & Setup</option>
            <option value="pricing">Pricing & Availability</option>
          </select>
        </div>

        <div class="cf-aq-field">
          <label>Your Question <span class="cf-aq-req">*</span></label>
          <textarea name="contact[body]" required placeholder="Type your question here..." rows="4"></textarea>
        </div>

        <button type="submit" class="cf-aq-submit">Submit Question</button>
      {% endform %}
    </div>
  </div>
</div>

<style>
/* Ask a Question Modal (same as existing — scoped with unique IDs) */
.cf-aq-modal { display:none; position:fixed; top:0; left:0; right:0; bottom:0; z-index:9999; align-items:center; justify-content:center; }
.cf-aq-modal.active { display:flex; }
.cf-aq-overlay { position:fixed; top:0; left:0; right:0; bottom:0; background:rgba(26,54,93,.6); backdrop-filter:blur(3px); }
.cf-aq-dialog { position:relative; background:#fff; border-radius:12px; width:90%; max-width:520px; max-height:90vh; overflow-y:auto; box-shadow:0 20px 60px rgba(0,0,0,.2); z-index:1; animation:cfAqSlideUp .25s ease-out; }
@keyframes cfAqSlideUp { from{opacity:0;transform:translateY(20px);} to{opacity:1;transform:translateY(0);} }
.cf-aq-close { position:absolute; top:12px; right:14px; background:none; border:none; font-size:24px; color:#fff; cursor:pointer; width:32px; height:32px; display:flex; align-items:center; justify-content:center; border-radius:50%; transition:background .2s; z-index:2; }
.cf-aq-close:hover { background:rgba(255,255,255,.15); }
.cf-aq-header { background:linear-gradient(135deg,#1a365d,#2d5a87); padding:22px 24px; border-radius:12px 12px 0 0; color:#fff; }
.cf-aq-header h3 { font-family:'Montserrat',sans-serif; font-size:18px; font-weight:700; margin:0 0 4px 0; }
.cf-aq-header p { font-size:13px; opacity:.9; margin:0; line-height:1.4; }
