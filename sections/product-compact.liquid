<script>
(function() {
  if (window.__cfCompactZoomInitialized) return;
  window.__cfCompactZoomInitialized = true;

  function initInlineZoom() {
    var container = document.querySelector('.compact-product .compact-main-image-box');
    var mainImage = document.getElementById('compact-main-img');
    if (!container || !mainImage) return;
    if (window.innerWidth <= 768) return;

    var zoomLevel = 2.5;
    var indicator = container.querySelector('.compact-zoom-indicator');

    function getZoomSrc() {
      return mainImage.dataset.zoomSrc || mainImage.src.replace(/width=\d+/, 'width=1600');
    }

    container.addEventListener('mouseenter', function() {
      if (window.innerWidth <= 768) return;
      var zoomUrl = getZoomSrc();
      new Image().src = zoomUrl;
      container.style.backgroundImage = "url('" + zoomUrl + "')";
      container.style.backgroundSize = (zoomLevel * 100) + '%';
      container.classList.add('zoomed');
      if (indicator) indicator.style.opacity = '0';
    });

    container.addEventListener('mousemove', function(e) {
      if (!container.classList.contains('zoomed')) return;
      var rect = container.getBoundingClientRect();
      var x = ((e.clientX - rect.left) / rect.width) * 100;
      var y = ((e.clientY - rect.top) / rect.height) * 100;
      container.style.backgroundPosition = x + '% ' + y + '%';
    });

    container.addEventListener('mouseleave', function() {
      container.classList.remove('zoomed');
      container.style.backgroundImage = '';
      container.style.backgroundSize = '';
      container.style.backgroundPosition = '';
      if (indicator) indicator.style.opacity = '1';
    });

    // Update zoom src when image changes (thumbnail click / variant switch)
    new MutationObserver(function(mutations) {
      mutations.forEach(function(m) {
        if (m.attributeName === 'src') {
          mainImage.dataset.zoomSrc = mainImage.src.replace(/width=\d+/, 'width=1600');
          if (container.classList.contains('zoomed')) {
            container.style.backgroundImage = "url('" + mainImage.dataset.zoomSrc + "')";
          }
        }
      });
    }).observe(mainImage, { attributes: true });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initInlineZoom);
  } else {
    initInlineZoom();
  }
})();
</script>

