{%- liquid
  assign page_title = section.settings.hero_title_override | default: page.title
  assign page_lead   = section.settings.hero_lead | default: ''

  assign has_cat_nav     = false
  assign has_equip       = false
  assign has_store_types = false
  assign has_guides      = false
  assign has_brands      = false

  for block in section.blocks
    if block.type == 'cat_nav'
      assign has_cat_nav = true
    endif
    if block.type == 'equip_section'
      assign has_equip = true
    endif
    if block.type == 'store_type'
      assign has_store_types = true
    endif
    if block.type == 'guide'
      assign has_guides = true
    endif
    if block.type == 'brand'
      assign has_brands = true
    endif
  endfor
-%}

<style>
  .cih {
    --maroon: #8B1538;
    --maroon-dark: #6E0F2B;
    --coral: #FF6B6B;
    --coral-soft: #FFF0EE;
    --navy: #1A365D;
    --navy-deep: #1B2B47;
    --gold: #D4AF37;
    --sale-red: #E9330C;
    --white: #FFFFFF;
    --gray-100: #F3F3F3;
    --gray-200: #E8E8E8;
    --gray-300: #D9D9D9;
    --gray-500: #8A8A8A;
    --gray-700: #4A4A4A;
    --ink: #121212;
    --dark-bg: #1B2B47;
    --maxw: 1600px;
    --pad-x: clamp(20px, 4vw, 56px);
    --radius: 6px;
    --radius-lg: 10px;
    --shadow-hover: 0 6px 18px rgba(18,18,18,.08);
    --font-serif: "Playfair Display", "Times New Roman", serif;
    --font-sans: "Inter", -apple-system, BlinkMacSystemFont, sans-serif;
  }

  /* ---------- Hero ---------- */
  .cih__hero {
    position: relative;
    background: var(--dark-bg);
    color: var(--white);
    overflow: hidden;
  }
  .cih__hero-bg {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center right;
    z-index: 0;
  }
  .cih__hero-bg::after {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(90deg,
      rgba(15,18,22,.92) 0%,
      rgba(15,18,22,.82) 32%,
      rgba(15,18,22,.45) 60%,
      rgba(15,18,22,.05) 90%,
      rgba(15,18,22,0) 100%);
  }
  .cih__hero-inner {
    max-width: var(--maxw);
    margin: 0 auto;
    padding: 24px var(--pad-x) 56px;
    position: relative;
    z-index: 2;
    min-height: 440px;
    display: flex;
    flex-direction: column;
  }
  .cih__breadcrumb {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 13px;
    color: rgba(255,255,255,.75);
    margin-bottom: 56px;
    letter-spacing: .01em;
    font-family: var(--font-sans);
  }
  .cih__breadcrumb a { color: inherit; text-decoration: none; }
  .cih__breadcrumb a:hover { color: var(--gold); }
  .cih__breadcrumb .sep { opacity: .5; }
  .cih__breadcrumb .cur { color: var(--white); }
  .cih__hero h1 {
    font-family: var(--font-serif);
    font-weight: 600;
    font-size: clamp(38px, 5.2vw, 70px);
    line-height: 1.02;
    letter-spacing: -.01em;
    margin: 0 0 22px;
    max-width: 720px;
  }
  .cih__lead {
    font-size: 17px;
    line-height: 1.55;
    color: rgba(255,255,255,.85);
    max-width: 460px;
    margin: 0 0 32px;
    font-family: var(--font-sans);
  }
  .cih__hero-ctas { display: flex; gap: 12px; flex-wrap: wrap; }

  /* ---------- Gold stripe ---------- */
  .cih__gold-stripe {
    height: 3px;
    background: linear-gradient(90deg, var(--maroon) 0%, var(--maroon) 30%, var(--gold) 30%, var(--gold) 33%, var(--maroon) 33%, var(--maroon) 100%);
    max-width: var(--maxw);
    margin: 0 auto;
    opacity: .9;
  }

  /* ---------- Buttons ---------- */
  .cih .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    padding: 13px 22px;
    font-size: 14px;
    font-weight: 600;
    letter-spacing: .02em;
    border-radius: var(--radius);
    transition: background .18s, color .18s, border-color .18s;
    white-space: nowrap;
    text-decoration: none;
    font-family: var(--font-sans);
    cursor: pointer;
  }
  .cih .btn-primary { background: var(--maroon); color: var(--white); }
  .cih .btn-primary:hover { background: var(--maroon-dark); }
  .cih .btn-secondary {
    background: rgba(255,255,255,.08);
    color: var(--white);
    border: 1px solid rgba(255,255,255,.45);
    backdrop-filter: blur(4px);
  }
  .cih .btn-secondary:hover { border-color: var(--gold); color: var(--gold); }
  .cih .btn-outline {
    background: transparent;
    color: var(--maroon);
    border: 1px solid var(--maroon);
  }
  .cih .btn-outline:hover { background: var(--maroon); color: var(--white); }
  .cih .btn-sm { padding: 11px 18px; font-size: 13px; }
  .cih .btn-coral { background: var(--coral); color: var(--white); }
  .cih .btn-coral:hover { background: #ff5252; }

  /* ---------- Page wrapper ---------- */
  .cih__page {
    max-width: var(--maxw);
    margin: 0 auto;
    padding: 0 var(--pad-x);
  }

  /* ---------- Horizontal category nav ---------- */
  .cih__cat-nav-wrap {
    background: var(--white);
    border: 1px solid var(--gray-200);
    border-radius: var(--radius-lg);
    margin-top: -28px;
    margin-bottom: 28px;
    position: relative;
    z-index: 5;
    box-shadow: 0 14px 40px rgba(18,18,18,.06);
  }
  .cih__cat-nav {
    display: grid;
    gap: 4px;
  }
  .cih__cat-nav-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    padding: 20px 8px 18px;
    text-align: center;
    font-size: 12.5px;
    font-weight: 500;
    color: var(--gray-700);
    border-bottom: 3px solid transparent;
    transition: color .15s, border-color .15s;
    line-height: 1.25;
    text-decoration: none;
    font-family: var(--font-sans);
  }
  .cih__cat-nav-item:hover { color: var(--ink); }
  .cih__cat-nav-item.active {
    color: var(--maroon);
    font-weight: 600;
    border-bottom-color: var(--maroon);
  }
  .cih__cat-nav-item .ci {
    width: 42px;
    height: 42px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: currentColor;
  }
  .cih__cat-nav-item.active .ci { color: var(--maroon); }
  .cih__cat-nav-item .ci svg { width: 100%; height: 100%; }
  @media (max-width: 980px) {
    .cih__cat-nav {
      display: flex;
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      padding: 4px;
      scrollbar-width: none;
    }
    .cih__cat-nav::-webkit-scrollbar { display: none; }
    .cih__cat-nav-item {
      flex: 0 0 auto;
      min-width: 110px;
      scroll-snap-align: start;
      padding: 14px 8px 12px;
    }
    .cih__cat-nav-item .ci { width: 32px; height: 32px; }
  }

  /* ---------- Equipment sections ---------- */
  .cih__equip-stack { display: flex; flex-direction: column; gap: 18px; margin-bottom: 28px; }
  .cih__equip-card {
    background: var(--white);
    border: 1px solid var(--gray-200);
    border-radius: var(--radius-lg);
    padding: 22px;
    display: grid;
    grid-template-columns: 360px 1fr 1.6fr;
    gap: 28px;
    align-items: stretch;
    transition: box-shadow .2s, border-color .2s;
  }
  .cih__equip-card.reverse { grid-template-columns: 1fr 1.6fr 360px; }
  .cih__equip-card:hover { box-shadow: var(--shadow-hover); border-color: var(--gray-300); }
  .cih__equip-media {
    border-radius: var(--radius);
    overflow: hidden;
    background: var(--gray-100);
    aspect-ratio: 4 / 3;
  }
  .cih__equip-card.reverse .cih__equip-media { order: 3; }
  .cih__equip-media img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .cih__equip-body { display: flex; flex-direction: column; min-width: 0; }
  .cih__equip-body h2 {
    font-family: var(--font-serif);
    font-weight: 600;
    font-size: 28px;
    line-height: 1.1;
    margin: 0 0 10px;
    color: var(--ink);
  }
  .cih__equip-body p {
    font-size: 14px;
    color: var(--gray-700);
    line-height: 1.55;
    margin: 0 0 16px;
    font-family: var(--font-sans);
  }
  .cih__bullets {
    list-style: none;
    padding: 0;
    margin: 0 0 22px;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .cih__bullets li {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    font-size: 13.5px;
    color: var(--ink);
    font-family: var(--font-sans);
  }
  .cih__check { color: var(--maroon); flex-shrink: 0; margin-top: 2px; }
  .cih__check svg { width: 14px; height: 14px; display: block; }
  .cih__equip-cta { margin-top: auto; }
  .cih__equip-products { min-width: 0; display: flex; flex-direction: column; }
  .cih__equip-products-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 14px;
  }
  .cih__equip-products-head h3 {
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: 15px;
    margin: 0;
    letter-spacing: -.01em;
    color: var(--ink);
  }
  .cih__view-all {
    font-size: 12px;
    font-weight: 600;
    color: var(--maroon);
    display: inline-flex;
    align-items: center;
    gap: 4px;
    letter-spacing: .02em;
    text-decoration: none;
    font-family: var(--font-sans);
  }
  .cih__view-all:hover { color: var(--maroon-dark); }
  .cih__view-all::after { content: "→"; font-size: 12px; }
  .cih__product-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 12px;
    flex: 1;
  }
  .cih__pcard { display: flex; flex-direction: column; cursor: pointer; transition: transform .15s; text-decoration: none; }
  .cih__pcard:hover { transform: translateY(-2px); }
  .cih__pcard-thumb {
    width: 100%;
    aspect-ratio: 1 / 1;
    background: var(--white);
    border: 1px solid var(--gray-200);
    border-radius: var(--radius);
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 8px;
    transition: border-color .15s;
  }
  .cih__pcard:hover .cih__pcard-thumb { border-color: var(--maroon); }
  .cih__pcard-thumb img { width: 100%; height: 100%; object-fit: contain; display: block; }
  .cih__pcard-name {
    margin-top: 10px;
    font-size: 12.5px;
    font-weight: 500;
    color: var(--ink);
    line-height: 1.3;
    font-family: var(--font-sans);
  }
  @media (max-width: 1180px) {
    .cih__equip-card,
    .cih__equip-card.reverse { grid-template-columns: 320px 1fr; grid-template-rows: auto auto; }
    .cih__equip-card.reverse .cih__equip-media { order: 0; }
    .cih__equip-products { grid-column: 1 / -1; }
  }
  @media (max-width: 720px) {
    .cih__equip-card,
    .cih__equip-card.reverse { grid-template-columns: 1fr; gap: 18px; padding: 16px; }
    .cih__equip-card.reverse .cih__equip-media { order: 0; }
    .cih__equip-media { aspect-ratio: 16 / 9; }
    .cih__equip-body h2 { font-size: 22px; }
    .cih__product-grid {
      display: flex;
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      gap: 12px;
      margin: 0 -16px;
      padding: 0 16px 4px;
      scrollbar-width: none;
    }
    .cih__product-grid::-webkit-scrollbar { display: none; }
    .cih__pcard { flex: 0 0 42%; max-width: 42%; scroll-snap-align: start; }
  }

  /* ---------- Store types ---------- */
  .cih__store-type {
    background: var(--white);
    border: 1px solid var(--gray-200);
    border-radius: var(--radius-lg);
    padding: 24px;
    margin-bottom: 18px;
  }
  .cih__store-type h2 {
    font-family: var(--font-serif);
    font-weight: 600;
    font-size: 24px;
    margin: 0 0 18px;
    color: var(--ink);
  }
  .cih__store-grid { display: grid; grid-template-columns: repeat(8, 1fr); gap: 14px; }
  .cih__store-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    cursor: pointer;
    transition: transform .15s;
    text-decoration: none;
  }
  .cih__store-card:hover { transform: translateY(-3px); }
  .cih__store-img {
    width: 100%;
    aspect-ratio: 16 / 11;
    border-radius: var(--radius);
    overflow: hidden;
    border: 1px solid var(--gray-200);
    position: relative;
    background: var(--gray-100);
  }
  .cih__store-img::after {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(0,0,0,0) 50%, rgba(0,0,0,.25) 100%);
  }
  .cih__store-img img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .cih__store-name {
    margin-top: 8px;
    font-size: 12.5px;
    font-weight: 500;
    line-height: 1.3;
    color: var(--ink);
    font-family: var(--font-sans);
  }
  @media (max-width: 980px) {
    .cih__store-grid {
      display: flex;
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      gap: 12px;
      margin: 0 -24px;
      padding: 0 24px 6px;
      scrollbar-width: none;
    }
    .cih__store-grid::-webkit-scrollbar { display: none; }
    .cih__store-card { flex: 0 0 40%; max-width: 40%; scroll-snap-align: start; }
  }

  /* ---------- Guides + Help row ---------- */
  .cih__row-two {
    display: grid;
    grid-template-columns: 1fr 1.3fr;
    gap: 18px;
    margin-bottom: 18px;
  }
  @media (max-width: 880px) { .cih__row-two { grid-template-columns: 1fr; } }
  .cih__guides {
    background: var(--white);
    border: 1px solid var(--gray-200);
    border-radius: var(--radius-lg);
    padding: 22px;
  }
  .cih__guides-head {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 16px;
  }
  .cih__guides-head h2 {
    font-family: var(--font-serif);
    font-weight: 600;
    font-size: 22px;
    margin: 0;
    color: var(--ink);
  }
  .cih__guide-item {
    display: flex;
    align-items: center;
    gap: 16px;
    padding: 12px 0;
    border-top: 1px solid var(--gray-100);
    cursor: pointer;
    text-decoration: none;
  }
  .cih__guide-item:first-of-type { border-top: 0; padding-top: 6px; }
  .cih__guide-item:hover .cih__guide-title { color: var(--maroon); }
  .cih__guide-thumb {
    width: 110px;
    flex-shrink: 0;
    aspect-ratio: 14 / 9;
    border-radius: 4px;
    overflow: hidden;
    background: var(--gray-100);
  }
  .cih__guide-thumb img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .cih__guide-title {
    font-size: 14px;
    font-weight: 600;
    color: var(--ink);
    margin: 0 0 6px;
    line-height: 1.35;
    transition: color .15s;
    font-family: var(--font-sans);
  }
  .cih__guide-meta {
    font-size: 12px;
    color: var(--gray-500);
    letter-spacing: .04em;
    text-transform: uppercase;
    font-family: var(--font-sans);
  }
  .cih__help-block {
    background: var(--white);
    border: 1px solid var(--gray-200);
    border-radius: var(--radius-lg);
    padding: 22px;
    display: flex;
    flex-direction: column;
  }
  .cih__help-row {
    background: var(--coral-soft);
    border-radius: var(--radius);
    padding: 22px;
    display: flex;
    align-items: center;
    gap: 18px;
    margin-bottom: 18px;
  }
  .cih__help-icon {
    width: 56px;
    height: 56px;
    background: var(--white);
    border-radius: var(--radius);
    color: var(--maroon);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  .cih__help-icon svg { width: 28px; height: 28px; }
  .cih__help-text { flex: 1; min-width: 0; }
  .cih__help-text h3 {
    font-family: var(--font-serif);
    font-size: 19px;
    font-weight: 600;
    margin: 0 0 4px;
    color: var(--ink);
  }
  .cih__help-text p {
    font-size: 13.5px;
    color: var(--gray-700);
    margin: 0 0 12px;
    font-family: var(--font-sans);
  }
  .cih__brands h3 {
    font-family: var(--font-serif);
    font-weight: 600;
    font-size: 19px;
    margin: 0 0 14px;
    color: var(--ink);
  }
  .cih__brand-strip {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 20px;
  }
  .cih__brand {
    font-family: var(--font-serif);
    font-weight: 700;
    font-size: 17px;
    letter-spacing: .02em;
    color: var(--gray-500);
    transition: color .15s;
    cursor: pointer;
    text-decoration: none;
  }
  .cih__brand:hover { color: var(--ink); }
  .cih__brand.italic { font-style: italic; }
  @media (max-width: 720px) {
    .cih__help-row { flex-direction: column; align-items: flex-start; }
    .cih__brand-strip { gap: 14px; }
    .cih__brand { font-size: 15px; }
  }

  /* ---------- Expert CTA ---------- */
  .cih__expert-cta {
    background: var(--navy-deep);
    color: var(--white);
    padding: 60px var(--pad-x);
    position: relative;
    overflow: hidden;
    margin-top: 32px;
  }
  .cih__expert-cta::before {
    content: "";
    position: absolute;
    top: -100px; right: -100px;
    width: 320px; height: 320px;
    background: radial-gradient(circle, rgba(212,175,55,.15) 0%, rgba(212,175,55,0) 70%);
    border-radius: 50%;
    pointer-events: none;
  }
  .cih__expert-cta::after {
    content: "";
    position: absolute;
    bottom: -120px; left: 5%;
    width: 320px; height: 320px;
    background: radial-gradient(circle, rgba(139,21,56,.35) 0%, rgba(139,21,56,0) 70%);
    border-radius: 50%;
    pointer-events: none;
  }
  .cih__expert-cta-inner {
    max-width: var(--maxw);
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1.4fr auto;
    gap: 36px;
    align-items: center;
    position: relative;
    z-index: 1;
  }
  .cih__expert-eyebrow {
    font-size: 12px;
    letter-spacing: .18em;
    text-transform: uppercase;
    color: var(--gold);
    font-weight: 600;
    margin-bottom: 12px;
    font-family: var(--font-sans);
  }
  .cih__expert-cta h2 {
    font-family: var(--font-serif);
    font-weight: 600;
    font-size: clamp(28px, 4vw, 42px);
    line-height: 1.1;
    margin: 0 0 12px;
    max-width: 620px;
  }
  .cih__expert-cta p {
    font-size: 15.5px;
    color: rgba(255,255,255,.7);
    max-width: 540px;
    margin: 0;
    line-height: 1.55;
    font-family: var(--font-sans);
  }
  .cih__expert-actions { display: flex; gap: 12px; flex-wrap: wrap; }
  @media (max-width: 880px) {
    .cih__expert-cta-inner { grid-template-columns: 1fr; gap: 22px; }
  }

  /* ---------- Features ---------- */
  .cih__features {
    background: var(--white);
    padding: 44px var(--pad-x);
    border-top: 1px solid var(--gray-200);
  }
  .cih__features-inner {
    max-width: var(--maxw);
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 28px;
  }
  .cih__feature { display: flex; align-items: center; gap: 16px; }
  .cih__feature-icon {
    width: 52px; height: 52px;
    border-radius: 50%;
    background: var(--gray-100);
    color: var(--maroon);
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0;
  }
  .cih__feature-icon svg { width: 26px; height: 26px; }
  .cih__feature-text h4 {
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: 15px;
    margin: 0 0 3px;
    color: var(--ink);
    letter-spacing: -.01em;
  }
  .cih__feature-text p {
    font-size: 13px;
    color: var(--gray-500);
    margin: 0;
    line-height: 1.4;
    font-family: var(--font-sans);
  }
  @media (max-width: 880px) { .cih__features-inner { grid-template-columns: repeat(2,1fr); gap: 22px; } }
  @media (max-width: 480px) { .cih__features-inner { grid-template-columns: 1fr; } }
</style>

<!-- ============ HERO ============ -->
<section class="cih__hero cih">
  <div class="cih__hero-bg"
    {% if section.settings.hero_image != blank %}
      style="background-image: url('{{ section.settings.hero_image | image_url: width: 1600 }}')"
    {% else %}
      style="background-image: linear-gradient(135deg, #1B2B47 0%, #0f172a 100%)"
    {% endif %}
    aria-hidden="true"></div>
  <div class="cih__hero-inner">
    <nav class="cih__breadcrumb" aria-label="Breadcrumb">
      <a href="/">Home</a>
      <span class="sep">›</span>
      <a href="/pages/use-cases">Use Cases</a>
      <span class="sep">›</span>
      <span class="cur">{{ page_title }}</span>
    </nav>
    <h1>{{ page_title }}<br><span style="font-size:.75em;opacity:.85;">Equipment Solutions</span></h1>
    {%- if page_lead != blank -%}
      <p class="cih__lead">{{ page_lead }}</p>
    {%- elsif page.content != blank -%}
      <p class="cih__lead">{{ page.content | strip_html | truncate: 200 }}</p>
    {%- endif -%}
    <div class="cih__hero-ctas">
      {%- if section.settings.hero_btn1_text != blank -%}
        <a href="{{ section.settings.hero_btn1_url | default: '/collections/restaurant-equipment' }}" class="btn btn-primary cih">{{ section.settings.hero_btn1_text }}</a>
      {%- endif -%}
      {%- if section.settings.hero_btn2_text != blank -%}
        <a href="{{ section.settings.hero_btn2_url | default: '/pages/contact-us' }}" class="btn btn-secondary cih">{{ section.settings.hero_btn2_text }}</a>
      {%- endif -%}
    </div>
  </div>
</section>

<!-- Gold stripe -->
<div class="cih__gold-stripe cih" aria-hidden="true"></div>

<!-- ============ MAIN CONTENT ============ -->
<div class="cih__page cih">

  <!-- Horizontal category nav -->
  {%- if has_cat_nav -%}
    {%- assign cat_nav_count = 0 -%}
    {%- for block in section.blocks -%}{%- if block.type == 'cat_nav' -%}{%- assign cat_nav_count = cat_nav_count | plus: 1 -%}{%- endif -%}{%- endfor -%}
    <div class="cih__cat-nav-wrap">
      <nav class="cih__cat-nav" aria-label="Equipment categories"
           style="grid-template-columns: repeat({{ cat_nav_count }}, 1fr);">
        {%- for block in section.blocks -%}
          {%- if block.type == 'cat_nav' -%}
            <a href="#{{ block.settings.anchor }}"
               class="cih__cat-nav-item{% if forloop.first %} active{% endif %}"
               data-anchor="{{ block.settings.anchor }}"
               {{ block.shopify_attributes }}>
              <span class="ci">
                {%- if block.settings.icon_svg != blank -%}
                  {{ block.settings.icon_svg }}
                {%- else -%}
                  <svg viewBox="0 0 40 40" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="20" cy="20" r="14"/></svg>
                {%- endif -%}
              </span>
              {{ block.settings.label }}
            </a>
          {%- endif -%}
        {%- endfor -%}
      </nav>
    </div>
  {%- endif -%}

  <!-- Equipment sections -->
  {%- if has_equip -%}
    <div class="cih__equip-stack">
      {%- for block in section.blocks -%}
        {%- if block.type == 'equip_section' -%}
          {%- assign equip_col = collections[block.settings.featured_collection] -%}
          <article
            class="cih__equip-card{% if block.settings.is_reverse %} reverse{% endif %}"
            {% if block.settings.section_id != blank %}id="{{ block.settings.section_id }}"{% endif %}
            {{ block.shopify_attributes }}
          >
            <div class="cih__equip-media">
              {%- if block.settings.image != blank -%}
                <img src="{{ block.settings.image | image_url: width: 720 }}"
                     alt="{{ block.settings.title }}"
                     width="720" height="540"
                     loading="lazy">
              {%- else -%}
                <div style="width:100%;height:100%;background:linear-gradient(135deg,#e2e8f0 0%,#f1f5f9 100%);"></div>
              {%- endif -%}
            </div>
            <div class="cih__equip-body">
              <h2>{{ block.settings.title }}</h2>
              {%- if block.settings.description != blank -%}
                <p>{{ block.settings.description }}</p>
              {%- endif -%}
              <ul class="cih__bullets">
                {%- if block.settings.bullet_1 != blank -%}
                  <li><span class="cih__check"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><path d="m4 12 5 5L20 6"/></svg></span>{{ block.settings.bullet_1 }}</li>
                {%- endif -%}
                {%- if block.settings.bullet_2 != blank -%}
                  <li><span class="cih__check"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><path d="m4 12 5 5L20 6"/></svg></span>{{ block.settings.bullet_2 }}</li>
                {%- endif -%}
                {%- if block.settings.bullet_3 != blank -%}
                  <li><span class="cih__check"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><path d="m4 12 5 5L20 6"/></svg></span>{{ block.settings.bullet_3 }}</li>
                {%- endif -%}
              </ul>
              {%- if block.settings.cta_text != blank -%}
                <div class="cih__equip-cta">
                  <a href="{{ block.settings.cta_url | default: '/collections/restaurant-equipment' }}" class="btn btn-primary btn-sm cih">{{ block.settings.cta_text }}</a>
                </div>
              {%- endif -%}
            </div>
            {%- if block.settings.featured_collection != blank and equip_col != blank -%}
              <div class="cih__equip-products">
                <div class="cih__equip-products-head">
                  <h3>Popular Products</h3>
                  {%- if block.settings.view_all_url != blank -%}
                    <a href="{{ block.settings.view_all_url }}" class="cih__view-all">View All</a>
                  {%- endif -%}
                </div>
                <div class="cih__product-grid">
                  {%- for product in equip_col.products limit: 4 -%}
                    <a class="cih__pcard" href="{{ product.url }}">
                      <div class="cih__pcard-thumb">
                        {%- if product.featured_image != blank -%}
                          <img src="{{ product.featured_image | image_url: width: 250 }}" alt="{{ product.title }}" width="250" height="250" loading="lazy">
                        {%- else -%}
                          <div style="width:100%;height:100%;background:var(--gray-100);display:flex;align-items:center;justify-content:center;font-size:28px;">📦</div>
                        {%- endif -%}
                      </div>
                      <div class="cih__pcard-name">{{ product.title | truncate: 40 }}</div>
                    </a>
                  {%- endfor -%}
                </div>
              </div>
            {%- endif -%}
          </article>
        {%- endif -%}
      {%- endfor -%}
    </div>
  {%- endif -%}

  <!-- Store types -->
  {%- if has_store_types and section.settings.show_store_types -%}
    <section class="cih__store-type">
      <h2>{{ section.settings.store_types_title | default: 'Shop by Store Type' }}</h2>
      <div class="cih__store-grid">
        {%- for block in section.blocks -%}
          {%- if block.type == 'store_type' -%}
            <a class="cih__store-card" href="{{ block.settings.url | default: '#' }}" {{ block.shopify_attributes }}>
              <div class="cih__store-img">
                {%- if block.settings.image != blank -%}
                  <img src="{{ block.settings.image | image_url: width: 320 }}" alt="{{ block.settings.name }}" width="320" height="220" loading="lazy">
                {%- endif -%}
              </div>
              <div class="cih__store-name">{{ block.settings.name }}</div>
            </a>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </section>
  {%- endif -%}

  <!-- Guides + Help -->
  {%- assign show_row_two = false -%}
  {%- if has_guides and section.settings.show_guides -%}{%- assign show_row_two = true -%}{%- endif -%}
  {%- if section.settings.help_title != blank -%}{%- assign show_row_two = true -%}{%- endif -%}
  {%- if show_row_two -%}
    <div class="cih__row-two">
      {%- if has_guides and section.settings.show_guides -%}
        <div class="cih__guides">
          <div class="cih__guides-head">
            <h2>Buying Guides &amp; Resources</h2>
            <a href="/blogs/news" class="cih__view-all">View All Articles</a>
          </div>
          {%- for block in section.blocks -%}
            {%- if block.type == 'guide' -%}
              <a class="cih__guide-item" href="{{ block.settings.url | default: '#' }}" {{ block.shopify_attributes }}>
                <div class="cih__guide-thumb">
                  {%- if block.settings.image != blank -%}
                    <img src="{{ block.settings.image | image_url: width: 220 }}" alt="{{ block.settings.title }}" width="140" height="90" loading="lazy">
                  {%- endif -%}
                </div>
                <div>
                  <div class="cih__guide-title">{{ block.settings.title }}</div>
                  <div class="cih__guide-meta">{{ block.settings.meta | default: 'Guide' }}</div>
                </div>
              </a>
            {%- endif -%}
          {%- endfor -%}
        </div>
      {%- endif -%}

      <div class="cih__help-block">
        {%- if section.settings.help_title != blank -%}
          <div class="cih__help-row">
            <div class="cih__help-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M21 11.5a8.4 8.4 0 0 1-8.5 8.5A8.4 8.4 0 0 1 9 19l-5 1 1-5a8.4 8.4 0 0 1-1-3.5 8.4 8.4 0 0 1 8.5-8.5 8.4 8.4 0 0 1 8.5 8.5z"/><path d="M9 10h.01M13 10h.01M17 10h.01"/></svg>
            </div>
            <div class="cih__help-text">
              <h3>{{ section.settings.help_title }}</h3>
              {%- if section.settings.help_body != blank -%}<p>{{ section.settings.help_body }}</p>{%- endif -%}
              <a href="{{ section.settings.expert_btn1_url | default: '/pages/contact-us' }}" class="btn btn-outline cih" style="padding:10px 16px;font-size:13px;">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 11.5a8.4 8.4 0 0 1-8.5 8.5A8.4 8.4 0 0 1 9 19l-5 1 1-5a8.4 8.4 0 0 1-1-3.5 8.4 8.4 0 0 1 8.5-8.5 8.4 8.4 0 0 1 8.5 8.5z"/></svg>
                Contact an Expert
              </a>
            </div>
          </div>
        {%- endif -%}
        {%- if has_brands and section.settings.show_brands -%}
          <div class="cih__brands">
            <h3>{{ section.settings.brands_title | default: 'Top Brands We Carry' }}</h3>
            <div class="cih__brand-strip">
              {%- for block in section.blocks -%}
                {%- if block.type == 'brand' -%}
                  <a class="cih__brand{% if block.settings.italic %} italic{% endif %}"
                     href="{{ block.settings.url | default: '#' }}"
                     {% if block.settings.color != blank %}style="color:{{ block.settings.color }}"{% endif %}
                     {{ block.shopify_attributes }}>{{ block.settings.name }}</a>
                {%- endif -%}
              {%- endfor -%}
            </div>
          </div>
        {%- endif -%}
      </div>
    </div>
  {%- endif -%}

</div>

<!-- ============ EXPERT CTA ============ -->
{%- if section.settings.expert_title != blank -%}
  <section class="cih__expert-cta cih">
    <div class="cih__expert-cta-inner">
      <div>
        {%- if section.settings.expert_eyebrow != blank -%}<div class="cih__expert-eyebrow">{{ section.settings.expert_eyebrow }}</div>{%- endif -%}
        <h2>{{ section.settings.expert_title }}</h2>
        {%- if section.settings.expert_body != blank -%}<p>{{ section.settings.expert_body }}</p>{%- endif -%}
      </div>
      <div class="cih__expert-actions">
        {%- if section.settings.expert_btn1_text != blank -%}
          <a href="{{ section.settings.expert_btn1_url | default: '/pages/contact-us' }}" class="btn btn-coral cih">{{ section.settings.expert_btn1_text }}</a>
        {%- endif -%}
        {%- if section.settings.expert_btn2_text != blank -%}
          <a href="{{ section.settings.expert_btn2_url | default: '/pages/contact-us' }}" class="btn btn-secondary cih">{{ section.settings.expert_btn2_text }}</a>
        {%- endif -%}
      </div>
    </div>
  </section>
{%- endif -%}

<!-- ============ FEATURES ============ -->
<section class="cih__features cih">
  <div class="cih__features-inner">
    <div class="cih__feature">
      <div class="cih__feature-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><circle cx="12" cy="8" r="3.2"/><path d="M5 20c.7-3.5 3.6-5.5 7-5.5s6.3 2 7 5.5"/></svg></div>
      <div class="cih__feature-text"><h4>Expert Support</h4><p>Get help from our equipment experts</p></div>
    </div>
    <div class="cih__feature">
      <div class="cih__feature-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><circle cx="11" cy="11" r="7"/><path d="m20 20-4-4"/><path d="M11 8v3l2 2"/></svg></div>
      <div class="cih__feature-text"><h4>Lowest Prices Guaranteed</h4><p>We match competitive pricing</p></div>
    </div>
    <div class="cih__feature">
      <div class="cih__feature-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M2 8h11v9H2zM13 11h5l3 4v2h-8"/><circle cx="6" cy="19" r="1.6"/><circle cx="17" cy="19" r="1.6"/></svg></div>
      <div class="cih__feature-text"><h4>Fast Shipping Across USA</h4><p>Quick delivery, nationwide</p></div>
    </div>
    <div class="cih__feature">
      <div class="cih__feature-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M12 3l8 3v6c0 5-3.5 8-8 9-4.5-1-8-4-8-9V6z"/><path d="m9 12 2 2 4-4"/></svg></div>
      <div class="cih__feature-text"><h4>Trusted by Businesses</h4><p>Thousands of satisfied customers</p></div>
    </div>
  </div>
</section>

<script>
(function() {
  var navItems = document.querySelectorAll('.cih__cat-nav-item[data-anchor]');
  if (!navItems.length) return;
  var sections = [];
  navItems.forEach(function(item) {
    var el = document.getElementById(item.dataset.anchor);
    if (el) sections.push({ el: el, nav: item });
  });
  if (!sections.length) return;
  var observer = new IntersectionObserver(function(entries) {
    entries.forEach(function(entry) {
      if (entry.isIntersecting) {
        sections.forEach(function(s) {
          s.nav.classList.toggle('active', s.el === entry.target);
        });
      }
    });
  }, { rootMargin: '-30% 0px -60% 0px' });
  sections.forEach(function(s) { observer.observe(s.el); });
})();
</script>

