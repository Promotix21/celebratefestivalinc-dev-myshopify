{% comment %}
  CPH Portal Page — Premium Members
  Hero: left text + right stacked collection cards.
  Fallback: hardcoded default collections if blocks are empty/unconfigured.
{% endcomment %}

{%- assign is_cph = false -%}
{%- if customer -%}
  {%- for tag in customer.tags -%}
    {%- assign tag_lower = tag | downcase -%}
    {%- if tag_lower == 'cph' -%}
      {%- assign is_cph = true -%}
      {%- break -%}
    {%- endif -%}
  {%- endfor -%}
{%- endif -%}

{%- unless is_cph -%}
<section class="cph-gate" style="min-height:60vh;display:flex;align-items:center;justify-content:center;text-align:center;padding:60px 20px;">
  <div>
    <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="#1a365d" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" style="margin-bottom:24px;">
      <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
      <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
    </svg>
    <h1 style="font-family:'Montserrat',sans-serif;font-size:28px;font-weight:700;color:#1a365d;margin:0 0 12px;">{{ section.settings.gate_title | default: 'Premium Members Only' }}</h1>
    <p style="font-size:16px;color:#64748b;max-width:480px;margin:0 auto 24px;line-height:1.6;">{{ section.settings.gate_description | default: 'This page is exclusively available to our Premium (CPH) members. Please log in with your premium account to access these curated collections.' }}</p>
    <a href="{{ routes.account_login_url }}?return_url={{ request.path | url_param_escape }}" style="display:inline-block;padding:14px 32px;background:#1a365d;color:#fff;border-radius:8px;font-weight:600;font-size:14px;text-decoration:none;transition:background 0.2s;">{{ section.settings.gate_button | default: 'Log In' }}</a>
  </div>
</section>
{%- else -%}

{%- comment -%} Build collection list: try blocks first, fallback to hardcoded defaults {%- endcomment -%}
{%- assign cph_collections_resolved = 0 -%}
{%- for block in section.blocks -%}
  {%- if block.type == 'collection' -%}
    {%- if block.settings.collection_handle != blank -%}
      {%- assign test_col = collections[block.settings.collection_handle] -%}
      {%- if test_col.handle != blank -%}
        {%- assign cph_collections_resolved = cph_collections_resolved | plus: 1 -%}
      {%- endif -%}
    {%- elsif block.settings.collection != blank -%}
      {%- if block.settings.collection.handle != blank -%}
        {%- assign cph_collections_resolved = cph_collections_resolved | plus: 1 -%}
      {%- endif -%}
    {%- endif -%}
  {%- endif -%}
{%- endfor -%}
{%- assign use_fallback = false -%}
{%- if cph_collections_resolved == 0 -%}
  {%- assign use_fallback = true -%}
{%- endif -%}

<style>
  .cph-page { --cph-deep-blue:#1a365d; --cph-navy:#2d5a87; --cph-coral:#ff6b6b; --cph-gold:#d4af37; --cph-success:#10b981; --cph-text-dark:#0f172a; --cph-text-medium:#475569; --cph-text-light:#64748b; --cph-text-muted:#94a3b8; --cph-border:#e2e8f0; --cph-bg-light:#f8fafc; --cph-bg-white:#ffffff; }
  .cph-page *, .cph-page *::before, .cph-page *::after { box-sizing: border-box; }
  .cph-page { overflow-x: hidden; }

  /* ─── HERO (two-column: left text + right stacked cards) ─── */
  .cph-hero {
    position: relative;
    display: flex; align-items: center; justify-content: center;
    padding: 70px 40px; overflow: hidden; background: var(--cph-deep-blue);
  }
  .cph-hero__mesh {
    position: absolute; inset: 0; z-index: 0;
    background:
      radial-gradient(ellipse 80% 60% at 20% 30%, rgba(45,90,135,0.7) 0%, transparent 70%),
      radial-gradient(ellipse 60% 80% at 80% 70%, rgba(45,90,135,0.5) 0%, transparent 70%),
      radial-gradient(ellipse 50% 50% at 50% 0%, rgba(212,175,55,0.12) 0%, transparent 60%),
      radial-gradient(ellipse 70% 70% at 70% 20%, rgba(255,107,107,0.08) 0%, transparent 50%),
      linear-gradient(135deg, #1a365d 0%, #0f172a 100%);
  }
  .cph-hero__orb {
    position: absolute; border-radius: 50%; filter: blur(80px);
    opacity: 0; animation: cph-orb-drift 12s ease-in-out infinite, cph-orb-in 1.5s ease forwards;
  }
  .cph-hero__orb--1 { width:400px;height:400px;background:rgba(45,90,135,0.35);top:-10%;left:-5%; }
  .cph-hero__orb--2 { width:300px;height:300px;background:rgba(212,175,55,0.12);top:20%;right:-5%;animation-delay:4s; }
  .cph-hero__orb--3 { width:250px;height:250px;background:rgba(255,107,107,0.08);bottom:-10%;left:30%;animation-delay:8s; }
  @keyframes cph-orb-drift { 0%,100%{transform:translate(0,0) scale(1);} 33%{transform:translate(30px,-20px) scale(1.05);} 66%{transform:translate(-20px,15px) scale(0.95);} }
  @keyframes cph-orb-in { to{opacity:1;} }

  /* Hero inner: two-column layout */
  .cph-hero__inner {
    position: relative; z-index: 2;
    display: flex; align-items: center; gap: 60px;
    width: 100%; max-width: 1280px;
  }
  .cph-hero__left {
    flex: 1; min-width: 0;
  }
  .cph-hero__right {
    width: 480px; flex-shrink: 0;
    display: flex; flex-direction: column; gap: 20px;
  }

  .cph-hero__badge {
    display:inline-flex;align-items:center;gap:8px;padding:8px 20px;
    border:1px solid rgba(212,175,55,0.5);border-radius:50px;
    background:rgba(212,175,55,0.1);color:var(--cph-gold);
    font-size:12px;font-weight:700;letter-spacing:1.5px;text-transform:uppercase;
    margin-bottom:24px;backdrop-filter:blur(8px);-webkit-backdrop-filter:blur(8px);
  }
  .cph-hero__badge svg { width:16px;height:16px;flex-shrink:0; }
  .cph-hero__greeting {
    font-family:'Inter',sans-serif;font-size:20px;color:rgba(255,255,255,0.9);
    margin:0 0 10px;font-weight:600;letter-spacing:0.2px;
  }
  .cph-hero__greeting strong {
    background:linear-gradient(135deg,var(--cph-coral) 0%,var(--cph-gold) 100%);
    -webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;
    font-weight:700;
  }
  .cph-hero__title {
    font-family:'Montserrat',sans-serif;font-size:clamp(28px,4vw,46px);font-weight:800;
    color:#fff;margin:0 0 8px;line-height:1.15;letter-spacing:-0.5px;
  }
  .cph-hero__title span {
    background:linear-gradient(135deg,var(--cph-coral) 0%,var(--cph-gold) 100%);
    -webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;
  }
  .cph-hero__subtitle { font-size:15px;color:rgba(255,255,255,0.55);margin:16px 0 0;line-height:1.7;max-width:520px; }

  .cph-hero__scroll {
    position:absolute;bottom:28px;left:50%;transform:translateX(-50%);z-index:2;
    animation:cph-bounce 2s ease-in-out infinite;color:rgba(255,255,255,0.3);
  }
  @keyframes cph-bounce { 0%,100%{transform:translateX(-50%) translateY(0);} 50%{transform:translateX(-50%) translateY(8px);} }

  /* ─── COLLECTION CARDS (inside hero) ─── */
  .cph-card {
    position:relative;border-radius:16px;overflow:hidden;text-decoration:none;display:block;
    min-height:210px;
    transition:transform 0.4s cubic-bezier(0.22,1,0.36,1),box-shadow 0.4s cubic-bezier(0.22,1,0.36,1);
    opacity:0;transform:translateY(30px);
  }
  .cph-card.cph-visible {
    opacity:1;transform:translateY(0);
    transition:opacity 0.7s cubic-bezier(0.22,1,0.36,1),transform 0.7s cubic-bezier(0.22,1,0.36,1),box-shadow 0.4s ease;
  }
  .cph-card:hover {
    transform:translateY(-4px);
    box-shadow:0 20px 48px rgba(0,0,0,0.35),0 8px 20px rgba(0,0,0,0.2);
  }

  .cph-card__bg { position:absolute;top:0;left:0;width:100%;height:100%;z-index:0; }
  .cph-card__bg img { width:100%;height:100%;object-fit:cover;transition:transform 8s cubic-bezier(0.22,1,0.36,1); }
  .cph-card:hover .cph-card__bg img { transform:scale(1.06); }
  .cph-card__bg-placeholder {
    position:absolute;top:0;left:0;width:100%;height:100%;
    background:linear-gradient(135deg,#1a365d 0%,#2d5a87 50%,#5a9ec9 100%);
  }

  .cph-card::before {
    content:'';position:absolute;top:0;left:0;width:100%;height:100%;z-index:1;
    background:linear-gradient(135deg, rgba(26,54,93,0.88) 0%, rgba(45,90,135,0.82) 50%, rgba(96,165,220,0.75) 100%);
    pointer-events:none;border-radius:inherit;
  }

  .cph-card__inner {
    position:relative;z-index:2;display:flex;align-items:center;justify-content:space-between;
    padding:28px 24px;gap:20px;min-height:210px;
  }
  .cph-card__text { flex:1;min-width:0; }
  .cph-card__tag {
    display:inline-flex;align-items:center;gap:6px;padding:4px 12px;
    background:rgba(212,175,55,0.15);border:1px solid rgba(212,175,55,0.3);border-radius:50px;
    font-size:10px;font-weight:700;color:var(--cph-gold);
    text-transform:uppercase;letter-spacing:1.2px;margin-bottom:12px;
  }
  .cph-card__tag svg { width:11px;height:11px; }
  .cph-card__name {
    font-family:'Montserrat',sans-serif;font-size:20px;font-weight:800;
    color:#fff;margin:0 0 6px;line-height:1.2;letter-spacing:-0.3px;
  }
  .cph-card__count {
    font-size:13px;color:rgba(255,255,255,0.5);margin:0 0 18px;font-weight:400;
  }
  .cph-card__cta {
    display:inline-flex;align-items:center;gap:8px;padding:11px 22px;
    background:var(--cph-coral);color:#fff;border-radius:8px;
    font-size:13px;font-weight:700;letter-spacing:0.3px;
    transition:all 0.3s ease;
  }
  .cph-card__cta svg { width:14px;height:14px;transition:transform 0.3s ease; }
  .cph-card:hover .cph-card__cta { background:#ff5252;box-shadow:0 8px 24px rgba(255,107,107,0.3); }
  .cph-card:hover .cph-card__cta svg { transform:translateX(4px); }

  /* Showcase box (right side of card) */
  .cph-showcase {
    width:160px;height:155px;flex-shrink:0;position:relative;
    border-radius:12px;overflow:hidden;
    border:1px solid rgba(255,255,255,0.12);
    background:rgba(255,255,255,0.06);
    backdrop-filter:blur(12px);-webkit-backdrop-filter:blur(12px);
  }
  .cph-showcase__slide {
    position:absolute;inset:0;display:flex;align-items:center;justify-content:center;
    padding:12px;opacity:0;transition:opacity 0.8s ease;
  }
  .cph-showcase__slide.cph-active { opacity:1; }
  .cph-showcase__slide img {
    max-width:100%;max-height:110px;object-fit:contain;
    filter:drop-shadow(0 4px 16px rgba(0,0,0,0.3));
  }
  .cph-showcase__name {
    position:absolute;bottom:0;left:0;right:0;padding:6px 10px;
    background:linear-gradient(transparent,rgba(0,0,0,0.6));
    font-size:10px;color:rgba(255,255,255,0.8);white-space:nowrap;
    overflow:hidden;text-overflow:ellipsis;text-align:center;
  }
  .cph-showcase__dots {
    position:absolute;bottom:6px;left:50%;transform:translateX(-50%);
    display:flex;gap:4px;z-index:3;
  }
  .cph-showcase__dot {
    width:5px;height:5px;border-radius:50%;background:rgba(255,255,255,0.3);
    transition:background 0.3s ease,transform 0.3s ease;
  }
  .cph-showcase__dot.cph-dot-active { background:var(--cph-gold);transform:scale(1.3); }

  /* Shine sweep on hover */
  .cph-card__shine {
    position:absolute;inset:0;z-index:3;pointer-events:none;
    background:linear-gradient(105deg,transparent 40%,rgba(255,255,255,0.04) 45%,rgba(255,255,255,0.08) 50%,rgba(255,255,255,0.04) 55%,transparent 60%);
    transform:translateX(-100%);transition:none;
  }
  .cph-card:hover .cph-card__shine { transform:translateX(100%);transition:transform 0.8s ease; }

  /* ─── STATS BAR ─── */
  .cph-stats {
    display:grid;grid-template-columns:repeat(4,1fr);
    background:var(--cph-bg-white);border-bottom:1px solid var(--cph-border);
  }
  .cph-stats__item { padding:28px 20px;text-align:center;position:relative;transition:background 0.3s ease; }
  .cph-stats__item:not(:last-child)::after {
    content:'';position:absolute;right:0;top:20%;height:60%;width:1px;background:var(--cph-border);
  }
  .cph-stats__item:hover { background:var(--cph-bg-light); }
  .cph-stats__icon { width:40px;height:40px;border-radius:10px;display:inline-flex;align-items:center;justify-content:center;margin-bottom:10px; }
  .cph-stats__icon svg { width:20px;height:20px; }
  .cph-stats__icon--blue { background:rgba(45,90,135,0.1);color:var(--cph-navy); }
  .cph-stats__icon--coral { background:rgba(255,107,107,0.1);color:var(--cph-coral); }
  .cph-stats__icon--gold { background:rgba(212,175,55,0.1);color:var(--cph-gold); }
  .cph-stats__icon--green { background:rgba(16,185,129,0.1);color:var(--cph-success); }
  .cph-stats__value { font-family:'Montserrat',sans-serif;font-size:24px;font-weight:800;color:var(--cph-deep-blue);margin:0 0 4px; }
  .cph-stats__label { font-size:12px;color:var(--cph-text-light);font-weight:500;margin:0; }

  /* ─── SECTION TITLES ─── */
  .cph-stitle {
    font-family:'Montserrat',sans-serif;font-size:30px;font-weight:800;
    color:var(--cph-deep-blue);margin:0 0 12px;letter-spacing:-0.3px;text-align:center;
  }
  .cph-stitle em {
    font-style:normal;
    background:linear-gradient(135deg,var(--cph-coral) 0%,var(--cph-gold) 100%);
    -webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;
  }
  .cph-sdesc { font-size:15px;color:var(--cph-text-light);margin:0 0 40px;line-height:1.6;text-align:center; }

  /* ─── BENEFITS STRIP ─── */
  .cph-benefits { padding:60px 40px; background:var(--cph-bg-white); }
  .cph-benefits__grid { display:grid;grid-template-columns:repeat(3,1fr);gap:24px;max-width:1200px;margin:0 auto; }
  .cph-benefits__card {
    padding:32px 28px;border-radius:14px;border:1px solid var(--cph-border);
    background:var(--cph-bg-white);transition:all 0.3s ease;position:relative;overflow:hidden;
  }
  .cph-benefits__card:hover {
    transform:translateY(-4px);box-shadow:0 12px 40px rgba(26,54,93,0.08);border-color:var(--cph-navy);
  }
  .cph-benefits__icon { width:48px;height:48px;border-radius:12px;display:flex;align-items:center;justify-content:center;margin-bottom:18px; }
  .cph-benefits__icon svg { width:24px;height:24px; }
  .cph-benefits__card h3 { font-family:'Montserrat',sans-serif;font-size:16px;font-weight:700;color:var(--cph-deep-blue);margin:0 0 8px; }
  .cph-benefits__card p { font-size:14px;color:var(--cph-text-light);line-height:1.6;margin:0; }

  /* ─── VIP SUPPORT ─── */
  .cph-support { padding:60px 40px; background:var(--cph-bg-light); }
  .cph-support__card {
    max-width:800px;margin:0 auto;border-radius:16px;overflow:hidden;
    border:1px solid var(--cph-border);background:var(--cph-bg-white);display:flex;align-items:stretch;
  }
  .cph-support__accent { width:6px;flex-shrink:0;background:linear-gradient(180deg,var(--cph-gold) 0%,var(--cph-coral) 100%); }
  .cph-support__body { padding:36px 40px;flex:1; }
  .cph-support__badge {
    display:inline-flex;align-items:center;gap:6px;padding:4px 12px;
    background:rgba(212,175,55,0.1);border:1px solid rgba(212,175,55,0.25);
    border-radius:4px;font-size:10px;font-weight:700;color:var(--cph-gold);
    text-transform:uppercase;letter-spacing:1px;margin-bottom:16px;
  }
  .cph-support__body h3 { font-family:'Montserrat',sans-serif;font-size:20px;font-weight:700;color:var(--cph-deep-blue);margin:0 0 10px; }
  .cph-support__body > p { font-size:14px;color:var(--cph-text-light);line-height:1.6;margin:0 0 24px; }
  .cph-support__phone {
    display:inline-flex;align-items:center;gap:10px;padding:14px 28px;
    background:var(--cph-deep-blue);color:#fff;border-radius:10px;
    font-family:'Montserrat',sans-serif;font-size:18px;font-weight:700;
    text-decoration:none;transition:all 0.3s ease;
  }
  .cph-support__phone:hover { background:var(--cph-navy);transform:translateY(-2px); }
  .cph-support__phone svg { width:20px;height:20px; }

  /* ─── RESPONSIVE ─── */
  @media (max-width:1100px) {
    .cph-hero__inner { gap:40px; }
    .cph-hero__right { width:400px; }
    .cph-hero__title { font-size:clamp(26px,3.5vw,40px); }
  }
  @media (max-width:992px) {
    .cph-hero { padding:50px 24px; }
    .cph-hero__inner { flex-direction:column; gap:40px; text-align:center; }
    .cph-hero__left { max-width:600px; }
    .cph-hero__subtitle { margin:16px auto 0; }
    .cph-hero__right { width:100%;max-width:500px; }
    .cph-benefits { padding:48px 24px; }
    .cph-benefits__grid { grid-template-columns:1fr; }
    .cph-support { padding:48px 24px; }
    .cph-card__inner { padding:24px 20px;gap:16px;min-height:190px; }
    .cph-card__name { font-size:18px; }
    .cph-showcase { width:140px;height:135px; }
    .cph-card__cta { width:100%;justify-content:center; }
  }
  @media (max-width:768px) {
    .cph-hero { padding:40px 20px; }
    .cph-stats { grid-template-columns:repeat(2,1fr); }
    .cph-stats__item:nth-child(2)::after { display:none; }
    .cph-card__inner { flex-direction:column;text-align:center;padding:28px 20px;gap:20px; }
    .cph-card__text { order:2; }
    .cph-showcase { order:1;width:160px;height:150px; }
    .cph-card__cta { width:100%;justify-content:center; }
    .cph-support__body { padding:28px 24px; }
    .cph-support__phone { font-size:16px;padding:12px 22px; }
  }
  @media (max-width:576px) {
    .cph-stitle { font-size:26px; }
    .cph-card__name { font-size:17px; }
    .cph-showcase { width:140px;height:130px; }
    .cph-stats__value { font-size:18px; }
  }
</style>

<div class="cph-page">

  <!-- ══════ HERO (left text + right stacked cards) ══════ -->
  <section class="cph-hero">
    <div class="cph-hero__mesh"></div>
    <div class="cph-hero__orb cph-hero__orb--1"></div>
    <div class="cph-hero__orb cph-hero__orb--2"></div>
    <div class="cph-hero__orb cph-hero__orb--3"></div>

    <div class="cph-hero__inner">
      <!-- LEFT: hero text -->
      <div class="cph-hero__left">
        <div class="cph-hero__badge">
          <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2L15.09 8.26L22 9.27L17 14.14L18.18 21.02L12 17.77L5.82 21.02L7 14.14L2 9.27L8.91 8.26L12 2Z"/></svg>
          {{ section.settings.hero_badge_text | default: 'Premium Member Portal' }}
        </div>
        <p class="cph-hero__greeting">{{ section.settings.hero_greeting | default: 'Welcome back,' }} <strong>{{ customer.first_name | default: 'Member' }}</strong></p>
        <h1 class="cph-hero__title">{{ section.settings.hero_title | default: 'Your Premium<br><span>Equipment Hub</span>' }}</h1>
        <p class="cph-hero__subtitle">{{ section.settings.hero_description | default: 'Your exclusive portal for premium restaurant equipment. Browse curated collections at your member-only pricing.' }}</p>
      </div>

      <!-- RIGHT: stacked collection cards -->
      <div class="cph-hero__right" id="cph-cards">

        {%- if use_fallback -%}
          {%- assign fallback_handles = 'pizza-equipment,smallware-cph' | split: ',' -%}
          {%- assign fallback_titles = 'Pizza Equipments,Smallware Items' | split: ',' -%}
          {%- for fh in fallback_handles -%}
            {%- assign col = collections[fh] -%}
            {%- if col.handle == blank -%}{%- continue -%}{%- endif -%}
            {%- assign card_title = fallback_titles[forloop.index0] | default: col.title -%}

            {%- assign prod_images_json = '' -%}
            {%- assign prod_names_json = '' -%}
            {%- assign img_count = 0 -%}
            {%- for product in col.products limit: 6 -%}
              {%- if product.featured_image -%}
                {%- if img_count > 0 -%}
                  {%- assign prod_images_json = prod_images_json | append: '|||' -%}
                  {%- assign prod_names_json = prod_names_json | append: '|||' -%}
                {%- endif -%}
                {%- assign img_url = product.featured_image | image_url: width: 400 -%}
                {%- assign prod_images_json = prod_images_json | append: img_url -%}
                {%- assign prod_names_json = prod_names_json | append: product.title -%}
                {%- assign img_count = img_count | plus: 1 -%}
              {%- endif -%}
            {%- endfor -%}

            <a href="{{ col.url }}" class="cph-card" data-images="{{ prod_images_json }}" data-names="{{ prod_names_json | escape }}">
              <div class="cph-card__bg">
                {% if col.image %}
                  <img src="{{ col.image | image_url: width: 1400 }}" alt="" loading="lazy">
                {% elsif col.products.first.featured_image %}
                  <img src="{{ col.products.first.featured_image | image_url: width: 1400 }}" alt="" loading="lazy">
                {% else %}
                  <div class="cph-card__bg-placeholder"></div>
