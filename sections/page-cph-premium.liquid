                  {%- assign prod_images_json = prod_images_json | append: img_url -%}
                  {%- assign prod_names_json = prod_names_json | append: product.title -%}
                  {%- assign img_count = img_count | plus: 1 -%}
                {%- endif -%}
              {%- endfor -%}

              <a href="{{ col.url }}" class="cph-card" data-images="{{ prod_images_json }}" data-names="{{ prod_names_json | escape }}" {{ block.shopify_attributes }}>
                <div class="cph-card__bg">
