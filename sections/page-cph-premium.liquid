<script>
(function() {
  'use strict';

  /* ── Scroll reveal ── */
  function initScrollReveal() {
    var cards = document.querySelectorAll('.cph-card');
    if (!cards.length) return;
    var observer = new IntersectionObserver(function(entries) {
      entries.forEach(function(entry) {
        if (entry.isIntersecting) {
          var card = entry.target;
          var idx = parseInt(card.getAttribute('data-cph-idx'), 10) || 0;
          setTimeout(function() { card.classList.add('cph-visible'); }, idx * 200);
          observer.unobserve(card);
        }
      });
    }, { threshold: 0.15 });
    cards.forEach(function(card, i) { card.setAttribute('data-cph-idx', i); observer.observe(card); });
  }

  /* ── Product image rotator in showcase boxes ── */
  function initShowcaseRotators() {
    var cards = document.querySelectorAll('.cph-card[data-images]');
    cards.forEach(function(card) {
      var imagesStr = card.getAttribute('data-images');
      var namesStr = card.getAttribute('data-names') || '';
      if (!imagesStr) return;

      var images = imagesStr.split('|||');
      var names = namesStr.split('|||');
      if (images.length === 0 || (images.length === 1 && !images[0])) return;

      var showcase = card.querySelector('.cph-showcase');
      if (!showcase) return;

      /* Build slides + dots */
      var dotsContainer = document.createElement('div');
      dotsContainer.className = 'cph-showcase__dots';

      images.forEach(function(src, i) {
        var slide = document.createElement('div');
        slide.className = 'cph-showcase__slide' + (i === 0 ? ' cph-active' : '');
        var img = document.createElement('img');
        img.src = src;
        img.alt = names[i] || 'Product';
        img.loading = 'lazy';
        slide.appendChild(img);

        if (names[i]) {
          var nameEl = document.createElement('div');
          nameEl.className = 'cph-showcase__name';
          nameEl.textContent = names[i].length > 30 ? names[i].substring(0, 30) + '...' : names[i];
          slide.appendChild(nameEl);
        }
        showcase.appendChild(slide);

        var dot = document.createElement('div');
        dot.className = 'cph-showcase__dot' + (i === 0 ? ' cph-dot-active' : '');
        dotsContainer.appendChild(dot);
      });

      showcase.appendChild(dotsContainer);

      /* Auto-rotate every 3s */
      if (images.length > 1) {
        var current = 0;
        var slides = showcase.querySelectorAll('.cph-showcase__slide');
        var dots = showcase.querySelectorAll('.cph-showcase__dot');

        setInterval(function() {
          slides[current].classList.remove('cph-active');
          dots[current].classList.remove('cph-dot-active');
          current = (current + 1) % slides.length;
          slides[current].classList.add('cph-active');
          dots[current].classList.add('cph-dot-active');
        }, 3000);
      }
    });
  }

  function init() {
    initScrollReveal();
    initShowcaseRotators();
  }

  if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', init);
  else init();
})();
</script>

