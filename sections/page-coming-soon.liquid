      "label": "Show email notification form",
      "default": true
    },
    {
      "type": "text",
      "id": "form_label",
      "label": "Form Label",
      "default": "Get notified when this page goes live"
    },
    {
      "type": "text",
      "id": "form_button_text",
      "label": "Form Button Text",
      "default": "Notify Me"
    },
    {
