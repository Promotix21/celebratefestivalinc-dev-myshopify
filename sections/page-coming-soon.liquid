      "default": "/"
    },
    {
      "type": "text",
      "id": "secondary_btn_text",
      "label": "Secondary Button Text",
      "default": "Browse Collections"
    },
    {
      "type": "url",
      "id": "secondary_btn_url",
      "label": "Secondary Button URL",
      "default": "/collections/all"
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature Badge",
      "limit": 6,
      "settings": [
        {
          "type": "text",
          "id": "icon",
          "label": "Icon (HTML entity or emoji)",
          "default": "&#9733;",
          "info": "Examples: &#9733; (star), &#9878; (gear), &#10003; (check), &#9742; (phone)"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "Feature"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Coming Soon Page",
      "blocks": [
        {
          "type": "feature",
          "settings": { "icon": "&#9878;", "label": "Professional Grade Equipment" }
        },
        {
          "type": "feature",
          "settings": { "icon": "&#9733;", "label": "Exclusive Member Pricing" }
        },
        {
          "type": "feature",
          "settings": { "icon": "&#10003;", "label": "Free Shipping on Select Items" }
        },
        {
          "type": "feature",
          "settings": { "icon": "&#9742;", "label": "Expert Support: (408) 673-9999" }
        }
      ]
    }
  ]
}
{% endschema %}
