    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "We're working hard to bring you this page. Professional-grade restaurant equipment, curated collections, and exclusive member pricing — all arriving shortly."
    },
    {
      "type": "header",
      "content": "Email Signup"
    },
    {
      "type": "checkbox",
