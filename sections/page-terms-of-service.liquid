{% comment %}
  Terms of Service Page Section - Celebrate Festival Inc
  Professional legal content page with consistent theme styling
{% endcomment %}

<style>
  .tos-page {
    --cf-deep-blue: #1a365d;
    --cf-navy: #2d5a87;
    --cf-coral: #ff6b6b;
    --cf-gold: #d4af37;
    --cf-success: #10b981;
    --cf-text-dark: #0f172a;
    --cf-text-medium: #475569;
    --cf-text-light: #64748b;
    --cf-text-muted: #94a3b8;
    --cf-border: #e2e8f0;
    --cf-bg-light: #f8fafc;
    --cf-bg-white: #ffffff;
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
  }

  /* Hero Section */
  .tos-hero {
    background: linear-gradient(135deg, var(--cf-deep-blue) 0%, #0f172a 100%);
    padding: 60px 40px;
    text-align: center;
    position: relative;
    overflow: hidden;
  }

  .tos-hero__shapes {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .tos-hero .shape {
    position: absolute;
    border-radius: 50%;
    opacity: 0.1;
    background: white;
  }

  .tos-hero .shape--1 {
    width: 300px;
    height: 300px;
    top: -100px;
    right: -50px;
  }

  .tos-hero .shape--2 {
    width: 200px;
    height: 200px;
    bottom: -80px;
    left: 10%;
  }

  .tos-hero__content {
    position: relative;
    z-index: 1;
    max-width: 700px;
    margin: 0 auto;
  }

  .tos-hero__tagline {
    display: inline-block;
    background: rgba(255, 255, 255, 0.15);
    padding: 8px 20px;
    border-radius: 30px;
    font-size: 13px;
    font-weight: 600;
    color: white;
    margin-bottom: 20px;
    letter-spacing: 0.5px;
  }

  .tos-hero__title {
    font-family: 'Montserrat', sans-serif;
    font-size: 36px;
    font-weight: 700;
    color: white;
    margin: 0 0 16px;
  }

  .tos-hero__subtitle {
    font-size: 16px;
    color: rgba(255, 255, 255, 0.8);
    margin: 0;
    line-height: 1.6;
  }

  /* Last Updated Badge */
  .tos-hero__updated {
    display: inline-block;
    margin-top: 20px;
    font-size: 13px;
    color: rgba(255, 255, 255, 0.6);
  }

  /* Table of Contents */
  .tos-toc {
    background: var(--cf-bg-light);
    padding: 30px 40px;
    border-bottom: 1px solid var(--cf-border);
  }

  .tos-toc__inner {
    max-width: 900px;
    margin: 0 auto;
  }

  .tos-toc__title {
    font-family: 'Montserrat', sans-serif;
    font-size: 14px;
    font-weight: 700;
    color: var(--cf-deep-blue);
    margin: 0 0 16px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .tos-toc__list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 8px 24px;
  }

  .tos-toc__link {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 14px;
    color: var(--cf-navy);
    text-decoration: none;
    padding: 6px 0;
    transition: all 0.2s ease;
  }

  .tos-toc__link:hover {
    color: var(--cf-coral);
    padding-left: 4px;
  }

  .tos-toc__link::before {
    content: '';
    width: 4px;
    height: 4px;
    background: var(--cf-navy);
    border-radius: 50%;
    flex-shrink: 0;
    transition: background 0.2s ease;
  }

  .tos-toc__link:hover::before {
    background: var(--cf-coral);
  }

  /* Content Area */
  .tos-content {
    max-width: 900px;
    margin: 0 auto;
    padding: 50px 40px;
  }

  /* Content Sections */
  .tos-section {
    margin-bottom: 40px;
    scroll-margin-top: 20px;
  }

  .tos-section__header {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 16px;
    padding-bottom: 12px;
    border-bottom: 2px solid var(--cf-border);
  }

  .tos-section__number {
    width: 36px;
    height: 36px;
    background: linear-gradient(135deg, var(--cf-deep-blue) 0%, var(--cf-navy) 100%);
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    font-family: 'Montserrat', sans-serif;
    font-size: 14px;
    font-weight: 700;
    flex-shrink: 0;
  }

  .tos-section__title {
    font-family: 'Montserrat', sans-serif;
    font-size: 20px;
    font-weight: 700;
    color: var(--cf-deep-blue);
    margin: 0;
  }

  .tos-section__body {
    color: var(--cf-text-medium);
    font-size: 15px;
    line-height: 1.8;
  }

  .tos-section__body p {
    margin: 0 0 16px;
  }

  .tos-section__body p:last-child {
    margin-bottom: 0;
  }

  .tos-section__body a {
    color: var(--cf-navy);
    text-decoration: underline;
    transition: color 0.2s ease;
  }

  .tos-section__body a:hover {
    color: var(--cf-coral);
  }

  .tos-section__body strong {
    color: var(--cf-text-dark);
    font-weight: 600;
  }

  .tos-section__body ul,
  .tos-section__body ol {
    margin: 12px 0;
    padding-left: 20px;
  }

  .tos-section__body li {
    margin-bottom: 8px;
  }

  /* Highlight Box */
  .tos-highlight {
    background: linear-gradient(135deg, #dbeafe 0%, #eff6ff 100%);
    border: 1px solid rgba(45, 90, 135, 0.2);
    border-radius: 10px;
    padding: 20px 24px;
    margin: 20px 0;
  }

  .tos-highlight p {
    margin: 0;
    font-size: 14px;
    color: var(--cf-deep-blue);
  }

  .tos-highlight strong {
    color: var(--cf-deep-blue);
  }

  /* Contact CTA */
  .tos-contact {
    background: var(--cf-bg-light);
    padding: 50px 40px;
    text-align: center;
  }

  .tos-contact__inner {
    max-width: 600px;
    margin: 0 auto;
  }

  .tos-contact__title {
    font-family: 'Montserrat', sans-serif;
    font-size: 24px;
    font-weight: 700;
    color: var(--cf-deep-blue);
    margin: 0 0 12px;
  }

  .tos-contact__text {
    font-size: 15px;
    color: var(--cf-text-medium);
    margin: 0 0 24px;
  }

  .tos-contact__buttons {
    display: flex;
    justify-content: center;
    gap: 16px;
    flex-wrap: wrap;
  }

  .tos-contact__btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 14px 28px;
    border-radius: 8px;
    font-size: 14px;
    font-weight: 600;
    text-decoration: none;
    transition: all 0.3s ease;
  }

  .tos-contact__btn--primary {
    background: var(--cf-coral);
    color: white;
  }

  .tos-contact__btn--primary:hover {
    background: #ff5252;
    transform: translateY(-2px);
    box-shadow: 0 4px 12px rgba(255, 107, 107, 0.4);
  }

  .tos-contact__btn--secondary {
    background: white;
    color: var(--cf-navy);
    border: 2px solid var(--cf-navy);
  }

  .tos-contact__btn--secondary:hover {
    background: var(--cf-navy);
    color: white;
    transform: translateY(-2px);
  }

  /* Responsive */
  @media (max-width: 768px) {
    .tos-hero {
      padding: 40px 20px;
    }

    .tos-hero__title {
      font-size: 28px;
    }

    .tos-toc {
      padding: 24px 20px;
    }

    .tos-toc__list {
      grid-template-columns: 1fr;
    }

    .tos-content {
      padding: 30px 20px;
    }

    .tos-section__title {
      font-size: 17px;
    }

    .tos-contact {
      padding: 40px 20px;
    }

    .tos-contact__buttons {
      flex-direction: column;
    }

    .tos-contact__btn {
      justify-content: center;
    }
  }
</style>

<div class="tos-page">
  <!-- Hero Section -->
  <section class="tos-hero">
    <div class="tos-hero__shapes">
      <div class="shape shape--1"></div>
      <div class="shape shape--2"></div>
    </div>
    <div class="tos-hero__content">
      <span class="tos-hero__tagline">{{ section.settings.hero_tagline }}</span>
      <h1 class="tos-hero__title">{{ section.settings.hero_title }}</h1>
      <p class="tos-hero__subtitle">{{ section.settings.hero_subtitle }}</p>
      {% if section.settings.last_updated != blank %}
        <span class="tos-hero__updated">Last Updated: {{ section.settings.last_updated }}</span>
      {% endif %}
    </div>
  </section>

  <!-- Table of Contents -->
  {% if section.settings.show_toc %}
  <nav class="tos-toc">
    <div class="tos-toc__inner">
      <h2 class="tos-toc__title">Table of Contents</h2>
      <ol class="tos-toc__list">
        {% assign section_index = 0 %}
        {% for block in section.blocks %}
          {% if block.type == 'tos_section' %}
            {% assign section_index = section_index | plus: 1 %}
            <li>
              <a href="#tos-section-{{ section_index }}" class="tos-toc__link">
                {{ block.settings.section_title }}
              </a>
            </li>
          {% endif %}
        {% endfor %}
      </ol>
    </div>
  </nav>
  {% endif %}

  <!-- TOS Content -->
  <div class="tos-content">
    {% assign section_index = 0 %}
    {% for block in section.blocks %}
      {% if block.type == 'tos_section' %}
        {% assign section_index = section_index | plus: 1 %}
        <section class="tos-section" id="tos-section-{{ section_index }}" {{ block.shopify_attributes }}>
          <div class="tos-section__header">
            <span class="tos-section__number">{{ section_index }}</span>
            <h2 class="tos-section__title">{{ block.settings.section_title }}</h2>
          </div>
          <div class="tos-section__body">
            {{ block.settings.section_content }}
          </div>
        </section>
      {% elsif block.type == 'highlight_box' %}
        <div class="tos-highlight" {{ block.shopify_attributes }}>
          {{ block.settings.highlight_content }}
        </div>
      {% endif %}
    {% endfor %}
  </div>

  <!-- Contact CTA -->
  {% if section.settings.show_contact_cta %}
  <section class="tos-contact">
    <div class="tos-contact__inner">
      <h2 class="tos-contact__title">{{ section.settings.contact_title }}</h2>
      <p class="tos-contact__text">{{ section.settings.contact_text }}</p>
      <div class="tos-contact__buttons">
        {% if section.settings.contact_phone != blank %}
        <a href="tel:{{ section.settings.contact_phone | remove: ' ' | remove: '-' | remove: '(' | remove: ')' }}" class="tos-contact__btn tos-contact__btn--primary">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          {{ section.settings.contact_phone }}
        </a>
        {% endif %}
        {% if section.settings.contact_email != blank %}
        <a href="mailto:{{ section.settings.contact_email }}" class="tos-contact__btn tos-contact__btn--secondary">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
          Email Us
        </a>
        {% endif %}
      </div>
    </div>
  </section>
  {% endif %}
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
  // Smooth scroll for TOC links
  document.querySelectorAll('.tos-toc__link').forEach(function(link) {
    link.addEventListener('click', function(e) {
      e.preventDefault();
      var target = document.querySelector(this.getAttribute('href'));
      if (target) {
        target.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }
    });
  });
});
</script>

{% schema %}
{
  "name": "Terms of Service",
  "tag": "section",
  "class": "section-tos-page",
  "settings": [
    {
      "type": "header",
      "content": "Hero Section"
    },
    {
      "type": "text",
      "id": "hero_tagline",
      "label": "Hero Tagline",
      "default": "Legal"
    },
    {
      "type": "text",
      "id": "hero_title",
      "label": "Hero Title",
      "default": "Terms of Service"
    },
    {
      "type": "textarea",
      "id": "hero_subtitle",
      "label": "Hero Subtitle",
      "default": "Please review the following terms and conditions that govern your use of our website and purchase of products."
    },
    {
      "type": "text",
      "id": "last_updated",
      "label": "Last Updated Date",
      "default": "February 2026"
    },
    {
      "type": "header",
      "content": "Table of Contents"
    },
    {
      "type": "checkbox",
      "id": "show_toc",
      "label": "Show Table of Contents",
      "default": true
    },
    {
      "type": "header",
      "content": "Contact Section"
    },
    {
      "type": "checkbox",
      "id": "show_contact_cta",
      "label": "Show Contact Section",
      "default": true
    },
    {
      "type": "text",
      "id": "contact_title",
      "label": "Contact Title",
      "default": "Questions about our policies?"
    },
    {
      "type": "textarea",
      "id": "contact_text",
      "label": "Contact Text",
      "default": "If you have any questions about these terms, please don't hesitate to reach out to our team."
    },
    {
      "type": "text",
      "id": "contact_phone",
      "label": "Contact Phone",
      "default": "(408) 673-9999"
    },
    {
      "type": "text",
      "id": "contact_email",
      "label": "Contact Email",
      "default": "sales@celebratefestivalinc.com"
    }
  ],
  "blocks": [
    {
      "type": "tos_section",
      "name": "TOS Section",
      "settings": [
        {
          "type": "text",
          "id": "section_title",
          "label": "Section Title",
          "default": "Section Title"
        },
        {
          "type": "richtext",
          "id": "section_content",
          "label": "Section Content",
          "default": "<p>Section content goes here.</p>"
        }
      ]
    },
    {
      "type": "highlight_box",
      "name": "Highlight Box",
      "settings": [
        {
          "type": "richtext",
          "id": "highlight_content",
          "label": "Highlight Content",
          "default": "<p><strong>Important:</strong> Key information highlighted here.</p>"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Terms of Service",
      "blocks": [
        {
          "type": "tos_section",
          "settings": {
            "section_title": "Information and Site Content",
            "section_content": "<p>We take every precaution when adding new items to our website using information directly from our manufacturers and suppliers. We present this information to you as accurately as we can, although errors and omissions do occur from time to time.</p><p>If you see any discrepancies, or potentially incorrect information or have any other questions about products we offer, please contact customer service via email or call us at (408) 673-9999.</p><p>It is our goal to provide you with the best information about foodservice equipment and supplies available on the Internet and we want to correct any missing or erroneous information as quickly as possible.</p>"
          }
        },
        {
          "type": "tos_section",
          "settings": {
            "section_title": "Typographical and Image Errors",
            "section_content": "<p>We make every effort to provide you with the most up-to-date and accurate information on the products we sell. We work closely with the manufacturers of our products to obtain this information, however, there are cases where obtaining an exact description or photo of the product is impossible.</p><p>When purchasing an item, please make sure to read the description as well as look at the image before committing to the purchase. We reserve the right to refuse or cancel any order for any reason.</p>"
          }
        },
        {
          "type": "tos_section",
          "settings": {
            "section_title": "Prices",
            "section_content": "<p>At Celebrate Festival Inc we believe you deserve the industry's best customer care and lowest prices for every purchase. If you find an item we offer elsewhere at a lower total cost, including shipping costs, please reach out to us at <a href='mailto:sales@celebratefestivalinc.com'>sales@celebratefestivalinc.com</a> with the details.</p><p>Prices are subject to change without notification. If a price differs from the website total you will be contacted to confirm.</p>"
          }
        }
      ]
    }
  ]
}
{% endschema %}
