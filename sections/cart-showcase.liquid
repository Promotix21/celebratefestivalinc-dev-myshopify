{%- liquid
  assign content_right = false
  if section.settings.content_position == 'right'
    assign content_right = true
  endif
  assign slide_blocks = section.blocks | where: "type", "slide"
  assign feature_blocks = section.blocks | where: "type", "feature"
  assign slide_count = slide_blocks | size
-%}

<section
  class="cart-showcase{% if content_right %} cart-showcase--content-right{% endif %}"
  id="cart-showcase-{{ section.id }}"
  style="
    --cs-bg: {{ section.settings.bg_color }};
    --cs-accent: {{ section.settings.accent_color }};
    --cs-min-height: {{ section.settings.min_height }}px;
    --cs-blur: {{ section.settings.bg_blur }}px;
  "
>
  <div class="cart-showcase__inner">

    {%- comment -%}— CONTENT SIDE —{%- endcomment -%}
    <div class="cart-showcase__content">

      {%- if section.settings.badge_text != blank -%}
        <span class="cart-showcase__badge">{{ section.settings.badge_text }}</span>
      {%- endif -%}

      {%- if section.settings.heading != blank -%}
        <h2 class="cart-showcase__heading">{{ section.settings.heading }}</h2>
      {%- endif -%}

      {%- if section.settings.subheading != blank -%}
        <p class="cart-showcase__subheading">{{ section.settings.subheading }}</p>
      {%- endif -%}

      {%- if section.settings.description != blank -%}
        <p class="cart-showcase__desc">{{ section.settings.description }}</p>
      {%- endif -%}

      {%- if feature_blocks.size > 0 -%}
        <ul class="cart-showcase__features">
          {%- for block in feature_blocks -%}
            {%- if block.settings.text != blank -%}
              <li class="cart-showcase__feature" {{ block.shopify_attributes }}>
                <span class="cart-showcase__feature-icon" aria-hidden="true">
                  <svg width="12" height="12" viewBox="0 0 12 12" fill="none">
                    <path d="M1.5 6L4.5 9L10.5 3" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </span>
                <span>{{ block.settings.text }}</span>
              </li>
            {%- endif -%}
          {%- endfor -%}
        </ul>
      {%- endif -%}

      {%- if section.settings.cta_text != blank -%}
        <a
          href="{{ section.settings.cta_url | default: '#' }}"
          class="cart-showcase__cta"
        >
          {{ section.settings.cta_text }}
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <path d="M3 8H13M13 8L9 4M13 8L9 12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      {%- endif -%}

    </div>

    {%- comment -%}— IMAGE SLIDER SIDE —{%- endcomment -%}
    <div
      class="cart-showcase__slider"
      data-autoplay="{{ section.settings.autoplay }}"
      data-speed="{{ section.settings.autoplay_speed }}"
      role="region"
      aria-label="Product image slider"
    >

      {%- if slide_count > 0 -%}

        {%- for block in slide_blocks -%}
          {%- if block.settings.image != blank -%}
            <div
              class="cart-showcase__slide{% if forloop.first %} is-active{% endif %}"
              {{ block.shopify_attributes }}
              role="group"
              aria-label="Slide {{ forloop.index }} of {{ slide_count }}"
            >
              <div class="cart-showcase__blur-bg" aria-hidden="true">
                <img
                  src="{{ block.settings.image | image_url: width: 1200 }}"
                  alt=""
                  class="cart-showcase__blur-img"
                  loading="{% if forloop.first %}eager{% else %}lazy{% endif %}"
                >
              </div>

              <div class="cart-showcase__overlay" aria-hidden="true"></div>

              <div class="cart-showcase__image-wrap">
                <img
                  src="{{ block.settings.image | image_url: width: 900 }}"
                  alt="{{ block.settings.caption | default: section.settings.heading | escape }}"
                  class="cart-showcase__image"
                  loading="{% if forloop.first %}eager{% else %}lazy{% endif %}"
                  width="900"
                >
              </div>

            </div>
          {%- endif -%}
        {%- endfor -%}

        {%- if slide_count > 1 -%}

          <button class="cart-showcase__arrow cart-showcase__arrow--prev" aria-label="Previous slide">
            <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
              <path d="M11 4L6 9L11 14" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>

          <button class="cart-showcase__arrow cart-showcase__arrow--next" aria-label="Next slide">
            <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
              <path d="M7 4L12 9L7 14" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>

          <div class="cart-showcase__dots" role="tablist" aria-label="Slide navigation">
            {%- for block in slide_blocks -%}
              {%- if block.settings.image != blank -%}
                <button
                  class="cart-showcase__dot{% if forloop.first %} is-active{% endif %}"
                  data-slide="{{ forloop.index0 }}"
                  role="tab"
                  aria-selected="{{ forloop.first | json }}"
                  aria-label="Slide {{ forloop.index }}"
                ></button>
              {%- endif -%}
            {%- endfor -%}
          </div>

        {%- endif -%}

      {%- else -%}
        <div class="cart-showcase__placeholder">
          <p>Add slides in the theme customizer to display images here.</p>
        </div>
      {%- endif -%}

    </div>
  </div>
</section>

<style>
  /* ============================================================
     CART SHOWCASE — scoped to section {{ section.id }}
     ============================================================ */

  #cart-showcase-{{ section.id }} {
    background-color: var(--cs-bg, #1a365d);
    overflow: hidden;
    position: relative;
  }

  #cart-showcase-{{ section.id }} .cart-showcase__inner {
    display: flex;
    min-height: var(--cs-min-height, 560px);
  }

  #cart-showcase-{{ section.id }}.cart-showcase--content-right .cart-showcase__inner {
    flex-direction: row-reverse;
  }

  /* ---- CONTENT SIDE ---- */
  #cart-showcase-{{ section.id }} .cart-showcase__content {
    flex: 0 0 42%;
    padding: 64px 56px 64px 64px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 0;
    z-index: 2;
    position: relative;
  }

  #cart-showcase-{{ section.id }}.cart-showcase--content-right .cart-showcase__content {
    padding: 64px 64px 64px 56px;
  }

  #cart-showcase-{{ section.id }} .cart-showcase__badge {
    display: inline-flex;
    align-items: center;
    background: rgba(212, 175, 55, 0.15);
    border: 1px solid rgba(212, 175, 55, 0.4);
    color: #d4af37;
    padding: 5px 14px;
    border-radius: 100px;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    margin-bottom: 20px;
    width: fit-content;
  }

  #cart-showcase-{{ section.id }} .cart-showcase__heading {
    font-family: 'Montserrat', sans-serif;
    font-size: clamp(26px, 2.8vw, 42px);
    font-weight: 800;
    color: #ffffff;
    line-height: 1.15;
    margin: 0 0 12px;
    letter-spacing: -0.5px;
  }

  #cart-showcase-{{ section.id }} .cart-showcase__subheading {
    font-family: 'Montserrat', sans-serif;
    font-size: 15px;
    font-weight: 500;
    color: rgba(255, 255, 255, 0.6);
    margin: 0 0 20px;
    line-height: 1.55;
  }

  #cart-showcase-{{ section.id }} .cart-showcase__desc {
    font-family: 'Inter', sans-serif;
    font-size: 15px;
    line-height: 1.8;
    color: rgba(255, 255, 255, 0.68);
    margin: 0 0 28px;
  }

  #cart-showcase-{{ section.id }} .cart-showcase__features {
    list-style: none;
    padding: 0;
    margin: 0 0 36px;
    display: flex;
    flex-direction: column;
    gap: 13px;
  }

  #cart-showcase-{{ section.id }} .cart-showcase__feature {
    display: flex;
    align-items: flex-start;
    gap: 11px;
    font-family: 'Inter', sans-serif;
    font-size: 14px;
    color: rgba(255, 255, 255, 0.8);
    line-height: 1.5;
  }

  #cart-showcase-{{ section.id }} .cart-showcase__feature-icon {
    flex-shrink: 0;
    width: 22px;
    height: 22px;
    border-radius: 50%;
    background: rgba(212, 175, 55, 0.15);
    border: 1px solid rgba(212, 175, 55, 0.4);
    display: flex;
    align-items: center;
    justify-content: center;
    color: #d4af37;
    margin-top: 1px;
  }

  #cart-showcase-{{ section.id }} .cart-showcase__cta {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    background: var(--cs-accent, #ff6b6b);
    color: #ffffff;
    padding: 14px 28px;
    border-radius: 8px;
    font-family: 'Montserrat', sans-serif;
    font-size: 14px;
    font-weight: 700;
    text-decoration: none;
    transition: background 0.25s ease, transform 0.22s ease, box-shadow 0.25s ease;
    width: fit-content;
    letter-spacing: 0.3px;
  }

  #cart-showcase-{{ section.id }} .cart-showcase__cta:hover {
    background: color-mix(in srgb, var(--cs-accent, #ff6b6b) 85%, black);
    transform: translateY(-2px);
    box-shadow: 0 10px 28px rgba(255, 107, 107, 0.35);
    color: #ffffff;
  }

  /* ---- SLIDER SIDE ---- */
  #cart-showcase-{{ section.id }} .cart-showcase__slider {
    flex: 1;
    position: relative;
    overflow: hidden;
    background: rgba(0, 0, 0, 0.25);
  }

  /* All slides stacked, absolutely positioned */
  #cart-showcase-{{ section.id }} .cart-showcase__slide {
    position: absolute;
    inset: 0;
    opacity: 0;
    transition: opacity 1s ease;
    z-index: 1;
  }

  #cart-showcase-{{ section.id }} .cart-showcase__slide.is-active {
    opacity: 1;
    z-index: 2;
  }

  /* Layer 1: Blurred ambient background */
  #cart-showcase-{{ section.id }} .cart-showcase__blur-bg {
    position: absolute;
    inset: -60px;
    overflow: hidden;
    filter: blur(var(--cs-blur, 28px)) brightness(0.6) saturate(1.4);
    animation: cs-ken-burns-{{ section.id }} 14s ease-in-out infinite alternate;
    will-change: transform;
  }

  #cart-showcase-{{ section.id }} .cart-showcase__blur-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  @keyframes cs-ken-burns-{{ section.id }} {
    0%   { transform: scale(1.00) translate(  0%,    0%); }
    20%  { transform: scale(1.07) translate(-1.2%,  -0.8%); }
    45%  { transform: scale(1.13) translate( 1.5%,  -0.4%); }
    70%  { transform: scale(1.09) translate(-0.6%,   1.1%); }
    100% { transform: scale(1.05) translate( 0.9%,   0.3%); }
  }

  /* Layer 2: Gradient overlay — directional, blends into content side */
  #cart-showcase-{{ section.id }} .cart-showcase__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to left,
      rgba(26, 54, 93, 0.0)  0%,
      rgba(26, 54, 93, 0.35) 100%
    );
    z-index: 1;
  }

  #cart-showcase-{{ section.id }}.cart-showcase--content-right .cart-showcase__overlay {
    background: linear-gradient(
      to right,
      rgba(26, 54, 93, 0.0)  0%,
      rgba(26, 54, 93, 0.35) 100%
    );
  }

  /* Layer 3: Contain image */
  #cart-showcase-{{ section.id }} .cart-showcase__image-wrap {
    position: absolute;
    inset: 40px;
    z-index: 3;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  #cart-showcase-{{ section.id }} .cart-showcase__image {
    max-width: 100%;
    max-height: 100%;
    width: auto;
    height: auto;
    display: block;
    object-fit: contain;
    filter: drop-shadow(0 16px 56px rgba(0, 0, 0, 0.65));
  }

  /* ---- ARROWS ---- */
  #cart-showcase-{{ section.id }} .cart-showcase__arrow {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    z-index: 10;
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.1);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1px solid rgba(255, 255, 255, 0.2);
    color: #ffffff;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: background 0.2s ease, transform 0.2s ease;
    padding: 0;
    line-height: 1;
  }

  #cart-showcase-{{ section.id }} .cart-showcase__arrow:hover {
    background: rgba(255, 255, 255, 0.25);
    transform: translateY(-50%) scale(1.1);
  }

  #cart-showcase-{{ section.id }} .cart-showcase__arrow--prev { left: 16px; }
  #cart-showcase-{{ section.id }} .cart-showcase__arrow--next { right: 16px; }

  /* ---- DOTS ---- */
  #cart-showcase-{{ section.id }} .cart-showcase__dots {
    position: absolute;
    bottom: 22px;
    left: 50%;
    transform: translateX(-50%);
    z-index: 10;
    display: flex;
    align-items: center;
    gap: 8px;
  }

  #cart-showcase-{{ section.id }} .cart-showcase__dot {
    width: 8px;
    height: 8px;
    border-radius: 100px;
    background: rgba(255, 255, 255, 0.38);
    border: none;
    cursor: pointer;
    padding: 0;
    transition: width 0.35s ease, background 0.3s ease;
  }

  #cart-showcase-{{ section.id }} .cart-showcase__dot.is-active {
    width: 28px;
    background: #ffffff;
  }

  /* ---- PLACEHOLDER ---- */
  #cart-showcase-{{ section.id }} .cart-showcase__placeholder {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 40px;
    text-align: center;
    color: rgba(255, 255, 255, 0.35);
    font-family: 'Inter', sans-serif;
    font-size: 14px;
  }

  /* ============================================================
     RESPONSIVE
     ============================================================ */

  @media (max-width: 991px) {
    #cart-showcase-{{ section.id }} .cart-showcase__content {
      flex: 0 0 46%;
      padding: 48px 40px;
    }

    #cart-showcase-{{ section.id }} .cart-showcase__heading {
      font-size: clamp(22px, 4vw, 32px);
    }
  }

  @media (max-width: 767px) {
    /* Stack vertically on mobile — image on top, content below */
    #cart-showcase-{{ section.id }} .cart-showcase__inner,
    #cart-showcase-{{ section.id }}.cart-showcase--content-right .cart-showcase__inner {
      flex-direction: column;
      min-height: auto;
    }

    #cart-showcase-{{ section.id }} .cart-showcase__slider {
      flex: none;
      width: 100%;
      height: 320px;
      order: 1;
    }

    #cart-showcase-{{ section.id }} .cart-showcase__content {
      flex: none;
      width: 100%;
      padding: 40px 24px 44px;
      order: 2;
    }

    #cart-showcase-{{ section.id }}.cart-showcase--content-right .cart-showcase__content {
      padding: 40px 24px 44px;
    }

    #cart-showcase-{{ section.id }} .cart-showcase__heading {
      font-size: 26px;
    }

    #cart-showcase-{{ section.id }} .cart-showcase__image-wrap {
      inset: 24px;
    }

    #cart-showcase-{{ section.id }} .cart-showcase__overlay {
      background: linear-gradient(
        to top,
        rgba(26, 54, 93, 0.4) 0%,
        rgba(26, 54, 93, 0.0) 100%
      ) !important;
    }
  }

  @media (max-width: 480px) {
    #cart-showcase-{{ section.id }} .cart-showcase__slider {
      height: 270px;
    }

    #cart-showcase-{{ section.id }} .cart-showcase__content {
      padding: 32px 20px 36px;
    }
  }
</style>

<script>
  (function () {
    var root = document.getElementById('cart-showcase-{{ section.id }}');
    if (!root) return;

    var slider    = root.querySelector('.cart-showcase__slider');
    var slides    = Array.from(root.querySelectorAll('.cart-showcase__slide'));
    var dots      = Array.from(root.querySelectorAll('.cart-showcase__dot'));
    var prevBtn   = root.querySelector('.cart-showcase__arrow--prev');
    var nextBtn   = root.querySelector('.cart-showcase__arrow--next');

    if (slides.length <= 1) return;

    var current  = 0;
    var autoplay = slider.dataset.autoplay === 'true';
    var speed    = parseInt(slider.dataset.speed, 10) || 5000;
    var timer    = null;

    function goTo(index) {
      var total = slides.length;
      index = ((index % total) + total) % total;

      // Deactivate current
      slides[current].classList.remove('is-active');
      if (dots[current]) {
        dots[current].classList.remove('is-active');
        dots[current].setAttribute('aria-selected', 'false');
      }

      current = index;

      // Activate next
      slides[current].classList.add('is-active');
      if (dots[current]) {
        dots[current].classList.add('is-active');
        dots[current].setAttribute('aria-selected', 'true');
      }

      // Reset Ken Burns on the newly active slide's blur layer
      var blurBg = slides[current].querySelector('.cart-showcase__blur-bg');
      if (blurBg) {
        blurBg.style.animation = 'none';
        void blurBg.offsetWidth; // force reflow
        blurBg.style.animation = '';
      }

      if (autoplay) resetTimer();
    }

    function startTimer() {
      timer = setInterval(function () { goTo(current + 1); }, speed);
    }

    function resetTimer() {
      clearInterval(timer);
      startTimer();
    }

    // Arrow buttons
    if (prevBtn) prevBtn.addEventListener('click', function () { goTo(current - 1); });
    if (nextBtn) nextBtn.addEventListener('click', function () { goTo(current + 1); });

    // Dot buttons
    dots.forEach(function (dot) {
      dot.addEventListener('click', function () {
        goTo(parseInt(dot.dataset.slide, 10));
      });
    });

    // Pause autoplay on hover
    slider.addEventListener('mouseenter', function () { clearInterval(timer); });
    slider.addEventListener('mouseleave', function () { if (autoplay) startTimer(); });

    // Touch swipe support
    var touchStartX = 0;
    slider.addEventListener('touchstart', function (e) {
      touchStartX = e.touches[0].clientX;
    }, { passive: true });
    slider.addEventListener('touchend', function (e) {
      var diff = touchStartX - e.changedTouches[0].clientX;
      if (Math.abs(diff) > 40) goTo(diff > 0 ? current + 1 : current - 1);
    }, { passive: true });

    // Keyboard navigation (when slider has focus)
    slider.setAttribute('tabindex', '0');
    slider.addEventListener('keydown', function (e) {
      if (e.key === 'ArrowLeft')  goTo(current - 1);
      if (e.key === 'ArrowRight') goTo(current + 1);
    });

    if (autoplay) startTimer();
  })();
</script>

{% schema %}
{
  "name": "Cart Showcase",
  "tag": "section",
  "class": "cart-showcase-section",
  "max_blocks": 12,
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "badge_text",
      "label": "Badge text",
      "default": "Featured Equipment"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Multi-Use Catering Carts"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Perfect for Live Cooking & Catering Events"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Elegant, stainless-steel multi-use carts built for live cooking stations, catering events, and food showcases. Designed to impress guests and simplify service."
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "Button text",
      "default": "View Full Details"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "Button URL"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "content_position",
      "label": "Content side",
      "options": [
        { "value": "left",  "label": "Left" },
        { "value": "right", "label": "Right" }
      ],
      "default": "left"
    },
    {
      "type": "range",
      "id": "min_height",
      "label": "Minimum height (desktop)",
      "min": 400,
      "max": 800,
      "step": 20,
      "unit": "px",
      "default": 580
    },
    {
      "type": "range",
      "id": "bg_blur",
      "label": "Background image blur",
      "min": 0,
      "max": 60,
      "step": 2,
      "unit": "px",
      "default": 28,
      "info": "Controls blurriness of the right-side ambient background image"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color",
      "default": "#1a365d"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Button / accent color",
      "default": "#ff6b6b"
    },
    {
      "type": "header",
      "content": "Slider"
    },
    {
      "type": "checkbox",
      "id": "autoplay",
      "label": "Autoplay",
      "default": true
    },
    {
      "type": "range",
      "id": "autoplay_speed",
      "label": "Autoplay speed",
      "min": 2500,
      "max": 9500,
      "step": 500,
      "unit": "ms",
      "default": 5000
    }
  ],
  "blocks": [
    {
      "type": "slide",
      "name": "Slide",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "caption",
          "label": "Image alt text",
          "info": "Describe the image for screen readers"
        }
      ]
    },
    {
      "type": "feature",
      "name": "Feature bullet",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Feature text",
          "default": "Stainless steel commercial-grade construction"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Cart Showcase",
      "blocks": [
        {
          "type": "feature",
          "settings": { "text": "Stainless steel commercial-grade construction" }
        },
        {
          "type": "feature",
          "settings": { "text": "Designed for live cooking and catering events" }
        },
        {
          "type": "feature",
          "settings": { "text": "Multiple configurations available" }
        }
      ]
    }
  ]
}
{% endschema %}
