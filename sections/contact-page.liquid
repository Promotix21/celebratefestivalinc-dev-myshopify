                {% if section.blocks.size == 0 %}
                    <div class="service-area-card">
                        <div class="service-area-name">California (Bay Area & Los Angeles)</div>
                    </div>
                    <div class="service-area-card">
                        <div class="service-area-name">Texas (Houston, Dallas, Austin)</div>
                    </div>
                    <div class="service-area-card">
                        <div class="service-area-name">New York & New Jersey</div>
                    </div>
                    <div class="service-area-card">
                        <div class="service-area-name">Florida (Miami, Orlando, Tampa)</div>
                    </div>
                    <div class="service-area-card">
                        <div class="service-area-name">Illinois (Chicago Metro)</div>
                    </div>
                    <div class="service-area-card">
                        <div class="service-area-name">And More Nationwide...</div>
                    </div>
                {% endif %}
            </div>
        </div>
    </section>

    {% comment %} FAQ Section {% endcomment %}
    <section class="faq-section">
        <div class="container">
            <div class="section-header">
                <h2 class="section-title">{{ settings.faq_title | default: "Frequently Asked Questions" }}</h2>
                <p class="section-subtitle">{{ settings.faq_description | default: "Quick answers to common questions about our equipment and services" }}</p>
            </div>
            
            <div class="faq-container">
                {% for block in section.blocks %}
                    {% if block.type == 'faq_item' %}
                        <div class="faq-item" onclick="toggleFaq(this)">
                            <div class="faq-question">
                                <span>{{ block.settings.question }}</span>
                                <div class="faq-toggle">+</div>
                            </div>
                            <div class="faq-answer">
                                {{ block.settings.answer }}
                            </div>
                        </div>
                    {% endif %}
                {% endfor %}
                
                {% comment %} Default FAQ items if no blocks {% endcomment %}
                {% if section.blocks.size == 0 %}
                    <div class="faq-item" onclick="toggleFaq(this)">
                        <div class="faq-question">
                            <span>What are your shipping options and costs?</span>
                            <div class="faq-toggle">+</div>
                        </div>
                        <div class="faq-answer">
                            We offer free standard shipping on orders over $2,500. For smaller orders, shipping costs are calculated at checkout based on weight and destination. Expedited shipping and white-glove delivery services are available for an additional fee.
                        </div>
                    </div>
                    
                    <div class="faq-item" onclick="toggleFaq(this)">
                        <div class="faq-question">
                            <span>Do you offer installation services?</span>
                            <div class="faq-toggle">+</div>
                        </div>
                        <div class="faq-answer">
                            Yes, we provide professional installation services for most equipment through our network of certified technicians nationwide. Contact us for a quote on installation for your specific equipment and location.
                        </div>
                    </div>
                    
                    <div class="faq-item" onclick="toggleFaq(this)">
                        <div class="faq-question">
                            <span>What warranty coverage do you provide?</span>
                            <div class="faq-toggle">+</div>
                        </div>
                        <div class="faq-answer">
                            All equipment comes with manufacturer warranties, typically ranging from 1-3 years depending on the product. We also offer extended warranty options for additional coverage. Check individual product pages for specific warranty details.
                        </div>
                    </div>
                    
                    <div class="faq-item" onclick="toggleFaq(this)">
                        <div class="faq-question">
                            <span>Can you help design my kitchen layout?</span>
                            <div class="faq-toggle">+</div>
                        </div>
                        <div class="faq-answer">
                            Yes, our kitchen design consultants work with restaurants of all sizes. We provide CAD drawings, workflow analysis, and equipment recommendations to maximize efficiency and meet health code requirements.
                        </div>
                    </div>
                {% endif %}
            </div>
        </div>
    </section>
</div>

<script>
// Form Type Switching with Buttons
function openFinancingModal() {
    document.getElementById('financingModal').classList.add('active');
    document.body.style.overflow = 'hidden';
}

function closeFinancingModal() {
    document.getElementById('financingModal').classList.remove('active');
    document.body.style.overflow = '';
}

function closeFinancingModalOutside(event) {
    if (event.target === document.getElementById('financingModal')) {
        closeFinancingModal();
    }
}

// Auto-open financing modal when linked from SPP (#financing hash)
if (window.location.hash === '#financing') {
    window.addEventListener('load', function() { openFinancingModal(); });
}

// Close modal on Escape key
document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape') closeFinancingModal();
});

function switchFormType(formType, clickedBtn) {
    var i, tabcontent, buttons;

    // Hide all form contents
    tabcontent = document.getElementsByClassName("tab-content");
    for (i = 0; i < tabcontent.length; i++) {
        tabcontent[i].style.display = "none";
        tabcontent[i].classList.remove("active");
    }

    // Remove active class from all buttons
    buttons = document.getElementsByClassName("form-type-btn");
    for (i = 0; i < buttons.length; i++) {
        buttons[i].classList.remove("active");
    }

    // Show selected form
    var selectedForm = document.getElementById(formType);
    if (selectedForm) {
        selectedForm.style.display = "block";
        selectedForm.classList.add("active");
    }

    // Add active class to clicked button
    if (clickedBtn) {
        clickedBtn.classList.add("active");
    }
}

// FAQ Toggle
function toggleFaq(element) {
    const isOpen = element.classList.contains('open');
    
    // Close all FAQs
    document.querySelectorAll('.faq-item').forEach(item => {
        item.classList.remove('open');
    });
    
    // Open clicked FAQ if it wasn't already open
    if (!isOpen) {
        element.classList.add('open');
    }
}

document.addEventListener('DOMContentLoaded', function() {
    // Show SweetAlert for form submission results
    if (window.__cfFormSuccess) {
        Swal.fire({
            icon: 'success',
            title: 'Message Sent!',
            html: '<p style="color: #64748b;">Thank you for contacting us.<br>We\'ll respond within <strong>24 hours</strong>.</p>',
            confirmButtonText: 'Got it!',
            confirmButtonColor: '#ff6b6b',
            background: '#fff',
            backdrop: 'rgba(26, 54, 93, 0.4)'
        });
    } else if (window.__cfFormError) {
        Swal.fire({
            icon: 'error',
            title: 'Oops!',
            html: '<p style="color: #64748b;">Something went wrong.<br>Please try again or email us directly.</p>',
            confirmButtonText: 'Try Again',
            confirmButtonColor: '#ff6b6b',
            background: '#fff',
            backdrop: 'rgba(26, 54, 93, 0.4)'
        });
    }

    // IMP-002 FIX: Handle URL parameter for default tab selection
    const urlParams = new URLSearchParams(window.location.search);
    const tabParam = urlParams.get('tab');
    if (tabParam === 'quote') {
        const quoteBtn = document.querySelector('[onclick*="quote"]');
        if (quoteBtn) {
            switchFormType('quote', quoteBtn);
        }
    }

    // IMP-003 FIX: Pre-populate form fields for logged-in users
    {% if customer %}
    const customerName = '{{ customer.name | escape }}';
    const customerEmail = '{{ customer.email | escape }}';
    const customerPhone = '{{ customer.phone | default: "" | escape }}';
    const customerCompany = '{{ customer.metafields.custom.company | default: "" | escape }}';

    // Pre-fill general inquiry form
    const generalName = document.getElementById('general-name');
    const generalEmail = document.getElementById('general-email');
    const generalPhone = document.getElementById('general-phone');
    const generalCompany = document.getElementById('general-company');

    if (generalName && customerName) generalName.value = customerName;
    if (generalEmail && customerEmail) generalEmail.value = customerEmail;
    if (generalPhone && customerPhone) generalPhone.value = customerPhone;
    if (generalCompany && customerCompany) generalCompany.value = customerCompany;

    // Pre-fill quote request form
    const quoteName = document.getElementById('quote-name');
    const quoteEmail = document.getElementById('quote-email');
    const quotePhone = document.getElementById('quote-phone');
    const quoteCompany = document.getElementById('quote-company');

    if (quoteName && customerName) quoteName.value = customerName;
    if (quoteEmail && customerEmail) quoteEmail.value = customerEmail;
    if (quotePhone && customerPhone) quotePhone.value = customerPhone;
    if (quoteCompany && customerCompany) quoteCompany.value = customerCompany;
    {% endif %}

    const forms = document.querySelectorAll('form[action*="contact"]');
    
    forms.forEach(form => {
        form.addEventListener('submit', function(e) {
            e.preventDefault();
            const submitBtn = this.querySelector('.submit-btn');

            // Show loading SweetAlert
            Swal.fire({
                title: 'Sending...',
                html: '<p style="color: #64748b;">Please wait while we send your message.</p>',
                allowOutsideClick: false,
                allowEscapeKey: false,
                showConfirmButton: false,
                background: '#fff',
                backdrop: 'rgba(26, 54, 93, 0.4)',
                didOpen: () => {
                    Swal.showLoading();
                }
            });

            submitBtn.disabled = true;
            form.submit();
        });
    });
    
    // Phone Number Formatting
    document.querySelectorAll('input[type="tel"]').forEach(input => {
        input.addEventListener('input', function(e) {
            let value = e.target.value.replace(/\D/g, '');
            if (value.length >= 6) {
                value = `(${value.slice(0,3)}) ${value.slice(3,6)}-${value.slice(6,10)}`;
            } else if (value.length >= 3) {
                value = `(${value.slice(0,3)}) ${value.slice(3)}`;
            }
            e.target.value = value;
        });
    });

    // File Upload Handling — for all file upload fields
    document.querySelectorAll('.file-input').forEach(function(fileInput) {
        var fileWrapper = fileInput.closest('.file-upload-wrapper');
        var fileSelectedName = fileWrapper ? fileWrapper.querySelector('.file-selected-name') : null;

        if (!fileWrapper || !fileSelectedName) return;

        fileInput.addEventListener('change', function() {
            if (this.files && this.files.length > 0) {
                var fileNames = Array.from(this.files).map(function(f) { return f.name; }).join(', ');
                var totalSize = Array.from(this.files).reduce(function(acc, f) { return acc + f.size; }, 0);
                var sizeMB = (totalSize / (1024 * 1024)).toFixed(2);

                if (totalSize > 10 * 1024 * 1024) {
                    fileSelectedName.style.color = 'var(--popup-error-red)';
                    fileSelectedName.textContent = 'File(s) exceed 10MB limit. Please email larger files.';
                } else {
                    fileSelectedName.style.color = 'var(--popup-success-green)';
                    fileSelectedName.textContent = fileNames + ' (' + sizeMB + ' MB)';
                }
            } else {
                fileSelectedName.textContent = '';
            }
        });

        fileWrapper.addEventListener('dragover', function(e) {
            e.preventDefault();
            this.classList.add('drag-over');
        });

        fileWrapper.addEventListener('dragleave', function(e) {
            e.preventDefault();
            this.classList.remove('drag-over');
        });

        fileWrapper.addEventListener('drop', function(e) {
            this.classList.remove('drag-over');
        });
    });
});
</script>

