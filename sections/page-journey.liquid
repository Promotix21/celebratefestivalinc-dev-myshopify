{%- comment -%} ===== JAVASCRIPT — Scroll reveal + timeline progress ===== {%- endcomment -%}
<script>
  (function() {
    /* Scroll reveal for .sj-reveal elements */
    var revealEls = document.querySelectorAll('.sj-reveal');
    var stepEls = document.querySelectorAll('.sj-step');

    if ('IntersectionObserver' in window) {
      var revealObs = new IntersectionObserver(function(entries) {
        entries.forEach(function(entry) {
          if (entry.isIntersecting) {
            entry.target.classList.add('sj-reveal--visible');
            revealObs.unobserve(entry.target);
          }
        });
      }, { threshold: 0.15 });

      revealEls.forEach(function(el) { revealObs.observe(el); });

      var stepObs = new IntersectionObserver(function(entries) {
        entries.forEach(function(entry) {
          if (entry.isIntersecting) {
            entry.target.classList.add('sj-step--visible');
            stepObs.unobserve(entry.target);
          }
        });
      }, { threshold: 0.2 });

      stepEls.forEach(function(el) { stepObs.observe(el); });
    } else {
      /* Fallback: show everything */
      revealEls.forEach(function(el) { el.classList.add('sj-reveal--visible'); });
      stepEls.forEach(function(el) { el.classList.add('sj-step--visible'); });
    }

    /* Timeline line fill on scroll */
    var track = document.getElementById('sj-timeline-track');
    var fill  = document.getElementById('sj-line-fill');
    if (track && fill) {
      var ticking = false;
      function updateLine() {
        var rect = track.getBoundingClientRect();
        var viewH = window.innerHeight;
        /* How far into the track the viewport center has progressed */
        var scrolled = (viewH * 0.6) - rect.top;
        var pct = Math.min(Math.max(scrolled / rect.height * 100, 0), 100);
        fill.style.height = pct + '%';
        ticking = false;
      }
      window.addEventListener('scroll', function() {
        if (!ticking) {
          requestAnimationFrame(updateLine);
          ticking = true;
        }
      }, { passive: true });
      updateLine();
    }
  })();
</script>

