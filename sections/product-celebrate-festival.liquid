}
.cf-aq-success h4 {
  font-family: 'Montserrat', sans-serif;
  font-size: 16px;
  color: #1a365d;
  margin: 0 0 8px 0;
}
.cf-aq-success p {
  font-size: 13px;
  color: #718096;
  margin: 0;
  line-height: 1.5;
}

@media (max-width: 600px) {
  .cf-aq-dialog { width: 95%; max-width: none; }
  .cf-aq-row { grid-template-columns: 1fr; }
  .cf-aq-header { padding: 18px 20px; }
  .cf-aq-body { padding: 16px 20px 20px; }
}
</style>

<script>
(function() {
  // Handle success state for Ask a Question modal
  if (window.__cfAqSuccess) {
    document.addEventListener('DOMContentLoaded', function() {
      var modal = document.getElementById('cf-ask-question-modal');
      var body = document.getElementById('cf-aq-form-body');
      if (modal && body) {
        body.innerHTML = '<div class="cf-aq-success">' +
          '<div class="cf-aq-success-icon">&#10003;</div>' +
          '<h4>Question Submitted!</h4>' +
          '<p>Thank you! Our team will respond to your email within 24 hours.</p>' +
          '</div>';
        modal.classList.add('active');
      }
    });
  }

  // Close modal on Escape key
  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape') {
      var modal = document.getElementById('cf-ask-question-modal');
      if (modal) modal.classList.remove('active');
    }
  });
})();
</script>

