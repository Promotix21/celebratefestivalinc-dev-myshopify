  flex-shrink: 0;
  padding: 24px;
  border-right: 1px solid var(--border-color);
  background: var(--bg-light);
}

.cf-plp-ajax__filters-title {
  font-family: 'Montserrat', sans-serif;
  font-size: 16px;
  font-weight: 700;
  color: var(--deep-blue);
  margin: 0 0 20px;
  display: flex;
  align-items: center;
  gap: 8px;
}

.cf-plp-ajax__filters-title::before {
