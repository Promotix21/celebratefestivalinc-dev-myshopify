}

.cf-plp-ajax--compact .cf-plp-ajax__results-count {
  font-size: 12px;
}

.cf-plp-ajax--compact .cf-plp-ajax__sort label {
  display: none;
}

.cf-plp-ajax--compact .cf-plp-ajax__sort select {
  font-size: 11px;
  padding: 6px 10px;
}

/* View toggle - icons only in compact mode */
.cf-plp-ajax--compact .cf-plp-ajax__view-btn {
  width: 32px;
  height: 32px;
  padding: 0;
  justify-content: center;
  font-size: 0;
  gap: 0;
}

.cf-plp-ajax--compact .cf-plp-ajax__view-btn svg {
  width: 14px;
  height: 14px;
}

/* Compact pagination */
.cf-plp-ajax--compact .cf-plp-ajax__pagination {
  padding: 16px;
  gap: 6px;
}

.cf-plp-ajax--compact .cf-plp-ajax__page-btn {
  font-size: 12px;
}

/* Compact login/call prompts */
.cf-plp-ajax--compact .cf-plp__login-prompt {
  font-size: 9px;
  padding: 4px 8px;
  margin-top: 6px;
}

.cf-plp-ajax--compact .cf-plp__call-prompt {
  font-size: 9px;
  padding: 4px 8px;
  margin-top: 6px;
}

/* Compact responsive */
@media (max-width: 1200px) {
  .cf-plp-ajax--compact .cf-plp-ajax__grid {
    grid-template-columns: repeat(4, minmax(0, 1fr));
  }
  .cf-plp-ajax--compact .cf-plp-ajax__grid.list-view {
    grid-template-columns: minmax(0, 1fr);
  }
}

@media (max-width: 992px) {
  .cf-plp-ajax--compact .cf-plp-ajax__grid {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }
  .cf-plp-ajax--compact .cf-plp-ajax__grid.list-view {
    grid-template-columns: minmax(0, 1fr);
  }
  .cf-plp-ajax--compact .cf-plp-ajax__sidebar {
    display: none;
  }
  .cf-plp-ajax--compact .cf-plp-ajax__mobile-filter-btn {
    display: inline-flex;
  }
}

@media (max-width: 768px) {
  .cf-plp-ajax--compact .cf-plp-ajax__grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 10px;
  }
  .cf-plp-ajax--compact .cf-plp-ajax__grid.list-view {
    grid-template-columns: minmax(0, 1fr);
  }
  .cf-plp-ajax--compact .cf-plp-ajax__grid.list-view .cf-plp__card {
    flex-direction: column;
  }
  .cf-plp-ajax--compact .cf-plp-ajax__grid.list-view .cf-plp__card-image-wrap {
    width: 100%;
    min-width: unset;
  }
  .cf-plp-ajax--compact .cf-plp__card {
    padding: 10px;
  }
  .cf-plp-ajax--compact .cf-plp__card-image-wrap {
    height: 100px;
  }
}

/* Main Container */
.cf-plp-ajax__container {
  display: flex;
  background: var(--bg-white);
  min-height: 800px;
}

/* Filters Sidebar */
.cf-plp-ajax__sidebar {
