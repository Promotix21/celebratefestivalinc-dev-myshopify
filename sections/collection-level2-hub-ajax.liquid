<script>
document.addEventListener('DOMContentLoaded', function() {
  // ========================================
  // AJAX FILTER SYSTEM - 100% Accurate Filters
  // ========================================

  // L3 Collection handles and titles passed from Liquid
  const l3CollectionHandles = {{ l3_collection_handles | split: '|||' | json }};
  const l3CollectionTitles = {};
  {% for handle in l3_handle_array %}
    {% assign h = handle | strip %}
    {% if h != blank %}
      {% assign c = collections[h] %}
      l3CollectionTitles["{{ h }}"] = "{{ c.title | remove: 'New Theme - ' | remove: 'New Theme- ' | escape }}";
    {% endif %}
  {% endfor %}

  console.log('CF-PLP-AJAX: Starting AJAX filter build for', l3CollectionHandles.length, 'collections');

  // Filter state
  const filterState = {
    category: 'all',
    brands: [],
    productTypes: [],
    priceRanges: []
  };

  // Product data cache
  let productData = [];

  // Pagination state
  const paginationState = {
    currentPage: 1,
    itemsPerPage: {{ section.settings.products_per_page | default: 48 }},
    totalPages: 1,
    filteredCards: []
  };

  // DOM elements
  const brandFilterLoading = document.getElementById('brand-filter-loading');
  const brandFilterOptions = document.getElementById('brand-filter-options');
  const brandFilterProgress = document.getElementById('brand-filter-progress');
  const typeFilterLoading = document.getElementById('type-filter-loading');
  const typeFilterOptions = document.getElementById('type-filter-options');
  const resultsCount = document.getElementById('filtered-count-ajax');
  const activeFiltersContainer = document.getElementById('active-filters-ajax');
  const activeFiltersList = document.getElementById('active-filters-list-ajax');
  const clearAllBtn = document.getElementById('clear-all-filters-ajax');
  const paginationContainer = document.getElementById('pagination-ajax');
  const prevBtn = document.getElementById('prev-btn-ajax');
  const nextBtn = document.getElementById('next-btn-ajax');
  const pageNumbersContainer = document.getElementById('page-numbers-ajax');

  // ========================================
  // AJAX PRODUCT FETCHING
  // ========================================

  async function fetchAllProducts() {
    const allBrands = new Map();
    const allTypes = new Map();
    const allProducts = []; // Full product data for backfill
    let totalFetched = 0;
    let collectionsProcessed = 0;
    const seenProductIds = new Set();

    for (const handle of l3CollectionHandles) {
      if (!handle || !handle.trim()) continue;
      const cleanHandle = handle.trim();

      collectionsProcessed++;
      if (brandFilterProgress) {
        brandFilterProgress.textContent = `Processing ${collectionsProcessed}/${l3CollectionHandles.length} categories...`;
      }

      try {
        let page = 1;
        let hasMore = true;

        while (hasMore) {
          const url = `/collections/${cleanHandle}/products.json?limit=250&page=${page}`;
          const response = await fetch(url);

          if (!response.ok) {
            console.warn('CF-PLP-AJAX: Failed to fetch', url);
            break;
          }

          const data = await response.json();
          const products = data.products || [];

          if (products.length === 0) {
            hasMore = false;
            break;
          }

          for (const product of products) {
            // Skip $0 products (matches Liquid: if product.price == 0 continue)
            const firstVariant = product.variants && product.variants[0];
            const productPrice = firstVariant ? parseFloat(firstVariant.price) : 0;
            if (productPrice === 0) continue;

            // Deduplicate across L3 collections
            if (seenProductIds.has(product.id)) continue;
            seenProductIds.add(product.id);

            totalFetched++;

            // Brand
            if (product.vendor) {
              const brandHandle = product.vendor.toLowerCase().replace(/[^a-z0-9]+/g, '-');
              if (allBrands.has(brandHandle)) {
                allBrands.get(brandHandle).count++;
              } else {
                allBrands.set(brandHandle, { name: product.vendor, count: 1 });
              }
            }

            // Product Type
            if (product.product_type) {
              const typeHandle = product.product_type.toLowerCase().replace(/[^a-z0-9]+/g, '-');
              if (allTypes.has(typeHandle)) {
                allTypes.get(typeHandle).count++;
              } else {
                allTypes.set(typeHandle, { name: product.product_type, count: 1 });
              }
            }

            // Store full product data with its L3 category handle
            allProducts.push({ product, categoryHandle: cleanHandle });
          }

          if (products.length < 250) {
            hasMore = false;
          } else {
            page++;
            await new Promise(resolve => setTimeout(resolve, 100));
          }
        }
      } catch (error) {
        console.error('CF-PLP-AJAX: Error fetching', handle, error);
      }
    }

    console.log('CF-PLP-AJAX: Fetched', totalFetched, 'products,', allBrands.size, 'brands,', allTypes.size, 'types');

    return { brands: allBrands, types: allTypes, totalProducts: totalFetched, allProducts };
  }

  // ========================================
  // DYNAMIC CARD CREATION (for AJAX backfill)
  // ========================================

  function createProductCard(product, categoryHandle) {
    const firstVariant = product.variants && product.variants[0];
    if (!firstVariant) return null;

    // products.json returns prices in dollars (e.g. "29676.80")
    // Liquid {{ product.price }} returns cents (e.g. 2967680)
    // We store cents in data-price to match server-rendered cards
    const priceInCents = Math.round(parseFloat(firstVariant.price) * 100);
    const compareAtPrice = firstVariant.compare_at_price ? parseFloat(firstVariant.compare_at_price) : 0;
    const compareAtCents = Math.round(compareAtPrice * 100);
    const vendorHandle = (product.vendor || '').toLowerCase().replace(/[^a-z0-9]+/g, '-');
    const typeHandle = (product.product_type || '').toLowerCase().replace(/[^a-z0-9]+/g, '-');
    const categoryTitle = l3CollectionTitles[categoryHandle] || categoryHandle;
    const productUrl = `/products/${product.handle}?variant=${firstVariant.id}`;

    // Format price as money
    const formatMoney = (cents) => {
      const dollars = (cents / 100).toFixed(2);
      return '$' + dollars.replace(/\B(?=(\d{3})+(?!\d))/g, ',');
    };

    // Image
    const featuredImage = product.images && product.images[0];
    const imgHtml = featuredImage
      ? `<img src="${featuredImage.src.replace(/\.([a-z]+)\?/, '_320x.$1?')}" alt="${product.title}" class="cf-plp__card-image" loading="lazy">`
      : `<div class="cf-plp__card-image" style="display:flex;align-items:center;justify-content:center;font-size:40px;color:#94a3b8;">📦</div>`;

    // Variants badge
    const variantCount = product.variants ? product.variants.length : 1;
    let variantsBadgeHtml = '';
    if (variantCount > 1) {
      let variationList = '';
      if (product.options) {
        variationList = product.options.map(opt => `${opt.name}: ${opt.values.join(', ')}`).join(' | ');
      }
      if (variationList.length > 150) variationList = variationList.substring(0, 147) + '...';
      variantsBadgeHtml = `
        <span class="cf-plp__variants-badge" data-variants="${variantCount}">
          <span class="cf-plp__variants-text">${variantCount} Variations</span>
          <span class="cf-plp__variants-tooltip">${variationList}</span>
        </span>`;
    }

    // Badge
    let badgeHtml = '';
    const tags = product.tags || [];
    if (tags.includes('best-seller') || tags.includes('featured')) {
      badgeHtml = '<span class="badge best-seller-badge">Best Seller</span>';
    } else if (compareAtCents > priceInCents) {
      badgeHtml = '<span class="badge sale-badge">Sale</span>';
    }

    // SKU
    const skuHtml = firstVariant.sku
      ? `<div class="card-sku product-sku cf-plp__card-sku">#${firstVariant.sku}</div>`
      : '';

    // Price range detection
    let priceVaries = false;
    if (product.variants && product.variants.length > 1) {
      const prices = product.variants.map(v => parseFloat(v.price));
      const minPrice = Math.min(...prices);
      const maxPrice = Math.max(...prices);
      if (minPrice !== maxPrice) priceVaries = true;
    }

    // Price HTML — server-side WSH not available, show base price
    // cf-wholesale-pricing.js will upgrade to member pricing via BDR API client-side
    let priceHtml = '';
    if (priceVaries) {
      const prices = product.variants.map(v => Math.round(parseFloat(v.price) * 100));
      const minP = Math.min(...prices);
      const maxP = Math.max(...prices);
      priceHtml = `
        <div class="price-label-single price-label cf-plp__price-label">Price</div>
        <div class="price-amount-single current-price cf-plp__price-main">${formatMoney(minP)} – ${formatMoney(maxP)}</div>`;
    } else if (compareAtCents > priceInCents) {
      const savings = compareAtCents - priceInCents;
      priceHtml = `
        <div class="compare-price-strike cf-plp__price-original"><s>${formatMoney(compareAtCents)}</s></div>
        <div class="price-label-single price-label cf-plp__price-label">Sale Price</div>
        <div class="price-amount-single current-price cf-plp__price-main">${formatMoney(priceInCents)}<span class="price-unit cf-plp__price-unit">/Each</span></div>
        <div class="sale-savings-tag cf-plp__sale-savings">Save ${formatMoney(savings)}</div>`;
    } else {
      priceHtml = `
        <div class="price-label-single price-label cf-plp__price-label">Price</div>
        <div class="price-amount-single current-price cf-plp__price-main">${formatMoney(priceInCents)}<span class="price-unit cf-plp__price-unit">/Each</span></div>`;
    }

    // Shipping
    // Metafields not available via products.json — skip shipment badge for backfilled cards

    const card = document.createElement('div');
    card.className = 'product-card cf-plp__card';
    card.dataset.productId = product.id;
    card.dataset.category = categoryHandle;
    card.dataset.vendor = vendorHandle;
    card.dataset.vendorRaw = product.vendor || '';
    card.dataset.type = typeHandle;
    card.dataset.typeRaw = product.product_type || '';
    card.dataset.price = priceInCents;
    card.dataset.available = 'true';
    card.dataset.title = product.title || '';
    // BDR API attributes for cf-wholesale-pricing.js
    card.dataset.cfProductId = product.id;
    card.dataset.cfVariantId = firstVariant.id;
    card.dataset.cfPrice = priceInCents;
    card.dataset.cfCompareAtPrice = compareAtCents || '';
    card.dataset.cfHandle = product.handle;
    card.dataset.cfCollectionIds = '';

    card.innerHTML = `
      <a href="${productUrl}" class="product-link">
        <div class="card-image product-image cf-plp__card-image-wrap">
          ${imgHtml}
          <div class="badge-container product-badges cf-plp__card-badge">
            ${badgeHtml}
          </div>
          ${variantsBadgeHtml}
        </div>
      </a>
      <div class="card-content product-info cf-plp__card-content">
        <span class="card-category product-brand cf-plp__card-category">${categoryTitle.length > 25 ? categoryTitle.substring(0, 22) + '...' : categoryTitle}</span>
        <a href="${productUrl}" class="product-title-link">
          <h3 class="card-title product-title cf-plp__card-title">${product.title}</h3>
        </a>
        ${skuHtml}
        <div class="price-single price-box cf-plp__price-box">
          ${priceHtml}
        </div>
        <div class="card-actions product-actions cf-plp__cart-row">
          <input type="number" class="qty-input cf-plp__qty-input" value="1" min="1" aria-label="Quantity" data-product-id="${product.id}">
          <button type="button" class="add-to-cart add-to-cart-btn quick-add-btn cf-plp__add-btn" data-product-id="${product.id}" data-variant-id="${firstVariant.id}">Add to Cart</button>
        </div>
      </div>`;

    return card;
  }

  /**
   * Backfill: inject DOM cards for products fetched via AJAX
   * that were not rendered by Liquid (beyond limit: 100 per L3).
   * Also deduplicates Liquid-rendered cards (same product in multiple L3 collections).
   */
  function backfillProducts(allProducts) {
    const grid = document.getElementById('product-grid-ajax');
    if (!grid) return 0;

    // Deduplicate existing Liquid-rendered cards
    // (a product can appear in multiple L3 collections)
    const existingIds = new Set();
    let removedDupes = 0;
    document.querySelectorAll('.cf-plp__card[data-product-id]').forEach(card => {
      const pid = String(card.dataset.productId);
      if (existingIds.has(pid)) {
        card.remove();
        removedDupes++;
      } else {
        existingIds.add(pid);
      }
    });
    if (removedDupes > 0) {
      console.log('CF-PLP-AJAX: Removed', removedDupes, 'duplicate Liquid cards');
    }

    let backfilled = 0;

    for (const { product, categoryHandle } of allProducts) {
      if (existingIds.has(String(product.id))) continue;

      const card = createProductCard(product, categoryHandle);
      if (!card) continue;

      grid.appendChild(card);
      backfilled++;

      // Attach add-to-cart listener to new card
      const addBtn = card.querySelector('.cf-plp__add-btn');
      if (addBtn) {
        addBtn.addEventListener('click', function(e) {
          e.preventDefault();
          const variantId = this.dataset.variantId;
          const parentCard = this.closest('.cf-plp__card');
          const qty = parentCard ? parseInt(parentCard.querySelector('.cf-plp__qty-input').value) || 1 : 1;
          const button = this;

          button.disabled = true;
          button.textContent = 'Adding...';

          fetch('/cart/add.js', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ id: parseInt(variantId), quantity: qty })
          })
          .then(res => {
            if (!res.ok) throw new Error('Add to cart failed');
            return res.json();
          })
          .then(data => {
            button.textContent = 'Added!';
            button.style.background = 'linear-gradient(135deg, #10b981 0%, #059669 100%)';
            if (window.updateCartCount) window.updateCartCount();
            else {
              fetch('/cart.js').then(r => r.json()).then(cart => {
                document.querySelectorAll('.cart-count-bubble span, .cart-count, [data-cart-count]').forEach(el => el.textContent = cart.item_count);
              });
            }
            if (typeof window.cfShowCartToast === 'function') window.cfShowCartToast(data, qty);
            setTimeout(() => { button.textContent = 'Add to Cart'; button.style.background = ''; button.disabled = false; }, 2000);
          })
          .catch(err => {
            console.error('Cart error:', err);
            button.textContent = 'Error';
            button.style.background = '#ef4444';
            setTimeout(() => { button.textContent = 'Add to Cart'; button.style.background = ''; button.disabled = false; }, 2000);
          });
        });
      }
    }

    return backfilled;
  }

  // ========================================
  // BUILD FILTER UI FROM AJAX DATA
  // ========================================

  function buildBrandFilters(brands) {
    if (!brandFilterOptions) return;

    // Sort brands alphabetically by name
    const sortedBrands = Array.from(brands.entries()).sort((a, b) => {
      return a[1].name.localeCompare(b[1].name);
    });

    brandFilterOptions.innerHTML = '';

    for (const [handle, data] of sortedBrands) {
      const li = document.createElement('li');
      li.innerHTML = `
        <label class="cf-plp-ajax__filter-option">
          <input type="checkbox" name="brand-ajax" value="${handle}">
          ${data.name}
          <span class="cf-plp-ajax__filter-count">(${data.count})</span>
        </label>
      `;
      brandFilterOptions.appendChild(li);
    }

    // Hide loading, show options
    if (brandFilterLoading) brandFilterLoading.style.display = 'none';
    brandFilterOptions.style.display = 'block';

    // Attach event listeners
    brandFilterOptions.querySelectorAll('input[name="brand-ajax"]').forEach(cb => {
      cb.addEventListener('change', function() {
        if (this.checked) {
          filterState.brands.push(this.value);
        } else {
          filterState.brands = filterState.brands.filter(b => b !== this.value);
        }
        applyFilters();
      });
    });
  }

  function buildTypeFilters(types) {
    if (!typeFilterOptions) return;

    // Sort product types alphabetically by name
    const sortedTypes = Array.from(types.entries()).sort((a, b) => {
      return a[1].name.localeCompare(b[1].name);
    });

    typeFilterOptions.innerHTML = '';

    for (const [handle, data] of sortedTypes) {
      const li = document.createElement('li');
      li.innerHTML = `
        <label class="cf-plp-ajax__filter-option">
          <input type="checkbox" name="type-ajax" value="${handle}">
          ${data.name}
          <span class="cf-plp-ajax__filter-count">(${data.count})</span>
        </label>
      `;
      typeFilterOptions.appendChild(li);
    }

    // Hide loading, show options
    if (typeFilterLoading) typeFilterLoading.style.display = 'none';
    typeFilterOptions.style.display = 'block';

    // Attach event listeners
    typeFilterOptions.querySelectorAll('input[name="type-ajax"]').forEach(cb => {
      cb.addEventListener('change', function() {
        if (this.checked) {
          filterState.productTypes.push(this.value);
        } else {
          filterState.productTypes = filterState.productTypes.filter(t => t !== this.value);
        }
        applyFilters();
      });
    });
  }

  // ========================================
  // INITIALIZE PRODUCT DATA FROM DOM
  // ========================================

  function initProductData() {
    const cards = document.querySelectorAll('.cf-plp__card');
    productData = [];

    cards.forEach((card, idx) => {
      productData.push({
        element: card,
        category: card.dataset.category || '',
        vendor: card.dataset.vendor || '',
        vendorRaw: card.dataset.vendorRaw || '',
        productType: card.dataset.type || '',
        typeRaw: card.dataset.typeRaw || '',
        price: parseFloat(card.dataset.price) || 0,
        title: (card.dataset.title || '').toLowerCase(),
        originalIndex: idx
      });
    });

    paginationState.filteredCards = Array.from(cards);
  }

  // ========================================
  // FILTER APPLICATION
  // ========================================

  function applyFilters(resetPage = true) {
    paginationState.filteredCards = [];

    const hasCategory = filterState.category !== 'all';
    const hasBrands = filterState.brands.length > 0;
    const hasProductTypes = filterState.productTypes.length > 0;
    const hasPrices = filterState.priceRanges.length > 0;

    for (let i = 0; i < productData.length; i++) {
      const p = productData[i];
      let visible = true;

      // Category
      if (hasCategory && p.category !== filterState.category) visible = false;

      // Brand
      if (visible && hasBrands && !filterState.brands.includes(p.vendor)) visible = false;

      // Product Type
      if (visible && hasProductTypes && !filterState.productTypes.includes(p.productType)) visible = false;

      // Price
      if (visible && hasPrices) {
        let priceMatch = false;
        for (const range of filterState.priceRanges) {
          if (range === '0-500' && p.price < 50000) { priceMatch = true; break; }
          if (range === '500-1000' && p.price >= 50000 && p.price < 100000) { priceMatch = true; break; }
          if (range === '1000-2500' && p.price >= 100000 && p.price < 250000) { priceMatch = true; break; }
          if (range === '2500+' && p.price >= 250000) { priceMatch = true; break; }
        }
        if (!priceMatch) visible = false;
      }

      if (visible) {
        paginationState.filteredCards.push(p.element);
      } else {
        p.element.style.display = 'none';
      }
    }

    if (resetPage) {
      paginationState.currentPage = 1;
    }

    updateActiveFiltersDisplay();
    applyPagination();
  }

  // ========================================
  // ACTIVE FILTERS DISPLAY
  // ========================================

  function updateActiveFiltersDisplay() {
    if (!activeFiltersContainer) return;

    const activeChips = [];

    if (filterState.category !== 'all') {
      const categoryPill = document.querySelector(`.cf-plp-ajax__pill[data-filter="${filterState.category}"]`);
      const categoryName = categoryPill ? categoryPill.textContent.trim() : filterState.category;
      activeChips.push({
        type: 'category',
        label: `Category: ${categoryName}`,
        value: filterState.category
      });
    }

    filterState.brands.forEach(brand => {
      const brandCheckbox = document.querySelector(`input[name="brand-ajax"][value="${brand}"]`);
      const brandLabel = brandCheckbox ? brandCheckbox.parentElement.textContent.trim().replace(/\(\d+\)/, '').trim() : brand;
      activeChips.push({
        type: 'brand',
        label: `Brand: ${brandLabel}`,
        value: brand
      });
    });

    filterState.productTypes.forEach(type => {
      const typeCheckbox = document.querySelector(`input[name="type-ajax"][value="${type}"]`);
      const typeLabel = typeCheckbox ? typeCheckbox.parentElement.textContent.trim().replace(/\(\d+\)/, '').trim() : type;
      activeChips.push({
        type: 'productType',
        label: `Type: ${typeLabel}`,
        value: type
      });
    });

    filterState.priceRanges.forEach(range => {
      let rangeLabel = '';
      if (range === '0-500') rangeLabel = 'Under $500';
      else if (range === '500-1000') rangeLabel = '$500 - $1,000';
      else if (range === '1000-2500') rangeLabel = '$1,000 - $2,500';
      else if (range === '2500+') rangeLabel = '$2,500+';

      activeChips.push({
        type: 'price',
        label: `Price: ${rangeLabel}`,
        value: range
      });
    });

    if (activeChips.length > 0) {
      activeFiltersContainer.style.display = 'flex';
      if (activeFiltersList) {
        activeFiltersList.innerHTML = activeChips.map(chip => `
          <div class="cf-plp-ajax__filter-chip" data-type="${chip.type}" data-value="${chip.value}">
            <span>${chip.label}</span>
            <span class="cf-plp-ajax__filter-chip-remove" onclick="removeFilterAjax('${chip.type}', '${chip.value}')">×</span>
          </div>
        `).join('');
      }
    } else {
      activeFiltersContainer.style.display = 'none';
    }
  }

  // Global remove filter function
  window.removeFilterAjax = function(type, value) {
    if (type === 'category') {
      filterState.category = 'all';
      document.querySelectorAll('.cf-plp-ajax__pill').forEach(p => p.classList.remove('active'));
      const allPill = document.querySelector('.cf-plp-ajax__pill[data-filter="all"]');
      if (allPill) allPill.classList.add('active');
    } else if (type === 'brand') {
      filterState.brands = filterState.brands.filter(b => b !== value);
      const checkbox = document.querySelector(`input[name="brand-ajax"][value="${value}"]`);
      if (checkbox) checkbox.checked = false;
    } else if (type === 'productType') {
      filterState.productTypes = filterState.productTypes.filter(t => t !== value);
      const checkbox = document.querySelector(`input[name="type-ajax"][value="${value}"]`);
      if (checkbox) checkbox.checked = false;
    } else if (type === 'price') {
      filterState.priceRanges = filterState.priceRanges.filter(p => p !== value);
      const checkbox = document.querySelector(`input[name="price-ajax"][value="${value}"]`);
      if (checkbox) checkbox.checked = false;
    }

    applyFilters();
  };

  // ========================================
  // PAGINATION
  // ========================================

  function applyPagination() {
    const { filteredCards, currentPage, itemsPerPage } = paginationState;
    const totalItems = filteredCards.length;
    paginationState.totalPages = Math.ceil(totalItems / itemsPerPage);

    if (resultsCount) resultsCount.textContent = totalItems;

    const startIndex = (currentPage - 1) * itemsPerPage;
    const endIndex = startIndex + itemsPerPage;

    requestAnimationFrame(() => {
      for (let i = 0; i < filteredCards.length; i++) {
        if (i >= startIndex && i < endIndex) {
          filteredCards[i].style.display = '';
        } else {
          filteredCards[i].style.display = 'none';
        }
      }
    });

    renderPagination();
  }

  function renderPagination() {
    if (!paginationContainer) return;
    const { currentPage, totalPages } = paginationState;

    if (totalPages <= 1) {
      paginationContainer.style.display = 'none';
      return;
    }
    paginationContainer.style.display = 'flex';

    if (prevBtn) prevBtn.disabled = currentPage === 1;
    if (nextBtn) nextBtn.disabled = currentPage === totalPages;

    if (pageNumbersContainer) {
      pageNumbersContainer.innerHTML = '';
      const maxVisible = 5;
      let startPage = Math.max(1, currentPage - Math.floor(maxVisible / 2));
      let endPage = Math.min(totalPages, startPage + maxVisible - 1);

      if (endPage - startPage < maxVisible - 1) {
        startPage = Math.max(1, endPage - maxVisible + 1);
      }

      if (startPage > 1) {
        pageNumbersContainer.appendChild(createPageButton(1));
        if (startPage > 2) {
          const ellipsis = document.createElement('span');
          ellipsis.className = 'cf-plp-ajax__page-ellipsis';
          ellipsis.textContent = '...';
          pageNumbersContainer.appendChild(ellipsis);
        }
      }

      for (let i = startPage; i <= endPage; i++) {
        pageNumbersContainer.appendChild(createPageButton(i));
      }

      if (endPage < totalPages) {
        if (endPage < totalPages - 1) {
          const ellipsis = document.createElement('span');
          ellipsis.className = 'cf-plp-ajax__page-ellipsis';
          ellipsis.textContent = '...';
          pageNumbersContainer.appendChild(ellipsis);
        }
        pageNumbersContainer.appendChild(createPageButton(totalPages));
      }
    }
  }

  function createPageButton(pageNum) {
    const btn = document.createElement('button');
    btn.type = 'button';
    btn.className = 'cf-plp-ajax__page-num' + (pageNum === paginationState.currentPage ? ' active' : '');
    btn.textContent = pageNum;
    btn.addEventListener('click', () => goToPage(pageNum));
    return btn;
  }

  function goToPage(pageNum) {
    paginationState.currentPage = pageNum;
    applyPagination();
    const productsContainer = document.querySelector('.cf-plp-ajax__products');
    if (productsContainer) {
      productsContainer.scrollIntoView({ behavior: 'smooth', block: 'start' });
    }
  }

  if (prevBtn) {
    prevBtn.addEventListener('click', () => {
      if (paginationState.currentPage > 1) goToPage(paginationState.currentPage - 1);
    });
  }

  if (nextBtn) {
    nextBtn.addEventListener('click', () => {
      if (paginationState.currentPage < paginationState.totalPages) goToPage(paginationState.currentPage + 1);
    });
  }

  // ========================================
  // MOBILE FILTER DRAWER (AJAX)
  // ========================================

  const mobileFilterBtnAjax = document.getElementById('mobile-filter-btn-ajax');
  const mobileFilterDrawerAjax = document.getElementById('mobile-filter-drawer-ajax');
  const mobileFilterContentAjax = document.getElementById('mobile-filter-content-ajax');
  const mobileFilterCloseAjax = document.getElementById('mobile-filter-close-ajax');
  const mobileFilterOverlayAjax = document.getElementById('mobile-filter-overlay-ajax');
  const mobileFilterApplyAjax = document.getElementById('mobile-filter-apply-ajax');

  function openAjaxMobileFilters() {
    // Move drawer to <body> so position:fixed is never trapped by a CSS transform ancestor
    if (mobileFilterDrawerAjax && mobileFilterDrawerAjax.parentElement !== document.body) {
      document.body.appendChild(mobileFilterDrawerAjax);
    }

    // Clone current sidebar filter content into mobile panel
    const sidebar = document.querySelector('.cf-plp-ajax__sidebar');
    if (mobileFilterContentAjax && sidebar) {
      mobileFilterContentAjax.innerHTML = sidebar.innerHTML;

      // Sync checked state from filterState into cloned checkboxes
      mobileFilterContentAjax.querySelectorAll('input[name="brand-ajax"]').forEach(cb => {
        cb.checked = filterState.brands.includes(cb.value);
      });
      mobileFilterContentAjax.querySelectorAll('input[name="type-ajax"]').forEach(cb => {
        cb.checked = filterState.productTypes.includes(cb.value);
      });
      mobileFilterContentAjax.querySelectorAll('input[name="price-ajax"]').forEach(cb => {
        cb.checked = filterState.priceRanges.includes(cb.value);
      });

      // Wire up change listeners on cloned checkboxes so checking immediately applies + closes
      mobileFilterContentAjax.querySelectorAll('input[type="checkbox"]').forEach(cb => {
        cb.addEventListener('change', function() {
          applyAjaxMobileFilters();
        });
      });
    }

    if (mobileFilterDrawerAjax) {
      mobileFilterDrawerAjax.classList.add('active');
      document.body.style.overflow = 'hidden';
    }
  }

  function closeAjaxMobileFilters() {
    if (mobileFilterDrawerAjax) {
      mobileFilterDrawerAjax.classList.remove('active');
      document.body.style.overflow = '';
    }
  }

  function applyAjaxMobileFilters() {
    if (!mobileFilterContentAjax) return;

    // Read checked state from mobile drawer and update filterState
    filterState.brands = [];
    mobileFilterContentAjax.querySelectorAll('input[name="brand-ajax"]:checked').forEach(cb => {
      filterState.brands.push(cb.value);
    });

    filterState.productTypes = [];
    mobileFilterContentAjax.querySelectorAll('input[name="type-ajax"]:checked').forEach(cb => {
      filterState.productTypes.push(cb.value);
    });

    filterState.priceRanges = [];
    mobileFilterContentAjax.querySelectorAll('input[name="price-ajax"]:checked').forEach(cb => {
      filterState.priceRanges.push(cb.value);
    });

    closeAjaxMobileFilters();
    applyFilters();
  }

  if (mobileFilterBtnAjax) mobileFilterBtnAjax.addEventListener('click', openAjaxMobileFilters);
  if (mobileFilterCloseAjax) mobileFilterCloseAjax.addEventListener('click', closeAjaxMobileFilters);
  if (mobileFilterOverlayAjax) mobileFilterOverlayAjax.addEventListener('click', closeAjaxMobileFilters);
  if (mobileFilterApplyAjax) mobileFilterApplyAjax.addEventListener('click', applyAjaxMobileFilters);

  // ========================================
  // EVENT LISTENERS
  // ========================================

  // Clear all filters
  if (clearAllBtn) {
    clearAllBtn.addEventListener('click', function() {
      filterState.category = 'all';
      filterState.brands = [];
      filterState.productTypes = [];
      filterState.priceRanges = [];

      document.querySelectorAll('.cf-plp-ajax__pill').forEach(p => p.classList.remove('active'));
      const allPill = document.querySelector('.cf-plp-ajax__pill[data-filter="all"]');
      if (allPill) allPill.classList.add('active');

      document.querySelectorAll('.cf-plp-ajax__sidebar input[type="checkbox"]').forEach(cb => cb.checked = false);

      applyFilters();
    });
  }

  // Category pills (skip link pills - they navigate to another page)
  document.querySelectorAll('.cf-plp-ajax__pill:not(.cf-plp-ajax__pill--link)').forEach(pill => {
    pill.addEventListener('click', function() {
      document.querySelectorAll('.cf-plp-ajax__pill').forEach(p => p.classList.remove('active'));
      this.classList.add('active');
      filterState.category = this.dataset.filter;
      applyFilters();
    });
  });

  // Price range checkboxes
  document.querySelectorAll('input[name="price-ajax"]').forEach(cb => {
    cb.addEventListener('change', function() {
      if (this.checked) {
        filterState.priceRanges.push(this.value);
      } else {
        filterState.priceRanges = filterState.priceRanges.filter(p => p !== this.value);
      }
      applyFilters();
    });
  });

  // View toggle
  const productGrid = document.getElementById('product-grid-ajax');
  document.querySelectorAll('.cf-plp-ajax__view-btn').forEach(btn => {
    btn.addEventListener('click', function() {
      document.querySelectorAll('.cf-plp-ajax__view-btn').forEach(b => b.classList.remove('active'));
      this.classList.add('active');

      const viewType = this.dataset.view;
      if (viewType === 'list' && productGrid) {
        productGrid.classList.add('list-view');
      } else if (productGrid) {
        productGrid.classList.remove('list-view');
      }
    });
  });

  // Add to Cart
  document.querySelectorAll('.cf-plp__add-btn').forEach(btn => {
    btn.addEventListener('click', function(e) {
      e.preventDefault();
      const variantId = this.dataset.variantId;
      const card = this.closest('.cf-plp__card');
      const qty = card ? parseInt(card.querySelector('.cf-plp__qty-input').value) || 1 : 1;
      const button = this;

      button.disabled = true;
      button.textContent = 'Adding...';

      fetch('/cart/add.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ id: parseInt(variantId), quantity: qty })
      })
      .then(res => {
        if (!res.ok) throw new Error('Add to cart failed');
        return res.json();
      })
      .then(data => {
        button.textContent = 'Added!';
        button.style.background = 'linear-gradient(135deg, #10b981 0%, #059669 100%)';

        if (window.updateCartCount) window.updateCartCount();
        else {
          fetch('/cart.js').then(r => r.json()).then(cart => {
            const countEls = document.querySelectorAll('.cart-count-bubble span, .cart-count, [data-cart-count]');
            countEls.forEach(el => el.textContent = cart.item_count);
          });
        }

        if (typeof window.cfShowCartToast === 'function') {
          window.cfShowCartToast(data, qty);
        }

        setTimeout(() => {
          button.textContent = 'Add to Cart';
          button.style.background = '';
          button.disabled = false;
        }, 2000);
      })
      .catch(err => {
        console.error('Cart error:', err);
        button.textContent = 'Error';
        button.style.background = '#ef4444';
        setTimeout(() => {
          button.textContent = 'Add to Cart';
          button.style.background = '';
          button.disabled = false;
        }, 2000);
      });
    });
  });

  // Sort handler — client-side sort (products are rendered from DOM, not server)
  window.handleSortAjax = function(value) {
    const grid = document.getElementById('product-grid-ajax');
    if (!grid) return;

    productData.sort((a, b) => {
      switch (value) {
        case 'price-ascending':
          return a.price - b.price;
        case 'price-descending':
          return b.price - a.price;
        case 'title-ascending':
          return a.title.localeCompare(b.title);
        case 'best-selling':
        default:
          return a.originalIndex - b.originalIndex;
      }
    });

    // Re-append cards in sorted order
    for (const item of productData) {
      grid.appendChild(item.element);
    }

    // Re-apply filters + pagination with new order
    applyFilters();
  };

  // ========================================
  // INITIALIZATION
  // ========================================

  // Phase 1: Initialize from server-rendered DOM cards (instant)
  initProductData();
  applyFilters();

  console.log('CF-PLP-AJAX: Phase 1 complete -', productData.length, 'server-rendered products');

  // Phase 2: AJAX fetch all products, backfill missing ones, then build filters
  fetchAllProducts().then(({ brands, types, totalProducts, allProducts }) => {
    const backfilled = backfillProducts(allProducts);

    if (backfilled > 0) {
      console.log('CF-PLP-AJAX: Backfilled', backfilled, 'products into DOM');
      // Re-init productData from now-complete DOM
      initProductData();
      applyFilters();

      // Trigger wpd-bridge to process new cards' WSH pricing
      if (typeof window.processCollectionBridges === 'function') {
        setTimeout(() => window.processCollectionBridges(), 500);
      }
    }

    // Build filters from AJAX data (counts match total including backfilled cards)
    buildBrandFilters(brands);
    buildTypeFilters(types);
    console.log('CF-PLP-AJAX: Phase 2 complete -', totalProducts, 'total products,', backfilled, 'backfilled,', brands.size, 'brands,', types.size, 'types');
  }).catch(error => {
    console.error('CF-PLP-AJAX: Failed to build filters', error);
    if (brandFilterLoading) {
      brandFilterLoading.innerHTML = '<span style="color: #ef4444; font-size: 12px;">Failed to load brands</span>';
    }
    if (typeFilterLoading) {
      typeFilterLoading.innerHTML = '<span style="color: #ef4444; font-size: 12px;">Failed to load types</span>';
    }
  });
});
</script>

