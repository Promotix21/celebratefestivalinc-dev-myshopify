  height: 18px;
  background: var(--primary-red);
  border-radius: 2px;
}

.cf-plp-ajax__filter-group {
  margin-bottom: 24px;
  padding-bottom: 20px;
  border-bottom: 1px solid var(--border-color);
}

.cf-plp-ajax__filter-group:last-child {
  border-bottom: none;
}

.cf-plp-ajax__filter-title {
  font-size: 13px;
  font-weight: 700;
  color: var(--deep-blue);
  margin: 0 0 14px;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.cf-plp-ajax__filter-options {
  list-style: none;
  margin: 0;
  padding: 0;
}

.cf-plp-ajax__filter-options li {
  margin-bottom: 10px;
}

.cf-plp-ajax__filter-option {
  display: flex;
  align-items: center;
  gap: 10px;
  font-size: 13px;
  color: var(--text-medium);
  cursor: pointer;
  transition: color 0.2s ease;
}

.cf-plp-ajax__filter-option:hover {
  color: var(--deep-blue);
}

.cf-plp-ajax__filter-option input[type="checkbox"] {
  width: 16px;
  height: 16px;
  accent-color: var(--primary-blue);
  cursor: pointer;
}

/* Loading State for Filters */
.cf-plp-ajax__filter-loading {
  padding: 20px;
  text-align: center;
}

.cf-plp-ajax__filter-spinner {
  display: inline-block;
  width: 24px;
  height: 24px;
  border: 3px solid var(--border-color);
  border-top-color: var(--primary-blue);
  border-radius: 50%;
  animation: cf-spin 0.8s linear infinite;
  margin-bottom: 10px;
}

@keyframes cf-spin {
  to { transform: rotate(360deg); }
}

.cf-plp-ajax__filter-loading-text {
  font-size: 12px;
  color: var(--text-muted);
  display: block;
}

.cf-plp-ajax__filter-progress {
  font-size: 11px;
  color: var(--primary-blue);
  margin-top: 8px;
  font-weight: 600;
}

/* Toolbar */
.cf-plp-ajax__toolbar-compact {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 8px 40px;
  background: var(--bg-light);
  border-bottom: 1px solid var(--border-color);
  gap: 16px;
  flex-wrap: wrap;
}

.cf-plp-ajax__toolbar-compact__left {
  display: flex;
  align-items: center;
  gap: 10px;
  flex-wrap: wrap;
}

.cf-plp-ajax__toolbar-compact__right {
  display: flex;
  align-items: center;
  gap: 16px;
}

.cf-plp-ajax__results-count {
  font-size: 13px;
  color: var(--text-medium);
}

.cf-plp-ajax__view-toggle {
  display: flex;
  gap: 0;
}

.cf-plp-ajax__view-btn {
  padding: 10px 16px;
  border: 1px solid var(--border-color);
  background: var(--bg-white);
  font-size: 13px;
  cursor: pointer;
  display: flex;
  align-items: center;
  gap: 6px;
  color: var(--text-medium);
  transition: all 0.2s ease;
}

.cf-plp-ajax__view-btn:first-child {
  border-radius: 6px 0 0 6px;
}

.cf-plp-ajax__view-btn:last-child {
  border-radius: 0 6px 6px 0;
  border-left: none;
}

.cf-plp-ajax__view-btn.active {
  background: var(--deep-blue);
  color: white;
  border-color: var(--deep-blue);
}

.cf-plp-ajax__sort {
  display: flex;
  align-items: center;
  gap: 10px;
}

.cf-plp-ajax__sort label {
  font-size: 13px;
  color: var(--text-medium);
}

.cf-plp-ajax__sort select {
  padding: 10px 36px 10px 14px;
  border: 1px solid var(--border-color);
  border-radius: 6px;
  font-size: 13px;
  background: var(--bg-white);
  cursor: pointer;
}

/* Active Filters */
.cf-plp-ajax__active-filters-inline {
  display: flex;
  align-items: center;
  gap: 8px;
  flex-wrap: wrap;
}

.cf-plp-ajax__active-filters-label {
  font-size: 12px;
  font-weight: 600;
  color: var(--text-medium);
}

.cf-plp-ajax__active-filters-list {
  display: flex;
  gap: 6px;
  flex-wrap: wrap;
}

.cf-plp-ajax__clear-all {
  background: none;
  border: none;
  font-size: 12px;
  font-weight: 600;
  color: var(--primary-blue);
  cursor: pointer;
  padding: 0;
  margin-left: 8px;
}

.cf-plp-ajax__clear-all:hover {
  color: var(--primary-red);
}

.cf-plp-ajax__filter-chip {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  padding: 6px 12px;
  background: var(--pale-blue);
  border: 1px solid var(--primary-blue);
  border-radius: 20px;
  font-size: 12px;
  font-weight: 500;
  color: var(--deep-blue);
}

.cf-plp-ajax__filter-chip-remove {
  width: 16px;
  height: 16px;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--primary-blue);
  color: white;
  border-radius: 50%;
  font-size: 10px;
  cursor: pointer;
  transition: all 0.2s ease;
}

.cf-plp-ajax__filter-chip-remove:hover {
  background: var(--primary-red);
  transform: scale(1.1);
}

/* Products Area */
.cf-plp-ajax__products {
  flex: 1;
  padding: 20px 30px;
  min-width: 0; /* Prevents flex item from overflowing */
}

/* Product Grid */
.cf-plp-ajax__grid {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 20px;
  align-items: start;
}

/* List View Mode - horizontal card: image left, content right, 2 per row */
.cf-plp-ajax__grid.list-view {
  grid-template-columns: repeat(2, minmax(0, 1fr));
}

.cf-plp-ajax__grid.list-view .cf-plp__card {
  display: flex;
  flex-direction: row;
  align-items: flex-start;
  gap: 20px;
}

.cf-plp-ajax__grid.list-view .cf-plp__card-image-wrap {
  width: 180px;
  min-width: 180px;
  height: 160px;
  margin-bottom: 0;
  align-self: center;
}

.cf-plp-ajax__grid.list-view .cf-plp__card-content {
  flex: 1;
  min-width: 0;
}

.cf-plp-ajax__grid.list-view .cf-plp__card-title {
  white-space: normal;
  -webkit-line-clamp: unset;
  overflow: visible;
  min-height: auto;
}

.cf-plp-ajax__grid.list-view .cf-plp__card-badge {
  top: 12px;
  left: 12px;
}

.cf-plp-ajax__grid.list-view .cf-plp__card-badge .badge {
  font-size: 9px;
}

.cf-plp-ajax__grid.list-view .cf-plp__price-box {
  max-width: 280px;
}

.cf-plp-ajax__grid.list-view .cf-plp__cart-row {
  max-width: 320px;
}

@media (max-width: 1200px) {
  .cf-plp-ajax__grid {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }
  .cf-plp-ajax__grid.list-view {
    grid-template-columns: minmax(0, 1fr);
  }
}

@media (max-width: 992px) {
  .cf-plp-ajax__grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }
  .cf-plp-ajax__grid.list-view {
    grid-template-columns: minmax(0, 1fr);
  }
  .cf-plp-ajax__sidebar {
    display: none;
  }
}

/* Product Card */
.cf-plp__card {
  background: var(--bg-white);
  border: 1px solid var(--border-color);
  border-radius: 12px;
  padding: 20px;
  position: relative;
  transition: all 0.3s ease;
  min-width: 0; /* Allows grid item to shrink below content min-width */
}

.cf-plp__card:hover {
  border-color: var(--primary-blue);
  box-shadow: 0 12px 40px rgba(37, 99, 235, 0.12);
  transform: translateY(-4px);
}

.cf-plp__card-badge {
  position: absolute;
  top: 16px;
  left: 16px;
  z-index: 2;
  display: flex;
  flex-wrap: wrap;
  gap: 4px;
}

.cf-plp__card-badge .badge {
  background: var(--deep-blue);
  color: white;
  font-size: 10px;
  padding: 4px 10px;
  font-weight: 700;
  border-radius: 4px;
  text-transform: uppercase;
  letter-spacing: 0.5px;
}

.cf-plp__card-image-wrap {
  display: block;
  width: 100%;
  height: 160px;
  margin-bottom: 16px;
  background: #ffffff;
  border: 1px solid var(--border-color);
  border-radius: 8px;
  overflow: hidden;
  position: relative;
}

.cf-plp__card-image {
  display: block;
  width: 100%;
  height: 100%;
  object-fit: contain;
  transition: filter 0.3s ease, transform 0.3s ease;
}

.cf-plp__card:hover .cf-plp__card-image {
  filter: brightness(1.08);
  transform: scale(1.02);
}

.cf-plp__card-category {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  font-size: 11px;
  color: var(--text-muted);
  margin-bottom: 8px;
  background: var(--sky-blue);
  padding: 4px 10px;
  border-radius: 20px;
}

.cf-plp__card .product-title-link,
.cf-plp__card .product-link {
  text-decoration: none;
  color: inherit;
  display: block;
}

.cf-plp__card-title {
  font-size: 13px;
  font-weight: 600;
  color: var(--deep-blue);
  text-decoration: none;
  line-height: 1.4;
  display: block;
  margin: 0 0 8px;
  transition: color 0.2s ease;
}

.cf-plp__card-title:hover {
  color: var(--primary-blue);
}

.cf-plp__card-sku {
  font-size: 11px;
  color: var(--text-muted);
  margin-bottom: 6px;
}

/* Variants Badge */
.cf-plp__variants-badge {
  position: absolute;
  top: 8px;
  right: 8px;
  background: var(--deep-blue);
  color: white;
  border-radius: 20px;
  padding: 5px 10px;
  font-size: 10px;
  font-weight: 600;
  cursor: pointer;
  z-index: 5;
  transition: all 0.3s ease;
  white-space: nowrap;
}

.cf-plp__variants-text {
  display: block;
}

.cf-plp__variants-tooltip {
  display: none;
  position: absolute;
  top: calc(100% + 8px);
  right: 0;
  background: var(--deep-blue);
  color: white;
  padding: 10px 14px;
  border-radius: 8px;
  font-size: 11px;
  font-weight: 500;
  line-height: 1.4;
  min-width: 180px;
  max-width: 280px;
  white-space: normal;
  text-align: left;
  box-shadow: 0 4px 16px rgba(0, 0, 0, 0.2);
  z-index: 10;
}

.cf-plp__variants-badge:hover .cf-plp__variants-tooltip {
  display: block;
}

/* Price Box */
.cf-plp__price-box {
  background: linear-gradient(135deg, #f8fafc 0%, #ffffff 100%);
  border: 1px solid #e2e8f0;
  padding: 8px 10px;
  margin-bottom: 8px;
  text-align: center;
  border-radius: 6px;
}

.cf-plp__price-label {
  font-size: 10px;
  color: var(--primary-blue);
  font-weight: 700;
  margin-bottom: 4px;
  text-transform: uppercase;
  letter-spacing: 0.5px;
}

.cf-plp__price-main {
  font-family: 'Montserrat', sans-serif;
  font-size: 16px;
  font-weight: 700;
  color: var(--primary-red);
}

.cf-plp__price-unit {
  font-size: 12px;
  color: var(--text-medium);
  font-weight: 400;
}

.cf-plp__price-original {
  font-size: 12px;
  color: var(--text-muted);
  text-decoration: line-through;
  margin-top: 4px;
}

/* Sale price strikethrough (compare_at_price) for everyone */
.cf-plp__price-original {
  font-size: 12px;
  color: #94a3b8;
  margin-top: 2px;
}

.cf-plp__price-original s {
  text-decoration: line-through;
}

.cf-plp__sale-savings {
  font-size: 11px;
  color: #10b981;
  font-weight: 600;
  margin-top: 2px;
}

/* Login/Call Prompts */
.cf-plp__login-prompt {
  display: inline-block;
  margin-top: 8px;
  padding: 6px 12px;
  background: linear-gradient(135deg, rgba(37, 99, 235, 0.1) 0%, rgba(26, 58, 92, 0.1) 100%);
  border: 1px dashed var(--primary-blue);
  border-radius: 6px;
  color: var(--primary-blue);
  font-size: 11px;
  font-weight: 600;
  text-decoration: none;
  transition: all 0.2s ease;
}

.cf-plp__login-prompt:hover {
  background: var(--primary-blue);
  color: white;
  border-style: solid;
}

.cf-plp__call-prompt {
  display: inline-block;
  margin-top: 8px;
  padding: 6px 12px;
  background: linear-gradient(135deg, #f8fafc 0%, #f1f5f9 100%);
  border: 1px solid var(--border-color);
  border-radius: 6px;
  color: var(--deep-blue);
  font-size: 10px;
  font-weight: 600;
  text-decoration: none;
  transition: all 0.2s ease;
}

.cf-plp__call-prompt:hover {
  background: linear-gradient(135deg, var(--deep-blue) 0%, var(--primary-blue) 100%);
  color: white;
  border-color: var(--deep-blue);
}

/* Shipping Badge */
.cf-plp__shipping {
  display: inline-block;
  font-size: 10px;
  padding: 5px 12px;
  font-weight: 700;
  border-radius: 20px;
  text-transform: uppercase;
  letter-spacing: 0.5px;
  margin-bottom: 10px;
}

.cf-plp__shipping--free {
  background: linear-gradient(135deg, var(--success-green) 0%, #059669 100%);
  color: white;
}

.cf-plp__shipping--quick {
  background: linear-gradient(135deg, var(--primary-blue) 0%, var(--deep-blue) 100%);
  color: white;
}

.cf-plp__shipping--regular {
  background: var(--bg-light);
  color: var(--text-medium);
}

/* Add to Cart Row */
.cf-plp__cart-row {
  display: flex;
  align-items: center;
  gap: 8px;
  margin-top: 14px;
}

.cf-plp__qty-input {
  width: 50px;
  height: 38px;
  border: 2px solid #e2e8f0;
  border-radius: 6px;
  text-align: center;
  font-size: 14px;
  font-weight: 600;
  color: #0f172a;
}

.cf-plp__qty-input:focus {
  outline: none;
  border-color: #2d5a87;
}

.cf-plp__add-btn {
  flex: 1;
  height: 38px;
  background: linear-gradient(135deg, #2d5a87 0%, #1a365d 100%);
  color: #ffffff;
  border: none;
  font-size: 12px;
  font-weight: 700;
  cursor: pointer;
  border-radius: 6px;
  transition: all 0.3s ease;
  text-transform: uppercase;
  letter-spacing: 0.5px;
}

.cf-plp__add-btn:hover {
  background: linear-gradient(135deg, #3d6a9f 0%, #2d5a87 100%);
  transform: translateY(-2px);
  box-shadow: 0 4px 15px rgba(45, 90, 135, 0.3);
}

.cf-plp__add-btn:disabled {
  background: #94a3b8;
  cursor: not-allowed;
  opacity: 0.7;
  transform: none;
  box-shadow: none;
}

/* Pagination */
.cf-plp-ajax__pagination {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 8px;
  padding: 30px 0;
  margin-top: 20px;
  border-top: 1px solid var(--border-color);
}

.cf-plp-ajax__page-btn {
  padding: 10px 20px;
  border: 1px solid var(--border-color);
  background: white;
  color: var(--text-dark);
  font-size: 14px;
  font-weight: 500;
  border-radius: 6px;
  cursor: pointer;
  transition: all 0.2s ease;
}

.cf-plp-ajax__page-btn:hover:not(:disabled) {
  border-color: var(--deep-blue);
  color: var(--deep-blue);
  background: var(--bg-light);
}

.cf-plp-ajax__page-btn:disabled {
  opacity: 0.5;
  cursor: not-allowed;
}

.cf-plp-ajax__page-numbers {
  display: flex;
  gap: 4px;
}

.cf-plp-ajax__page-num {
  width: 36px;
  height: 36px;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 1px solid var(--border-color);
  background: white;
  color: var(--text-dark);
  font-size: 14px;
  font-weight: 500;
  border-radius: 6px;
  cursor: pointer;
  transition: all 0.2s ease;
}

.cf-plp-ajax__page-num:hover {
  border-color: var(--deep-blue);
  color: var(--deep-blue);
}

.cf-plp-ajax__page-num.active {
  background: var(--deep-blue);
  border-color: var(--deep-blue);
  color: white;
}

/* Mobile */
@media (max-width: 768px) {
  .cf-plp-ajax__grid.list-view .cf-plp__card {
    flex-direction: column;
  }
  .cf-plp-ajax__grid.list-view .cf-plp__card-image-wrap {
    width: 100%;
    min-width: unset;
  }
  .cf-plp-ajax__grid.list-view .cf-plp__price-box,
  .cf-plp-ajax__grid.list-view .cf-plp__cart-row {
    max-width: 100%;
  }

  .cf-plp-ajax__header-compact {
    flex-direction: column;
    align-items: flex-start;
    gap: 8px;
    padding: 12px 20px;
  }

  .cf-plp-ajax__title-compact {
    font-size: 18px;
    white-space: normal;
  }

  .cf-plp-ajax__toolbar-compact {
    flex-direction: column;
    align-items: stretch;
    gap: 10px;
    padding: 10px 20px;
  }

  .cf-plp-ajax__toolbar-compact__left {
    justify-content: flex-start;
  }

  .cf-plp-ajax__toolbar-compact__right {
    justify-content: space-between;
    width: 100%;
  }

  .cf-plp-ajax__pills {
    padding: 6px 12px;
    overflow-x: auto;
    flex-wrap: nowrap;
    gap: 6px;
  }

  .cf-plp-ajax__pills-label {
    font-size: 11px;
    white-space: nowrap;
  }

  /* Use !important to override compact-mode specificity */
  .cf-plp-ajax__pill,
  .cf-plp-ajax--compact .cf-plp-ajax__pill {
    padding: 4px 10px !important;
    font-size: 11px !important;
    white-space: nowrap;
  }
}

/* Mobile Filter Button */
.cf-plp-ajax__mobile-filter-btn {
  display: none;
  padding: 10px 16px;
  border: 1px solid var(--border-color);
  background: var(--bg-white);
  font-size: 13px;
  cursor: pointer;
  align-items: center;
  gap: 6px;
  color: var(--text-medium);
  border-radius: 6px;
}

@media (max-width: 992px) {
  .cf-plp-ajax__mobile-filter-btn {
    display: flex;
  }
}

/* Filter Count Badge */
.cf-plp-ajax__filter-count {
  color: var(--text-muted);
  margin-left: auto;
  font-size: 12px;
}
</style>

<div class="cf-plp-ajax{% if section.settings.compact_mode %} cf-plp-ajax--compact{% endif %}">
  {% comment %} Compact Header Row 1: Breadcrumb (left) | Title (right) {% endcomment %}
  <header class="cf-plp-ajax__header-compact">
    <nav class="cf-plp-ajax__breadcrumb-inline" aria-label="Breadcrumb">
      <a href="/">Home</a>
      <span class="cf-plp-ajax__breadcrumb-sep">›</span>
      {% assign breadcrumb_found = false %}
      {% for link in linklists[menu_handle].links %}
        {% unless breadcrumb_found %}
          {% for l2_link in link.links %}
            {% assign l2_handle = l2_link.url | split: '/' | last | split: '?' | first %}
            {% if l2_handle == collection.handle %}
              <a href="{{ link.url }}">{{ link.title | remove: 'New Theme - ' | remove: 'New Theme- ' }}</a>
              <span class="cf-plp-ajax__breadcrumb-sep">›</span>
              {% assign breadcrumb_found = true %}
              {% break %}
            {% endif %}
          {% endfor %}
        {% endunless %}
      {% endfor %}
      <span class="cf-plp-ajax__breadcrumb-current">{{ collection.title | remove: 'New Theme - ' | remove: 'New Theme- ' }}</span>
    </nav>
    <h1 class="cf-plp-ajax__title-compact">{{ collection.title | remove: 'New Theme - ' | remove: 'New Theme- ' }}</h1>
  </header>

  {% comment %} L3 Filter Pills (L2 only) - Menu is source of truth {% endcomment %}
  {% if l3_handle_array.size > 0 %}
    <nav class="cf-plp-ajax__pills" aria-label="Filter by category">
      <span class="cf-plp-ajax__pills-label">Subcategory:</span>

      <button type="button" class="cf-plp-ajax__pill active" data-filter="all">
        All Products
      </button>

      {% for handle in l3_handle_array %}
        {% assign handle_clean = handle | strip %}
        {% assign pill_index = forloop.index0 %}
        {% assign pill_title = l3_title_array[pill_index] | default: handle_clean %}
        {% if handle_clean != blank %}
          {% comment %} Special case: Indian Specialty pills link to L1 page instead of filtering {% endcomment %}
          {% assign pill_title_lower = pill_title | downcase %}
          {% if pill_title_lower contains 'indian specialty' %}
            <a href="/collections/indian-specialty" class="cf-plp-ajax__pill cf-plp-ajax__pill--link">
              {{ pill_title }}
            </a>
          {% elsif pill_title_lower contains 'food holding' %}
            <a href="/collections/food-holding-and-warming-equipment" class="cf-plp-ajax__pill cf-plp-ajax__pill--link">
              {{ pill_title }}
            </a>
          {% elsif pill_title_lower contains 'storage racks' %}
            <a href="/collections/chrome" class="cf-plp-ajax__pill cf-plp-ajax__pill--link">
              {{ pill_title }}
            </a>
          {% else %}
            <button type="button" class="cf-plp-ajax__pill" data-filter="{{ handle_clean }}">
              {{ pill_title }}
            </button>
          {% endif %}
        {% endif %}
      {% endfor %}
    </nav>
  {% endif %}

  {% comment %} Toolbar Row {% endcomment %}
  <div class="cf-plp-ajax__toolbar-compact">
    <div class="cf-plp-ajax__toolbar-compact__left">
      <div class="cf-plp-ajax__active-filters-inline" id="active-filters-ajax" style="display: none;">
        <span class="cf-plp-ajax__active-filters-label">Active Filters:</span>
        <div class="cf-plp-ajax__active-filters-list" id="active-filters-list-ajax"></div>
        <button type="button" class="cf-plp-ajax__clear-all" id="clear-all-filters-ajax">Clear All</button>
      </div>
      <div class="cf-plp-ajax__results-count">
        <strong id="filtered-count-ajax">{{ grand_total_products }}</strong> products
      </div>
    </div>

    <div class="cf-plp-ajax__toolbar-compact__right">
      <button type="button" class="cf-plp-ajax__mobile-filter-btn" id="mobile-filter-btn-ajax">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <line x1="4" y1="6" x2="20" y2="6"></line>
          <line x1="8" y1="12" x2="16" y2="12"></line>
          <line x1="11" y1="18" x2="13" y2="18"></line>
        </svg>
        Filters
      </button>
      <div class="cf-plp-ajax__view-toggle">
        <button class="cf-plp-ajax__view-btn active" data-view="grid">
          <svg width="14" height="14" viewBox="0 0 16 16" fill="currentColor">
            <rect x="0" y="0" width="7" height="7" rx="1"/>
            <rect x="9" y="0" width="7" height="7" rx="1"/>
            <rect x="0" y="9" width="7" height="7" rx="1"/>
            <rect x="9" y="9" width="7" height="7" rx="1"/>
          </svg>
          Grid
        </button>
        <button class="cf-plp-ajax__view-btn" data-view="list">
          <svg width="14" height="14" viewBox="0 0 16 16" fill="currentColor">
            <rect x="0" y="1" width="16" height="3" rx="1"/>
            <rect x="0" y="6" width="16" height="3" rx="1"/>
            <rect x="0" y="11" width="16" height="3" rx="1"/>
          </svg>
          List
        </button>
      </div>

      <div class="cf-plp-ajax__sort">
        <label for="plp-sort-ajax">Sort by</label>
        <select id="plp-sort-ajax" onchange="handleSortAjax(this.value)">
          <option value="best-selling">Most Popular</option>
          <option value="price-ascending">Price: Low to High</option>
          <option value="price-descending">Price: High to Low</option>
          <option value="title-ascending">Name: A-Z</option>
        </select>
      </div>
    </div>
  </div>

  {% comment %} Main Container {% endcomment %}
  <div class="cf-plp-ajax__container">

    {% comment %} Filters Sidebar with AJAX Loading {% endcomment %}
    <aside class="cf-plp-ajax__sidebar">
      <h2 class="cf-plp-ajax__filters-title">Filters</h2>

      {% comment %} Brand Filter - AJAX Loaded {% endcomment %}
      <div class="cf-plp-ajax__filter-group" id="brand-filter-group">
        <h3 class="cf-plp-ajax__filter-title">Brand</h3>
        <div class="cf-plp-ajax__filter-loading" id="brand-filter-loading">
          <div class="cf-plp-ajax__filter-spinner"></div>
          <span class="cf-plp-ajax__filter-loading-text">Loading brands...</span>
          <div class="cf-plp-ajax__filter-progress" id="brand-filter-progress"></div>
        </div>
        <ul class="cf-plp-ajax__filter-options" id="brand-filter-options" style="display: none;"></ul>
      </div>

      {% comment %} Product Type Filter - AJAX Loaded {% endcomment %}
      <div class="cf-plp-ajax__filter-group" id="type-filter-group">
        <h3 class="cf-plp-ajax__filter-title">Product Type</h3>
        <div class="cf-plp-ajax__filter-loading" id="type-filter-loading">
          <div class="cf-plp-ajax__filter-spinner"></div>
          <span class="cf-plp-ajax__filter-loading-text">Loading types...</span>
        </div>
        <ul class="cf-plp-ajax__filter-options" id="type-filter-options" style="display: none;"></ul>
      </div>

      {% comment %} Price Range Filter - Static {% endcomment %}
      <div class="cf-plp-ajax__filter-group">
        <h3 class="cf-plp-ajax__filter-title">Price Range</h3>
        <ul class="cf-plp-ajax__filter-options">
          <li>
            <label class="cf-plp-ajax__filter-option">
              <input type="checkbox" name="price-ajax" value="0-500">
              Under $500
            </label>
          </li>
          <li>
            <label class="cf-plp-ajax__filter-option">
              <input type="checkbox" name="price-ajax" value="500-1000">
              $500 - $1,000
            </label>
          </li>
          <li>
            <label class="cf-plp-ajax__filter-option">
              <input type="checkbox" name="price-ajax" value="1000-2500">
              $1,000 - $2,500
            </label>
          </li>
          <li>
            <label class="cf-plp-ajax__filter-option">
              <input type="checkbox" name="price-ajax" value="2500+">
              $2,500+
            </label>
          </li>
        </ul>
      </div>
    </aside>

    {% comment %} Products Area {% endcomment %}
    <div class="cf-plp-ajax__products">
      <div class="cf-plp-ajax__grid" id="product-grid-ajax">
        {% assign products_shown = 0 %}
        {% assign products_limit = 500 %}

        {% for handle in l3_handle_array %}
          {% assign handle_clean = handle | strip %}
          {% if handle_clean != blank %}
            {% assign l3_coll = collections[handle_clean] %}
            {% assign l3_category = l3_coll.title | remove: 'New Theme - ' | remove: 'New Theme- ' %}
            {% for product in l3_coll.products limit: 100 %}
              {% if product.price == 0 %}{% continue %}{% endif %}
              {% if products_shown < products_limit %}
                {% assign products_shown = products_shown | plus: 1 %}
                {% render 'product-card', product: product, collection_ref: l3_coll, data_category: handle_clean %}
              {% endif %}
            {% endfor %}
          {% endif %}
        {% endfor %}

        {% if products_shown == 0 %}
          {% for product in l2_collection.products limit: products_limit %}
            {% if product.price == 0 %}{% continue %}{% endif %}
            {% render 'product-card', product: product, collection_ref: l2_collection, data_category: 'all' %}
          {% endfor %}
        {% endif %}
      </div>

      {% comment %} Pagination {% endcomment %}
      <div class="cf-plp-ajax__pagination" id="pagination-ajax" style="display: none;">
        <button type="button" class="cf-plp-ajax__page-btn" id="prev-btn-ajax">Previous</button>
        <div class="cf-plp-ajax__page-numbers" id="page-numbers-ajax"></div>
        <button type="button" class="cf-plp-ajax__page-btn" id="next-btn-ajax">Next</button>
      </div>
    </div>
  </div>
</div>

{% comment %} Mobile Filter Drawer - appended to body via JS on open {% endcomment %}
<div class="cf-plp-ajax__mobile-filter-drawer" id="mobile-filter-drawer-ajax">
  <div class="cf-plp-ajax__mobile-filter-overlay" id="mobile-filter-overlay-ajax"></div>
  <div class="cf-plp-ajax__mobile-filter-panel">
    <div class="cf-plp-ajax__mobile-filter-header">
      <h3>Filters</h3>
      <button type="button" class="cf-plp-ajax__mobile-filter-close" id="mobile-filter-close-ajax">×</button>
    </div>
    <div class="cf-plp-ajax__mobile-filter-content" id="mobile-filter-content-ajax">
      <!-- Filters cloned here by JS -->
    </div>
    <div class="cf-plp-ajax__mobile-filter-apply">
      <button type="button" id="mobile-filter-apply-ajax">Apply Filters</button>
    </div>
  </div>
</div>

<style>
