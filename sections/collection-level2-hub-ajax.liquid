{
  "name": "L2 Collection Hub (AJAX)",
  "tag": "section",
  "class": "section-collection-level2-ajax",
  "settings": [
    {
      "type": "link_list",
      "id": "menu",
      "label": "Navigation Menu",
      "default": "main-menu"
    },
    {
      "type": "range",
      "id": "products_per_page",
      "min": 24,
      "max": 480,
      "step": 24,
      "default": 48,
      "label": "Products per page"
    },
    {
      "type": "checkbox",
      "id": "compact_mode",
      "label": "Compact Mode (5 columns)",
      "default": true,
      "info": "Show 5 products per row with smaller cards"
    }
  ],
  "presets": [
    {
      "name": "L2 Collection Hub (AJAX)"
    }
  ]
}
{% endschema %}
