{% comment %}
  Collection Level 2 Hub - AJAX Filtering Version
  This version fetches ALL products via AJAX to build 100% accurate filters
  Trade-off: Filters take 3-10 seconds to load, but show ALL brands/types
{% endcomment %}

{% comment %} ========================================
   COLLECTION HANDLE FALLBACK LOGIC
   Menu URLs may point to empty collections.
   Try: original -> new-theme-{handle} -> special mappings
======================================== {% endcomment %}

{% assign menu_handle = section.settings.menu | default: 'main-menu' %}
{% assign l3_children = blank %}
{% assign found_in_menu = false %}

{% comment %} Find current collection in menu and get L3 children {% endcomment %}
{% for link in linklists[menu_handle].links %}
  {% for l2_link in link.links %}
    {% assign l2_handle = l2_link.url | split: '/' | last | split: '?' | first %}
    {% if l2_handle == collection.handle %}
      {% assign l3_children = l2_link.links %}
      {% assign found_in_menu = true %}
      {% break %}
    {% endif %}
  {% endfor %}
  {% if found_in_menu %}{% break %}{% endif %}
{% endfor %}

{% comment %} Collect L3 collection handles with fallback {% endcomment %}
{% assign l3_collection_handles = '' %}
{% assign l3_menu_titles = '' %}
{% assign handle_mappings = 'meat-processing-equipment:new-theme-meat-process-equipment,vegetable-slicers-and-cutters-2:new-theme-vegetable-slicers-and-cutters,rice-cooker:new-theme-rice-cooker,commercial-can-openers:new-theme-commercial-can-openers,stainless-steel-work-tables-with-undershelves-1:new-theme-stainless-steel-work-tables-with-undershelves,stainless-steel-enclosed-base-work-tables-1:new-theme-stainless-steel-work-tables-with-undershelves,open-base-work-tables:new-theme-stainless-steel-work-tables-with-undershelves,equipment-stands-mixer-tables:new-theme-equipment-stands,work-table-preparation-stations:new-theme-preparation-stations' %}

{% if l3_children.size > 0 %}
  {% for child_link in l3_children %}
    {% assign child_handle = child_link.url | split: '/' | last | split: '?' | first %}
    {% assign menu_title = child_link.title %}
    {% assign child_coll = collections[child_handle] %}
    {% assign used_handle = child_handle %}

    {% assign new_theme_handle = 'new-theme-' | append: child_handle %}
    {% assign new_theme_coll = collections[new_theme_handle] %}

    {% assign orig_count = child_coll.products_count | default: 0 | plus: 0 %}
    {% assign new_count = new_theme_coll.products_count | default: 0 | plus: 0 %}

    {% if new_theme_coll and new_count > 0 %}
      {% assign used_handle = new_theme_handle %}
    {% elsif orig_count == 0 %}
      {% assign mappings_array = handle_mappings | split: ',' %}
      {% for mapping in mappings_array %}
        {% assign mapping_parts = mapping | split: ':' %}
        {% assign map_from = mapping_parts[0] %}
        {% assign map_to = mapping_parts[1] %}
        {% if map_from == child_handle %}
          {% assign mapped_coll = collections[map_to] %}
          {% assign map_count = mapped_coll.products_count | default: 0 | plus: 0 %}
          {% if mapped_coll and map_count > 0 %}
            {% assign used_handle = map_to %}
          {% endif %}
          {% break %}
        {% endif %}
      {% endfor %}
    {% endif %}

    {% if l3_collection_handles == '' %}
      {% assign l3_collection_handles = used_handle %}
      {% assign l3_menu_titles = menu_title %}
    {% else %}
      {% assign l3_collection_handles = l3_collection_handles | append: '|||' | append: used_handle %}
      {% assign l3_menu_titles = l3_menu_titles | append: '|||' | append: menu_title %}
    {% endif %}
  {% endfor %}
{% endif %}

{% assign l3_handle_array = l3_collection_handles | split: '|||' %}
{% assign l3_title_array = l3_menu_titles | split: '|||' %}

{% comment %} Calculate totals {% endcomment %}
{% assign total_l3_products = 0 %}
{% for handle in l3_handle_array %}
  {% assign handle_clean = handle | strip %}
  {% if handle_clean != blank %}
    {% assign coll = collections[handle_clean] %}
    {% if coll %}
      {% assign total_l3_products = total_l3_products | plus: coll.products_count %}
    {% endif %}
  {% endif %}
{% endfor %}

{% comment %} L2 collection fallback {% endcomment %}
{% assign l2_collection = collection %}
{% if collection.products_count == 0 %}
  {% assign l2_new_theme_handle = 'new-theme-' | append: collection.handle %}
  {% assign l2_new_theme_coll = collections[l2_new_theme_handle] %}
  {% if l2_new_theme_coll and l2_new_theme_coll.products_count > 0 %}
    {% assign l2_collection = l2_new_theme_coll %}
  {% endif %}
{% endif %}

{% assign grand_total_products = l2_collection.products_count | plus: total_l3_products %}

<style>
/* ========================================
   LEVEL 2 PLP STYLES - AJAX Version
   ======================================== */

/* Color Variables */
.cf-plp-ajax {
  --deep-blue: #1a3a5c;
  --primary-blue: #2563eb;
  --medium-blue: #3b82f6;
  --light-blue: #60a5fa;
  --pale-blue: #dbeafe;
  --sky-blue: #e0f2fe;
  --deep-red: #991b1b;
  --primary-red: #dc2626;
  --bright-red: #ef4444;
  --text-dark: #0f172a;
  --text-medium: #475569;
  --text-light: #64748b;
  --text-muted: #94a3b8;
  --border-color: #e2e8f0;
  --bg-light: #f8fafc;
  --bg-white: #ffffff;
  --rating-gold: #f59e0b;
  --success-green: #10b981;
}

.cf-plp-ajax {
  font-family: 'Inter', sans-serif;
  background: var(--bg-white);
  max-width: 100vw;
  overflow-x: hidden;
  box-sizing: border-box;
}

.cf-plp-ajax *,
.cf-plp-ajax *::before,
.cf-plp-ajax *::after {
  box-sizing: border-box;
}

/* Header Row */
.cf-plp-ajax__header-compact {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 10px 40px;
  background: var(--bg-white);
  border-bottom: 1px solid var(--border-color);
  gap: 20px;
}

.cf-plp-ajax__breadcrumb-inline {
  display: flex;
  align-items: center;
  gap: 8px;
  flex-wrap: wrap;
  font-size: 12px;
  margin: 0;
}

.cf-plp-ajax__breadcrumb-inline a {
  color: var(--primary-blue);
  text-decoration: none;
  transition: color 0.2s ease;
}

.cf-plp-ajax__breadcrumb-inline a:hover {
  color: var(--primary-red);
}

.cf-plp-ajax__breadcrumb-sep {
  color: var(--text-muted);
  font-size: 12px;
}

.cf-plp-ajax__breadcrumb-current {
  color: var(--text-muted);
  font-size: 12px;
}

.cf-plp-ajax__title-compact {
  font-family: 'Montserrat', sans-serif;
  font-size: 20px;
  font-weight: 700;
  color: var(--deep-blue);
  margin: 0;
  line-height: 1.2;
  white-space: nowrap;
}

/* L3 Filter Pills */
.cf-plp-ajax__pills {
  padding: 10px 40px;
  background: var(--bg-light);
  border-bottom: 1px solid var(--border-color);
  display: flex;
  align-items: center;
  gap: 12px;
  flex-wrap: wrap;
}

.cf-plp-ajax__pills-label {
  font-size: 13px;
  font-weight: 600;
  color: var(--text-medium);
}

.cf-plp-ajax__pill {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  padding: 10px 18px;
  background: var(--bg-white);
  border: 1px solid var(--border-color);
  border-radius: 25px;
  font-size: 13px;
  font-weight: 500;
  color: var(--text-medium);
  cursor: pointer;
  transition: all 0.2s ease;
  text-decoration: none;
}

.cf-plp-ajax__pill:hover {
  border-color: var(--primary-blue);
  color: var(--primary-blue);
}

.cf-plp-ajax__pill.active {
  background: var(--deep-blue);
  border-color: var(--deep-blue);
  color: white;
}

.cf-plp-ajax__pill-count {
  background: rgba(0,0,0,0.1);
  padding: 2px 8px;
  border-radius: 12px;
  font-size: 11px;
  font-weight: 600;
}

.cf-plp-ajax__pill.active .cf-plp-ajax__pill-count {
  background: rgba(255,255,255,0.2);
}

/* Pill Link (navigates to another page instead of filtering) */
.cf-plp-ajax__pill--link {
  text-decoration: none;
  background: linear-gradient(135deg, #fff5f5 0%, #ffe8e8 100%);
  border-color: var(--primary-red);
  color: var(--primary-red);
}

.cf-plp-ajax__pill--link:hover {
  background: var(--primary-red);
  border-color: var(--primary-red);
  color: white;
  text-decoration: none;
}

/* ============================================
   COMPACT MODE - 5 Columns (Scaled Down)
   ============================================ */
.cf-plp-ajax--compact .cf-plp-ajax__pills {
  padding: 10px 30px;
  gap: 8px;
}

.cf-plp-ajax--compact .cf-plp-ajax__pills-label {
  font-size: 11px;
}

.cf-plp-ajax--compact .cf-plp-ajax__pill {
  padding: 6px 12px;
  font-size: 11px;
  border-radius: 20px;
}

.cf-plp-ajax--compact .cf-plp-ajax__container {
  gap: 20px;
}

.cf-plp-ajax--compact .cf-plp-ajax__sidebar {
  width: 220px;
  padding: 16px;
}

.cf-plp-ajax--compact .cf-plp-ajax__filters-title {
  font-size: 14px;
  margin-bottom: 8px;
}

.cf-plp-ajax--compact .cf-plp-ajax__filter-group {
  margin-bottom: 12px;
  padding-bottom: 10px;
}

.cf-plp-ajax--compact .cf-plp-ajax__filter-title {
  font-size: 11px;
  padding: 0;
  margin: 0 0 6px;
}

.cf-plp-ajax--compact .cf-plp-ajax__filter-options li {
  margin-bottom: 4px;
}

.cf-plp-ajax--compact .cf-plp-ajax__filter-option {
  font-size: 11px;
  padding: 2px 0;
  gap: 6px;
}

.cf-plp-ajax--compact .cf-plp-ajax__filter-option input[type="checkbox"] {
  width: 14px;
  height: 14px;
}

.cf-plp-ajax--compact .cf-plp-ajax__products {
  padding: 16px 20px;
}

.cf-plp-ajax--compact .cf-plp-ajax__grid {
  grid-template-columns: repeat(5, minmax(0, 1fr));
  gap: 14px;
  align-items: start;
}

.cf-plp-ajax--compact .cf-plp-ajax__grid.list-view {
  grid-template-columns: repeat(2, minmax(0, 1fr));
}

.cf-plp-ajax--compact .cf-plp-ajax__grid.list-view .cf-plp__card {
  display: flex;
  flex-direction: row;
  align-items: flex-start;
  gap: 16px;
}

.cf-plp-ajax--compact .cf-plp-ajax__grid.list-view .cf-plp__card-image-wrap {
  width: 160px;
  min-width: 160px;
  height: 140px;
  margin-bottom: 0;
  align-self: center;
}

.cf-plp-ajax--compact .cf-plp-ajax__grid.list-view .cf-plp__card-content {
  flex: 1;
  min-width: 0;
}

.cf-plp-ajax--compact .cf-plp-ajax__grid.list-view .cf-plp__card-title {
  white-space: normal;
  -webkit-line-clamp: unset;
  overflow: visible;
  min-height: auto;
}

.cf-plp-ajax--compact .cf-plp__card {
  padding: 12px;
  border-radius: 10px;
}

.cf-plp-ajax--compact .cf-plp__card-badge {
  top: 10px;
  left: 10px;
}

.cf-plp-ajax--compact .cf-plp__card-badge .badge {
  font-size: 9px;
  padding: 3px 8px;
}

.cf-plp-ajax--compact .cf-plp__card-image-wrap {
  height: 120px;
  margin-bottom: 10px;
  border-radius: 6px;
}

.cf-plp-ajax--compact .cf-plp__card-category {
  font-size: 9px;
  padding: 3px 8px;
  margin-bottom: 6px;
}

.cf-plp-ajax--compact .cf-plp__card-title {
  font-size: 11px;
  margin-bottom: 6px;
  line-height: 1.35;
  min-height: calc(11px * 1.35 * 2);
  -webkit-line-clamp: 2;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.cf-plp-ajax--compact .cf-plp__card-sku {
  font-size: 9px;
  margin-bottom: 4px;
}

.cf-plp-ajax--compact .cf-plp__price-box {
  padding: 8px 6px;
  border-radius: 6px;
}

.cf-plp-ajax--compact .cf-plp__price-label {
  font-size: 9px;
  margin-bottom: 2px;
}

.cf-plp-ajax--compact .cf-plp__price-main {
  font-size: 12px;
}

.cf-plp-ajax--compact .cf-plp__price-original {
  font-size: 10px;
}

.cf-plp-ajax--compact .cf-plp__price-original {
  font-size: 10px;
}

.cf-plp-ajax--compact .cf-plp__sale-savings {
  font-size: 9px;
}

.cf-plp-ajax--compact .cf-plp__shipping {
  font-size: 9px;
  padding: 4px 8px;
  margin-top: 6px;
}

.cf-plp-ajax--compact .cf-plp__cart-row {
  margin-top: 8px;
  gap: 6px;
}

.cf-plp-ajax--compact .cf-plp__qty-input {
  width: 50px;
  padding: 6px 4px;
  font-size: 11px;
}

.cf-plp-ajax--compact .cf-plp__add-btn {
  padding: 8px 10px;
  font-size: 10px;
}

.cf-plp-ajax--compact .cf-plp__variants-badge {
  padding: 3px 8px;
  font-size: 9px;
}

/* Compact toolbar */
.cf-plp-ajax--compact .cf-plp-ajax__toolbar-compact {
  padding: 10px 20px;
}

.cf-plp-ajax--compact .cf-plp-ajax__toolbar-compact__left {
  flex: 1;
  min-width: 0;
}

.cf-plp-ajax--compact .cf-plp-ajax__active-filters-inline {
  display: flex;
  align-items: center;
  gap: 8px;
  flex-wrap: wrap;
}

.cf-plp-ajax--compact .cf-plp-ajax__active-filters-label {
  font-size: 11px;
  white-space: nowrap;
}

.cf-plp-ajax--compact .cf-plp-ajax__active-filters-list {
  display: flex;
  flex-wrap: wrap;
  gap: 6px;
  flex: 1;
