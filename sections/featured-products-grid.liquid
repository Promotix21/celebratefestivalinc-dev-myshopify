{% comment %}
  Featured Products Slider - Swiper Layout
  Matches Staff Picks section layout (horizontal Swiper slider)
  Used for: Sale Items, Featured Collections, etc.
{% endcomment %}

{{ 'product-celebrate-festival.css' | asset_url | stylesheet_tag }}

<style>
.fpg-section {
  padding: 60px 0;
  background: #ffffff;
}

.fpg-container {
  max-width: 100%;
  width: 100%;
  margin: 0;
  padding: 0 40px 0 20px;
}

/* Section Header */
.fpg-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 32px;
}

.fpg-title {
  font-family: 'Montserrat', sans-serif;
  font-size: 28px;
  font-weight: 700;
  color: #1a365d;
  display: flex;
  align-items: center;
  gap: 12px;
  margin: 0;
}

.fpg-title::before {
  content: '';
  width: 4px;
  height: 32px;
  background: linear-gradient(180deg, #ff6b6b 0%, #1a365d 100%);
  border-radius: 2px;
}

.fpg-subtitle {
  color: #64748b;
  font-size: 15px;
  margin-top: 8px;
}

.fpg-nav-wrap {
  display: flex;
  align-items: center;
  gap: 12px;
}

.fpg-view-all {
  font-size: 14px;
  color: #2563eb;
  text-decoration: none;
  font-weight: 600;
  display: inline-flex;
  align-items: center;
  gap: 6px;
  transition: all 0.2s ease;
}

.fpg-view-all:hover {
  color: #ff6b6b;
  gap: 10px;
}

.fpg-nav-btn {
  width: 44px;
  height: 44px;
  border-radius: 50%;
  border: 2px solid #e2e8f0;
  background: #ffffff;
  color: #1a365d;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s ease;
}

.fpg-nav-btn:hover {
  background: #ff6b6b;
  border-color: #ff6b6b;
  color: #ffffff;
}

.fpg-nav-btn svg {
  width: 18px;
  height: 18px;
}

/* Swiper slider */
.fpg-slider.swiper {
  overflow: hidden;
  width: 100%;
}

.fpg-slider .swiper-wrapper {
  display: flex;
  width: max-content;
  align-items: stretch;
}

/* Reuse sp-slide-wrapper styling from Staff Picks for consistent cards */
.fpg-slide {
  width: 220px !important;
  min-width: 220px;
  height: auto !important;
}

.fpg-slide .product-card {
  width: 100%;
  margin: 0;
  background: #ffffff;
  border-radius: 10px;
  overflow: hidden;
  box-shadow: 0 2px 8px rgba(0,0,0,0.08);
  transition: transform 0.2s, box-shadow 0.2s;
  border: 1px solid #e2e8f0;
}

.fpg-slide .product-card:hover {
  transform: translateY(-4px);
  box-shadow: 0 8px 24px rgba(26, 54, 93, 0.15);
  border-color: #2d5a87;
}

.fpg-slide .product-card .card-image {
  padding: 12px;
  height: 140px;
  aspect-ratio: auto !important;
  display: flex !important;
  align-items: center !important;
  justify-content: center !important;
}

.fpg-slide .product-card .card-image img:not(.product-image-hover) {
  max-width: 100%;
  max-height: 100%;
  width: auto !important;
  height: auto !important;
  object-fit: contain;
}

.fpg-slide .product-card .card-content {
  padding: 12px;
}

.fpg-slide .product-card .card-title {
  font-size: 12px;
  min-height: 36px;
  -webkit-line-clamp: 2;
}

.fpg-slide .product-card .sku {
  font-size: 9px;
}

.fpg-slide .product-card .price-single,
.fpg-slide .product-card .price-dual,
.fpg-slide .product-card .price-member-view {
  padding: 8px 6px;
  min-height: 92px;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.fpg-slide .product-card .price-amount-single,
.fpg-slide .product-card .member-price-amount,
.fpg-slide .product-card .member-view-price {
  font-size: 13px !important;
}

.fpg-slide .product-card .compare-price-strike {
  font-size: 11px;
}

.fpg-slide .product-card .price-label-single,
.fpg-slide .product-card .member-view-label {
  font-size: 9px;
}

.fpg-slide .product-card .price-unit {
  font-size: 10px;
}

.fpg-slide .product-card .card-actions {
  padding: 0 12px 12px;
}

.fpg-slide .product-card .qty-input {
  width: 50px;
  height: 34px;
  font-size: 12px;
}

.fpg-slide .product-card .add-to-cart {
  height: 34px;
  font-size: 11px;
}

.fpg-slide .product-card .add-to-cart:disabled {
  background: #94a3b8;
  cursor: not-allowed;
  opacity: 0.7;
  flex: 1;
}

.fpg-slide .product-card .cf-plp__login-prompt,
.fpg-slide .product-card .cf-plp__call-prompt {
  display: block;
  width: 100%;
  box-sizing: border-box;
  margin-top: 6px;
  padding: 5px 8px;
  border-radius: 6px;
  font-size: 9px;
  font-weight: 600;
  text-align: center;
  text-decoration: none;
  white-space: normal;
  word-break: break-word;
}

.fpg-slide .product-card .cf-plp__login-prompt {
  background: rgba(45, 90, 135, 0.08);
  border: 1px dashed #2d5a87;
  color: #2d5a87;
}

.fpg-slide .product-card .cf-plp__call-prompt {
  background: #f8fafc;
  border: 1px solid #e2e8f0;
  color: #1a365d;
}

.fpg-slider.swiper .swiper-slide {
  width: 220px;
  flex-shrink: 0;
}

/* Empty state */
.fpg-empty {
  text-align: center;
  padding: 60px 20px;
  color: #64748b;
}

.fpg-empty svg {
  width: 64px;
  height: 64px;
  margin-bottom: 16px;
  opacity: 0.5;
}

/* Responsive */
@media (max-width: 768px) {
  .fpg-section {
    padding: 40px 0;
  }

  .fpg-container {
    padding: 0 16px;
  }

  .fpg-header {
    flex-direction: column;
    align-items: flex-start;
    gap: 16px;
  }

  .fpg-title {
    font-size: 22px;
  }

  .fpg-slide {
    width: 180px !important;
    min-width: 180px;
  }

  .fpg-slide .product-card .card-image {
    height: 120px;
    display: flex !important;
    align-items: center !important;
    justify-content: center !important;
  }

  .fpg-slide .product-card .price-amount-single,
  .fpg-slide .product-card .member-price-amount,
  .fpg-slide .product-card .member-view-price {
    font-size: 14px !important;
  }
}

@media (max-width: 576px) {
  .fpg-slide {
    width: 155px !important;
    min-width: 155px;
  }

  .fpg-slider.swiper .swiper-slide {
    width: 155px;
  }

  .fpg-slide .product-card .card-image {
    height: 95px;
    padding: 8px;
  }

  .fpg-slide .product-card .card-content {
    padding: 8px;
  }

  .fpg-slide .product-card .card-title {
    font-size: 11px;
    min-height: 30px;
  }

  .fpg-slide .product-card .card-category,
  .fpg-slide .product-card .card-sku {
    display: none;
  }

  .fpg-slide .product-card .price-single,
  .fpg-slide .product-card .price-dual,
  .fpg-slide .product-card .price-member-view {
    padding: 6px 5px;
    min-height: 60px;
  }

  .fpg-slide .product-card .price-amount-single,
  .fpg-slide .product-card .member-price-amount,
  .fpg-slide .product-card .member-view-price {
    font-size: 12px !important;
  }

  .fpg-slide .product-card .compare-price-strike {
    font-size: 10px;
  }

  .fpg-slide .product-card .sale-savings-tag {
    font-size: 9px;
  }

  .fpg-slide .product-card .card-actions {
    padding: 0 8px 8px;
  }

  .fpg-slide .product-card .qty-input {
    width: 38px;
    height: 28px;
    font-size: 11px;
  }

  .fpg-slide .product-card .add-to-cart {
    height: 28px;
    font-size: 10px;
  }

  .fpg-slide .product-card .cf-plp__login-prompt,
  .fpg-slide .product-card .cf-plp__call-prompt {
    font-size: 8px;
    padding: 4px 6px;
    margin-top: 4px;
  }
}
</style>

<section class="fpg-section" data-section-id="{{ section.id }}">
  <div class="fpg-container">

    <!-- Header -->
    <div class="fpg-header">
      <div>
        <h2 class="fpg-title">{{ section.settings.section_title | default: 'Featured Products' }}</h2>
        {% if section.settings.section_subtitle != blank %}
          <p class="fpg-subtitle">{{ section.settings.section_subtitle }}</p>
        {% endif %}
      </div>
      <div class="fpg-nav-wrap">
        {% if section.settings.view_all_link != blank %}
          <a href="{{ section.settings.view_all_link }}" class="fpg-view-all">View All &rarr;</a>
        {% endif %}
        <button class="fpg-nav-btn" id="fpg-prev-{{ section.id }}" aria-label="Previous">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M15 18l-6-6 6-6"/>
          </svg>
        </button>
        <button class="fpg-nav-btn" id="fpg-next-{{ section.id }}" aria-label="Next">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M9 18l6-6-6-6"/>
          </svg>
        </button>
      </div>
    </div>

    <!-- Products Slider -->
    {% assign featured_products = blank %}
    {% if section.settings.product_source == 'collection' and section.settings.featured_collection != blank %}
      {% assign featured_products = collections[section.settings.featured_collection].products %}
    {% elsif section.settings.product_source == 'manual' %}
      {% assign featured_products = section.settings.featured_products %}
    {% endif %}

    {% if featured_products.size > 0 %}
      <div class="fpg-slider swiper" id="fpg-swiper-{{ section.id }}">
        <div class="swiper-wrapper">
          {% for product in featured_products limit: section.settings.products_limit %}
            {% if product.price == 0 %}{% continue %}{% endif %}
            <div class="swiper-slide fpg-slide">
              {%- render 'product-card',
                product: product,
                show_vendor: false,
                show_rating: false,
                show_sale_badge: true,
                show_shipping_badge: true,
                show_sku: true,
                show_qty_input: true,
                show_category: false,
                homepage_pricing_mode: true
              -%}
            </div>
          {% endfor %}
        </div>
      </div>
    {% else %}
      <div class="fpg-empty">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <rect x="3" y="3" width="7" height="7" rx="1"/>
          <rect x="14" y="3" width="7" height="7" rx="1"/>
          <rect x="14" y="14" width="7" height="7" rx="1"/>
          <rect x="3" y="14" width="7" height="7" rx="1"/>
        </svg>
        <p>No products found. Please configure this section.</p>
      </div>
    {% endif %}

  </div>
</section>

<script>
document.addEventListener('DOMContentLoaded', function() {
  var fpgSwiper{{ section.id | replace: '-', '_' }} = new Swiper('#fpg-swiper-{{ section.id }}', {
    slidesPerView: 'auto',
    spaceBetween: 16,
    loop: true,
    loopedSlides: 8,
    navigation: {
      nextEl: '#fpg-next-{{ section.id }}',
      prevEl: '#fpg-prev-{{ section.id }}',
    },
  });
});
</script>

{% schema %}
{
  "name": "Featured Products Grid",
  "tag": "section",
  "class": "section-featured-products",
  "settings": [
    {
      "type": "text",
      "id": "section_title",
      "label": "Section Title",
      "default": "Featured Products"
    },
    {
      "type": "text",
      "id": "section_subtitle",
      "label": "Section Subtitle",
      "default": "Handpicked by our experts"
    },
    {
      "type": "url",
      "id": "view_all_link",
      "label": "View All Link",
      "info": "Optional link to collection page"
    },
    {
      "type": "header",
      "content": "Product Source"
    },
    {
      "type": "select",
      "id": "product_source",
      "label": "Product Source",
      "options": [
        {
          "value": "collection",
          "label": "From Collection"
        },
        {
          "value": "manual",
          "label": "Manual Selection"
        }
      ],
      "default": "collection"
    },
    {
      "type": "collection",
      "id": "featured_collection",
      "label": "Collection",
      "info": "Select a collection (when using 'From Collection')"
    },
    {
      "type": "product_list",
      "id": "featured_products",
      "label": "Products",
      "info": "Select products manually (when using 'Manual Selection')"
    },
    {
      "type": "range",
      "id": "products_limit",
      "min": 4,
      "max": 20,
      "step": 1,
      "default": 10,
      "label": "Number of Products to Show"
    }
  ],
  "presets": [
    {
      "name": "Featured Products Grid",
      "settings": {
        "section_title": "Sale Items",
        "section_subtitle": "Limited time offers on popular equipment",
        "products_limit": 10
      }
    }
  ]
}
{% endschema %}
