{%- comment -%}
  CF — You May Also Like
  Restores the "You may also like" section from the old theme (148371996717),
  using Shopify's built-in `recommendations.products` API via the section_id
  rendering pattern (the same approach the old theme used in
  sections/static-product-recommendations.liquid).

  Visual design matches the "Works With Products" carousel at the top of
  the SPP main section (sections/product-compact.liquid) — uses the same
  compact-carousel-* class set defined in assets/product-compact.css.

  Architecture:
    • This section is registered in templates/product.json (id "cf-related")
      so that /recommendations/products?section_id={section.id} works as a
      standard Shopify section_id fetch — that's what populates the
      `recommendations` Liquid object with real products.
    • On a NORMAL page render (not a section_id fetch) we deliberately emit
      NO visible carousel. If we did, Shopify would render it as a top-level
      sibling below product-compact and it would span the full container
      width — outside the SPP's left content column.
    • The carousel actually appears via an inline placeholder
      <div data-cf-related-inline …> placed inside .compact-content-col in
      sections/product-compact.liquid. The loader script below fetches this
      section by section_id and injects the carousel HTML into that
      placeholder, so it inherits the left content column's width.
{%- endcomment -%}

{{ 'product-compact.css' | asset_url | stylesheet_tag }}

{%- comment -%}
  Theme-editor on/off toggle. When unchecked the section renders nothing:
  the carousel HTML is suppressed AND the loader script doesn't run, so
  the inline <div data-cf-related-inline> placeholder in product-compact
  stays empty and the carousel doesn't appear on the SPP.
{%- endcomment -%}
{%- if section.settings.show_section == false -%}
  {%- comment -%} disabled via theme editor — render nothing {%- endcomment -%}

{%- elsif recommendations.performed and recommendations.products_count > 0 -%}
  {%- comment -%}
    Carousel HTML returned to fetch callers (?section_id=…). The
    [data-cf-related-payload] wrapper is only a marker so the loader can
    pluck this block out of the response.
  {%- endcomment -%}
  <div data-cf-related-payload>
    <div class="compact-carousel-section">
      <h3>{{ section.settings.heading | default: 'You May Also Like' }}</h3>
      <div class="compact-carousel-wrap" id="carousel-cf-related-{{ section.id }}">
        <button
          class="compact-carousel-nav prev"
          type="button"
          onclick="slideCarousel('carousel-cf-related-{{ section.id }}', -1)"
          aria-label="Previous"
        >&lsaquo;</button>
        <div class="compact-carousel-track">
          {%- for rp in recommendations.products limit: section.settings.limit -%}
            <div class="compact-carousel-card">
              <a href="{{ rp.url }}">
                {%- if rp.featured_image -%}
                  <img
                    src="{{ rp.featured_image | image_url: width: 140 }}"
                    alt="{{ rp.title | escape }}"
                    class="compact-carousel-card-img"
                    loading="lazy"
                    width="140"
                    height="140"
                  >
                {%- else -%}
                  <div class="compact-carousel-card-img" style="background:#f4f4f4;display:flex;align-items:center;justify-content:center;font-size:10px;color:#888;">No image</div>
                {%- endif -%}
                <div class="compact-carousel-card-info">
                  <div class="compact-carousel-card-title">{{ rp.title }}</div>
                  <div class="compact-carousel-card-price">{{ rp.price | money }}</div>
                </div>
              </a>
              <div class="compact-carousel-card-actions">
                <input type="number" value="1" min="1" aria-label="Quantity">
                <button type="button" onclick="quickAdd({{ rp.variants.first.id }}, this)">Add to Cart</button>
              </div>
            </div>
          {%- endfor -%}
        </div>
        <button
          class="compact-carousel-nav next"
          type="button"
          onclick="slideCarousel('carousel-cf-related-{{ section.id }}', 1)"
          aria-label="Next"
        >&rsaquo;</button>
      </div>
    </div>
  </div>
{%- endif -%}

{%- if section.settings.show_section != false -%}
<script>
  (function () {
    window.cfYouMayLikeSectionId = {{ section.id | json }};
    var DEFAULT_LIMIT  = {{ section.settings.limit  | default: 8         | json }};
    var DEFAULT_INTENT = {{ section.settings.intent | default: 'related' | json }};

    function load() {
      var nodes = document.querySelectorAll('[data-cf-related-inline]:not([data-cf-loaded])');
      nodes.forEach(function (el) {
        var pid    = el.getAttribute('data-product-id');
        var sid    = window.cfYouMayLikeSectionId;
        var limit  = el.getAttribute('data-limit')  || DEFAULT_LIMIT;
        var intent = el.getAttribute('data-intent') || DEFAULT_INTENT;
        if (!pid || !sid) { el.setAttribute('data-cf-loaded', '1'); return; }
        var url = '/recommendations/products'
          + '?section_id=' + encodeURIComponent(sid)
          + '&product_id=' + encodeURIComponent(pid)
          + '&limit='      + encodeURIComponent(limit)
          + '&intent='     + encodeURIComponent(intent);
        fetch(url, { credentials: 'same-origin' })
          .then(function (r) { return r.text(); })
          .then(function (html) {
            var wrap = document.createElement('div');
            wrap.innerHTML = html.trim();
            var payload = wrap.querySelector('[data-cf-related-payload]');
            if (payload) { el.innerHTML = payload.innerHTML; }
            el.setAttribute('data-cf-loaded', '1');
          })
          .catch(function () { el.setAttribute('data-cf-loaded', '1'); });
      });
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', load);
    } else {
      load();
    }
  })();
</script>
{%- endif -%}

{% schema %}
{
  "name": "CF You May Also Like",
  "tag": "section",
  "class": "cf-you-may-like-section",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_section",
      "label": "Show \"You May Also Like\" section",
      "info": "Toggle the recommendations carousel at the bottom of the product page on or off.",
      "default": true
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "You May Also Like"
    },
    {
      "type": "select",
      "id": "intent",
      "label": "Recommendation Intent",
      "default": "related",
      "options": [
        { "value": "related",       "label": "Related products" },
        { "value": "complementary", "label": "Complementary products" }
      ]
    },
    {
      "type": "range",
      "id": "limit",
      "label": "Number of products",
      "min": 4,
      "max": 16,
      "step": 1,
      "default": 8
    }
  ],
  "presets": [
    { "name": "CF You May Also Like" }
  ],
  "enabled_on": {
    "templates": ["product"]
  }
}
{% endschema %}
