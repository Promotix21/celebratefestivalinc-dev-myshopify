NODE_ENV=production
PORT=3000

# --- MySQL ---
# IMPORTANT: use 127.0.0.1 on Hostinger (not "localhost" — resolves to ::1)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=u603392249_cfchatbot
DB_USER=u603392249_cfchatbot
DB_PASSWORD=

# --- Gemini ---
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# --- Shopify ---
SHOPIFY_STORE=celebratefestivalinc.myshopify.com
SHOPIFY_API_TOKEN=
SHOPIFY_API_VERSION=2024-01

# --- SMTP (SMTP2GO) ---
SMTP_HOST=mail.smtp2go.com
SMTP_PORT=2525
SMTP_USER=hiraya
SMTP_PASSWORD=
SMTP_FROM="CF Chatbot <no-reply@hiraya.digital>"
ADMIN_EMAIL=rajesh_kumar@hiraya.digital

# --- Admin dashboard (Basic Auth) ---
# REQUIRED: without these set, /admin returns 503.
ADMIN_USER=
ADMIN_PASS=

# --- Weekly report ---
# Override window (default 7 days) or recipient via ADMIN_EMAIL above.
REPORT_DAYS=7

# --- Pro Mode tuning ---
# Items priced at or above this threshold (cents) trigger the high-value consult nudge.
PRO_HIGH_VALUE_CENTS=500000

# --- CORS ---
ALLOWED_ORIGINS=https://celebratefestivalinc.myshopify.com,https://celebratefestivalinc.com,https://www.celebratefestivalinc.com,https://cf-chatbot.hiraya.digital
